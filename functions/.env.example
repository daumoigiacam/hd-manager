PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# App ID dang dung trong Firestore path: artifacts/{appId}/public/data/...
HD_MANAGER_APP_ID=hd-manager-production

# Public URL sau khi deploy Firebase Hosting.
HD_MANAGER_PUBLIC_URL=https://hd-manager-c5839.web.app

# Tuy chon. Neu bo trong, Functions tu tao tu HD_MANAGER_PUBLIC_URL.
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=

# Bat buoc khi dung SePay webhook tren production.
# Cau hinh cung gia tri nay o SePay de ngan request gia mao.
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_SECRET=

# Danh sach origin duoc phep goi Functions, phan cach bang dau phay.
# Vi du: https://hd-manager-c5839.web.app,capacitor://localhost
HD_MANAGER_ALLOWED_ORIGINS=
