VITE_GEMINI_API_KEY=

# local = store data on this device only.
# cloud = sync data through Firebase Firestore.
VITE_DATA_MODE=cloud

# Firebase web app config.
VITE_HD_APP_ID=hd-manager-production
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Used by APK/EXE when calling Firebase Hosting/Functions for PayOS.
# Example: https://hd-manager-c5839.web.app
# Leave empty only when the app is served directly from Firebase Hosting.
VITE_PAYOS_API_BASE_URL=

# Google Maps Platform key for the in-app delivery map.
# Enable Maps JavaScript API for this key.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=

# Goong Map keys for Vietnam map provider.
# Map Tiles key renders the map. REST API key is reserved for geocoding/directions.
VITE_GOONG_MAPTILES_KEY=
VITE_GOONG_REST_API_KEY=

# Performance Monitor.
# Keep disabled in normal production builds. Use ?perfCheck=1 or set true only when auditing.
VITE_PERFORMANCE_MONITOR=false
VITE_PERFORMANCE_LOG_LIMIT=800
VITE_PERFORMANCE_CONSOLE=false

# Firebase Performance Monitoring.
# Keep disabled unless you are measuring production/device performance.
VITE_FIREBASE_PERFORMANCE=false
