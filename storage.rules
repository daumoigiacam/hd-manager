rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Basic production guardrail: only authenticated app sessions can read/write
    // uploaded images and documents. Use Firebase Auth custom claims later for
    // strict per-company paths such as companies/{companyId}/...
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
