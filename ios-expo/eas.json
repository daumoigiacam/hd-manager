{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_HD_MANAGER_URL": "https://hd-manager-c5839.web.app"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_HD_MANAGER_URL": "https://hd-manager-c5839.web.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_HD_MANAGER_URL": "https://hd-manager-c5839.web.app"
      }
    }
  }
}
