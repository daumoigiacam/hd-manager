};

const getCustomerLoyaltySettings = (company = null) => {
  const earnAmountPerPoint = parseInt(company?.loyaltyEarnAmountPerPoint, 10);
  const redeemValuePerPoint = parseInt(company?.loyaltyRedeemValuePerPoint, 10);

  return {
    enabled: company?.customerLoyaltyEnabled === true,
    earnAmountPerPoint: earnAmountPerPoint > 0 ? earnAmountPerPoint : DEFAULT_CUSTOMER_LOYALTY_SETTINGS.earnAmountPerPoint,
    redeemValuePerPoint: redeemValuePerPoint > 0 ? redeemValuePerPoint : DEFAULT_CUSTOMER_LOYALTY_SETTINGS.redeemValuePerPoint
  };
};

const calculateCustomerLoyaltySummary = ({ customer = {}, ledger = null, company = null } = {}) => {
  const loyaltySettings = getCustomerLoyaltySettings(company);
  const eligibleAmount = Math.max(0, roundMoneyValue(ledger?.totalPaid ?? customer?.totalPaid ?? 0));
  const manualBonusPoints = Math.max(0, parseInt(customer?.bonusLoyaltyPoints, 10) || 0);
  const usedPoints = Math.max(0, parseInt(customer?.usedLoyaltyPoints, 10) || 0);
  const earnedPoints = loyaltySettings.enabled ? Math.floor(eligibleAmount / loyaltySettings.earnAmountPerPoint) : 0;
  const currentPoints = Math.max(0, earnedPoints + manualBonusPoints - usedPoints);

  return {
    ...loyaltySettings,
    eligibleAmount,
    earnedPoints,
    manualBonusPoints,
    usedPoints,
    currentPoints,
    redeemValue: roundMoneyValue(currentPoints * loyaltySettings.redeemValuePerPoint)
  };
};

