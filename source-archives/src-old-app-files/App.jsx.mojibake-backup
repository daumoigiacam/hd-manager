  if (period === 'quarters') return { monthsPerCycle: 3, label: 'quÄ‚â€Ă¢â‚¬ÂÄ‚â€Ă‚Â½' };
  if (period === 'years') return { monthsPerCycle: 12, label: 'nĂ„â€Ă¢â‚¬ÂÄ‚â€ Ă¢â‚¬â„¢m' };
