function FinanceView({ isAccounting, employee, expenses, payments, orders, onAddExpense, onAddPayment, onDeleteExpense, onDeletePayment, employees, customers, searchKeyword: externalSearchKeyword, setSearchKeyword: setExternalSearchKeyword, showSearchBox: externalShowSearchBox, setShowSearchBox: setExternalShowSearchBox, showFilterPanel: externalShowFilterPanel, setShowFilterPanel: setExternalShowFilterPanel }) {
  const [filterDate, setFilterDate] = useState(getTodayString());
  const [periodType, setPeriodType] = useState('day');
  const [transactionTypeFilter, setTransactionTypeFilter] = useState('all');
  const [localSearchKeyword, setLocalSearchKeyword] = useState('');
  const [localShowSearchBox, setLocalShowSearchBox] = useState(false);
  const [localShowFilterPanel, setLocalShowFilterPanel] = useState(false);
  const [showExpenseModal, setShowExpenseModal] = useState(false);
  const [showPaymentModal, setShowPaymentModal] = useState(false);
  const [newExpense, setNewExpense] = useState({ category: 'Chi mua hĂ ng hĂ³a', customCategory: '', amount: '', note: '', date: getTodayString() });
  const [newPayment, setNewPayment] = useState({
    customerId: '',
    amount: '',
    note: '',
    date: getTodayString(),
    method: 'Tiá»n máº·t',
    sourceType: 'driver_cash'
  });

  const expenseCategories = useMemo(() => {
    const base = ['Chi mua hĂ ng hĂ³a', 'Chi xÄƒng dáº§u', 'Chi phĂ­ vÄƒn phĂ²ng', 'Chi phĂ­ khĂ¡c'];
    const dynamic = [...new Set(expenses.map(expense => normalizeExpenseCategoryLabel(expense.category)).filter(Boolean))];
    return [...new Set([...base, ...dynamic])];
  }, [expenses]);
  const normalizedExpenseCategory = normalizeExpenseCategoryLabel(newExpense.category);
  const isNewExpenseCategory = Boolean(normalizedExpenseCategory) && !expenseCategories.includes(normalizedExpenseCategory);

  const employeeNameMap = useMemo(
    () => Object.fromEntries(employees.map(emp => [emp.id, emp.name])),
    [employees]
  );

  const customerNameMap = useMemo(
    () => Object.fromEntries(customers.map(customer => [customer.id, customer.name])),
    [customers]
  );
  const searchKeyword = externalSearchKeyword ?? localSearchKeyword;
  const setSearchKeyword = setExternalSearchKeyword ?? setLocalSearchKeyword;
  const showSearchBox = externalShowSearchBox ?? localShowSearchBox;
  const setShowSearchBox = setExternalShowSearchBox ?? setLocalShowSearchBox;
  const showFilterPanel = externalShowFilterPanel ?? localShowFilterPanel;
  const setShowFilterPanel = setExternalShowFilterPanel ?? setLocalShowFilterPanel;

  const periodRange = useMemo(
    () => getDateRangeForPeriod(filterDate, periodType),
    [filterDate, periodType]
  );

  const periodLabel = useMemo(
    () => buildPeriodLabel(periodType, periodRange),
    [periodType, periodRange]
  );

  const customerLedgerMap = useMemo(() => Object.fromEntries(
    customers.map(customer => [customer.id, buildCustomerLedger(customer.id, orders, payments)])
  ), [customers, orders, payments]);

  const paymentStatusMap = useMemo(() => {
    const map = {};
    Object.values(customerLedgerMap).forEach(ledger => {
      ledger.payments.forEach(payment => {
        map[payment.id] = payment;
      });
    });
    return map;
  }, [customerLedgerMap]);

  const periodTransactions = useMemo(() => {
    const list = [
      ...expenses
        .filter(expense => !expense.isArchived && expense.date >= periodRange.startDate && expense.date <= periodRange.endDate)
        .map(expense => ({ ...expense, transactionType: 'expense' })),
      ...payments
        .filter(payment => !payment.isArchived && payment.date >= periodRange.startDate && payment.date <= periodRange.endDate)
        .map(payment => ({
        ...payment,
        ...(paymentStatusMap[payment.id] || {}),
        transactionType: 'payment'
      }))
    ];

    return list.sort((a, b) => {
      if ((b.date || '') !== (a.date || '')) return (b.date || '').localeCompare(a.date || '');
      return (b.id || '').localeCompare(a.id || '');
    });
  }, [expenses, payments, paymentStatusMap, periodRange]);

  const filteredTransactions = useMemo(() => {
    const keyword = searchKeyword.trim().toLowerCase();

    return periodTransactions.filter(transaction => {
      if (transactionTypeFilter !== 'all' && transaction.transactionType !== transactionTypeFilter) return false;
      if (!keyword) return true;

      const employeeName = employeeNameMap[transaction.empId] || 'KĂ¡ÂºÂ¿ toÄ‚Â¡n';
      const customerName = customerNameMap[transaction.customerId] || 'KhÄ‚Â¡ch hÄ‚Â ng';
      const haystack = [
        transaction.note,
        transaction.category,
        customerName,
        transaction.date,
        employeeName,
        formatCurrency(transaction.amount),
        getPaymentMethodLabel(transaction),
        getPaymentSourceLabel(transaction)
      ].filter(Boolean).join(' ').toLowerCase();

      return haystack.includes(keyword);
    });
  }, [periodTransactions, transactionTypeFilter, searchKeyword, employeeNameMap, customerNameMap]);

  const totalExpense = filteredTransactions.filter(item => item.transactionType === 'expense').reduce((sum, item) => sum + (item.amount || 0), 0);
  const totalIncome = filteredTransactions.filter(item => item.transactionType === 'payment').reduce((sum, item) => sum + (item.amount || 0), 0);
  const balance = totalIncome - totalExpense;

  const handleResetFilters = () => {
    setFilterDate(getTodayString());
    setPeriodType('day');
    setTransactionTypeFilter('all');
    setSearchKeyword('');
    setShowSearchBox(false);
    setShowFilterPanel(false);
  };

  const handleExpenseSubmit = (e) => {
    e.preventDefault();
    const selectedCategory = normalizeExpenseCategoryLabel(newExpense.category);
    if (!selectedCategory || !newExpense.amount) return;

    onAddExpense({
      category: selectedCategory,
      amount: parseInputCurrency(newExpense.amount),
      note: normalizeLeadingLabel(newExpense.note),
      date: newExpense.date
