  const [editingProd, setEditingProd] = useState(null);
  const [productSearch, setProductSearch] = useState('');
  const [selectedUnit, setSelectedUnit] = useState('Táº¥t cáº£');
  const [discountFilter, setDiscountFilter] = useState('Táº¥t cáº£');
  
  const [prodData, setProdData] = useState({ 
    name: '', category: '', unit: 'CĂ¡i', costPrice: '', sellingPrice: '', 
    barcode: '', image: '', discount: '' 
  });
  const [barcodeScanStatus, setBarcodeScanStatus] = useState('');
  const barcodeImageInputRef = useRef(null);

  const [activeCategory, setActiveCategory] = useState('Táº¥t cáº£');

  const activeProducts = products.filter(p => !!p.isArchived === showArchived);
  const allCategories = useMemo(() => [...new Set(products.map(p => p.category).filter(Boolean))], [products]);
  const normalizedCategory = prodData.category.trim().toLowerCase();
  const isNewCategory = normalizedCategory && !allCategories.some(category => category.toLowerCase() === normalizedCategory);
  
  const categories = useMemo(() => {
    const cats = activeProducts.map(p => p.category).filter(Boolean);
    return ['Táº¥t cáº£', ...new Set(cats)];
  }, [activeProducts]);

  const units = useMemo(() => {
    const list = activeProducts.map(p => p.unit).filter(Boolean);
    return ['Táº¥t cáº£', ...new Set(list)];
  }, [activeProducts]);

  const displayedProducts = useMemo(() => {
    const keyword = productSearch.trim().toLowerCase();

    return activeProducts.filter(p => {
      if (activeCategory !== 'Táº¥t cáº£' && p.category !== activeCategory) return false;
      if (selectedUnit !== 'Táº¥t cáº£' && p.unit !== selectedUnit) return false;
      if (discountFilter === 'Äang giáº£m giĂ¡' && !(p.discount > 0)) return false;
      if (discountFilter === 'KhĂ´ng giáº£m giĂ¡' && p.discount > 0) return false;

      if (!keyword) return true;

      const haystack = [
        p.name,
        p.category,
        p.unit,
        p.barcode
      ].filter(Boolean).join(' ').toLowerCase();

      return haystack.includes(keyword);
    });
  }, [activeProducts, activeCategory, selectedUnit, discountFilter, productSearch]);

  useEffect(() => {
    if (!categories.includes(activeCategory)) setActiveCategory('Táº¥t cáº£');
  }, [categories, activeCategory]);

  useEffect(() => {
    if (!units.includes(selectedUnit)) setSelectedUnit('Táº¥t cáº£');
  }, [units, selectedUnit]);

  const resetProductFilters = () => {
    setProductSearch('');
    setActiveCategory('Táº¥t cáº£');
    setSelectedUnit('Táº¥t cáº£');
    setDiscountFilter('Táº¥t cáº£');
  };

  const handleOpenEdit = (p) => {
    setEditingProd(p);
    setBarcodeScanStatus('');
    setProdData({ 
      name: p.name, category: p.category, unit: p.unit, 
      costPrice: p.costPrice || '', sellingPrice: p.sellingPrice || '',
      barcode: p.barcode || '', image: p.image || '', discount: p.discount || ''
    });
    setShowForm(true);
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const pData = { 
      ...prodData, 
      costPrice: parseInt(prodData.costPrice) || 0, 
      sellingPrice: parseInt(prodData.sellingPrice) || 0,
      discount: parseInt(prodData.discount) || 0
    };
    if (editingProd) onEditProduct(editingProd.id, pData); 
    else onAddProduct(pData);
    setBarcodeScanStatus('');
    setShowForm(false);
  };

  const handleImageUpload = (e) => {
    const file = e.target.files[0];
    if (file) {
      if (file.size > 500000) {
        alert("Vui lĂ²ng chá»n áº£nh cĂ³ kĂ­ch thÆ°á»›c nhá» hÆ¡n 500KB Ä‘á»ƒ tá»‘i Æ°u tá»‘c Ä‘á»™.");
        return;
      }
      const reader = new FileReader();
      reader.onloadend = () => setProdData({...prodData, image: reader.result});
      reader.readAsDataURL(file);
    }
  };

  const handleBarcodeImageScan = async (file) => {
    if (!file) return;

    if (typeof window === 'undefined' || !('BarcodeDetector' in window)) {
      setBarcodeScanStatus('TrĂ¬nh duyá»‡t hiá»‡n táº¡i chÆ°a há»— trá»£ Ä‘á»c mĂ£ tá»« áº£nh. Báº¡n váº«n cĂ³ thá»ƒ nháº­p tay mĂ£ váº¡ch hoáº·c SKU.');
