      chipClasses: 'bg-emerald-50 text-emerald-700',
      amountClasses: 'text-emerald-600'
    };
  };

  const buildOrderShareText = (order) => {
    if (!order) return '';

    const itemLines = (order.items || []).map((item, index) => {
      const lineTotal = (parseFloat(item.quantity) || 0) * (parseFloat(item.unitPrice) || 0);
      return `${index + 1}. ${item.description || 'Sáº£n pháº©m'} - ${formatNumber(parseFloat(item.quantity) || 0)} x ${formatCurrency(parseFloat(item.unitPrice) || 0)} Ä‘ = ${formatCurrency(lineTotal)} Ä‘`;
    });

    const textLines = [
