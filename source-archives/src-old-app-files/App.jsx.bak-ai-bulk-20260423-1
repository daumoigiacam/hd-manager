const calculateSalaryDetails = (empId, employees, attendance, financials, performance, allCustomers = [], allOrders = [], allPayments = [], holidays = []) => {
  const emp = employees.find(e => e.id === empId);
  if (!emp) return null;

  const perf = performance[empId] || { revenue: 0, overtime: 0 };
  let workDaysProbation = 0;
  let workDaysOfficial = 0;
  let holidayBonus = 0;

  const salaryMonthDays = resolveSalaryMonthDays(emp);
  const dailyBaseWage = (emp.basicSalary || 0) / salaryMonthDays;
  const dailySupportWage = (emp.supportSalary || 0) / salaryMonthDays;
  const probationRate = (emp.probationRate !== undefined ? emp.probationRate : 100) / 100;

  const probationEndDate = resolveProbationEndDate(emp.startDate, emp.probationDuration, emp.probationUnit);

  Object.keys(attendance).forEach(key => {
    if (!key.endsWith(`_${empId}`)) return;
    const rec = attendance[key];
    const dateStr = key.split('_')[0];

    if (rec.status !== 'present' && rec.status !== 'late') return;

    const workDate = parseDateInputValue(dateStr);
    if (probationEndDate && workDate <= probationEndDate) workDaysProbation += 1;
    else workDaysOfficial += 1;

    const isHoliday = holidays.find(h => h.date === dateStr);
    if (isHoliday) {
      if (isHoliday.type === 'fixed') holidayBonus += isHoliday.value;
      else if (isHoliday.type === 'percentage') holidayBonus += dailyBaseWage * (isHoliday.value / 100);
    }
  });

  const workDays = workDaysProbation + workDaysOfficial;
  const baseSalaryCalc = roundMoneyValue((workDaysProbation * dailyBaseWage * probationRate) + (workDaysOfficial * dailyBaseWage));
  const supportSalaryCalc = roundMoneyValue((workDaysProbation * dailySupportWage * probationRate) + (workDaysOfficial * dailySupportWage));

  const experienceDetails = calculateExperienceSalary(emp.startDate, emp.experienceSalary || 0, emp.experienceSalaryPeriod || 'months');
  const experienceSalaryCalc = roundMoneyValue(experienceDetails.total);
  const expMonths = experienceDetails.expMonths;
  const experienceCycles = experienceDetails.experienceCycles;
  const experienceCycleLabel = experienceDetails.experienceCycleLabel;

  const effectiveRevenue = isSalesPosition(emp.position) ? calculateMonthRevenue(empId, allOrders, allCustomers) : (perf.revenue || 0);
  const commission = roundMoneyValue(calculateCommission(effectiveRevenue || 0, emp.targetRevenue || 0, emp.commissionRate || 0));
  const tieredBonus = 0;
  const overtimePay = roundMoneyValue((perf.overtime || 0) * (emp.overtimeRate || 0));

  let totalBonus = 0;
  let totalPenalty = 0;
  let totalAdvance = 0;
  financials.filter(f => f.empId === empId && !f.isArchived).forEach(record => {
    if (record.type === 'bonus') totalBonus += record.amount;
    if (record.type === 'penalty') totalPenalty += record.amount;
    if (record.type === 'advance') totalAdvance += record.amount;
  });

  holidayBonus = roundMoneyValue(holidayBonus);
  totalBonus += holidayBonus;
  totalBonus = roundMoneyValue(totalBonus);
  totalPenalty = roundMoneyValue(totalPenalty);
  totalAdvance = roundMoneyValue(totalAdvance);

  let badDebt = 0;
  if (isSalesPosition(emp.position)) {
    const myCustomers = allCustomers.filter(c => c.empId === empId);
    badDebt = myCustomers.reduce((sum, cus) => sum + getCustomerDebt(cus.id, allOrders, allPayments), 0);
    if (badDebt < 0) badDebt = 0;
  }
  badDebt = roundMoneyValue(badDebt);

  const netSalary = roundMoneyValue(baseSalaryCalc + supportSalaryCalc + experienceSalaryCalc + commission + tieredBonus + overtimePay + totalBonus - totalPenalty - totalAdvance - badDebt);

  return {
    workDays,
    workDaysProbation,
    workDaysOfficial,
    expMonths,
    experienceCycles,
    experienceCycleLabel,
    perf: { ...perf, revenue: effectiveRevenue },
    baseSalaryCalc,
    supportSalary: supportSalaryCalc,
    experienceSalary: experienceSalaryCalc,
    commission,
    tieredBonus,
    overtimePay,
    totalBonus,
    holidayBonus,
    totalPenalty,
    totalAdvance,
    badDebt,
    netSalary
  };
};

const buildSalaryDetails = (empId, employees, attendance, financials, performance, allCustomers = [], allOrders = [], allPayments = [], holidays = [], monthKey = getTodayString().substring(0, 7)) => {
  const emp = employees.find(e => e.id === empId);
  if (!emp) return null;

  const perf = performance[empId] || { revenue: 0, overtime: 0 };
  const salaryMonthDays = resolveSalaryMonthDays(emp);
  const dailyBaseWage = (emp.basicSalary || 0) / salaryMonthDays;
  const dailySupportWage = (emp.supportSalary || 0) / salaryMonthDays;
  const probationRate = (emp.probationRate !== undefined ? emp.probationRate : 100) / 100;

  let workDaysProbation = 0;
  let workDaysOfficial = 0;
  let holidayBonus = 0;

  const probationEndDate = resolveProbationEndDate(emp.startDate, emp.probationDuration, emp.probationUnit);

  const attendanceEntries = Object.keys(attendance)
    .filter(key => key.endsWith(`_${empId}`) && key.startsWith(monthKey))
    .map(key => {
      const rec = attendance[key];
      const dateStr = key.split('_')[0];
      return {
        date: dateStr,
        status: rec?.status || 'missing',
        checkIn: rec?.checkIn || null,
        checkOut: rec?.checkOut || null,
        checkInMethod: rec?.checkInMethod || '',
        checkOutMethod: rec?.checkOutMethod || ''
      };
    })
    .sort((a, b) => new Date(a.date) - new Date(b.date));

  attendanceEntries.forEach(entry => {
    if (entry.status === 'present' || entry.status === 'late') {
      const workDate = parseDateInputValue(entry.date);
      if (probationEndDate && workDate <= probationEndDate) workDaysProbation += 1;
      else workDaysOfficial += 1;

      const isHoliday = holidays.find(h => h.date === entry.date);
      if (isHoliday) {
        if (isHoliday.type === 'fixed') holidayBonus += isHoliday.value;
        else if (isHoliday.type === 'percentage') holidayBonus += dailyBaseWage * (isHoliday.value / 100);
      }
    }
  });

  const workDays = workDaysProbation + workDaysOfficial;
  const baseSalaryCalc = roundMoneyValue((workDaysProbation * dailyBaseWage * probationRate) + (workDaysOfficial * dailyBaseWage));
  const supportSalaryCalc = roundMoneyValue((workDaysProbation * dailySupportWage * probationRate) + (workDaysOfficial * dailySupportWage));
  const responsibilitySalaryCalc = roundMoneyValue(((emp.responsibilitySalary || 0) / STANDARD_WORK_DAYS) * workDays);

  const experienceDetails = calculateExperienceSalary(emp.startDate, emp.experienceSalary || 0, emp.experienceSalaryPeriod || 'months');
  const experienceSalaryCalc = roundMoneyValue(experienceDetails.total);
  const expMonths = experienceDetails.expMonths;
  const experienceCycles = experienceDetails.experienceCycles;
  const experienceCycleLabel = experienceDetails.experienceCycleLabel;

  const effectiveRevenue = isSalesPosition(emp.position)
    ? calculateRevenueForMonth(empId, allOrders, allCustomers, monthKey)
    : (perf.revenue || 0);
  const commission = roundMoneyValue(calculateCommission(effectiveRevenue || 0, emp.targetRevenue || 0, emp.commissionRate || 0));
  const tieredBonus = 0;
  const overtimePay = roundMoneyValue((perf.overtime || 0) * (emp.overtimeRate || 0));

  const monthlyFinancials = financials
    .filter(f => f.empId === empId && !f.isArchived && (!f.date || f.date.startsWith(monthKey)))
    .sort((a, b) => new Date(a.date || 0) - new Date(b.date || 0));

  const bonusRecords = monthlyFinancials.filter(record => record.type === 'bonus');
  const penaltyRecords = monthlyFinancials.filter(record => record.type === 'penalty');
  const advanceRecords = monthlyFinancials.filter(record => record.type === 'advance');

  let totalBonus = bonusRecords.reduce((sum, record) => sum + (record.amount || 0), 0);
  const totalPenalty = penaltyRecords.reduce((sum, record) => sum + (record.amount || 0), 0);
  const totalAdvance = advanceRecords.reduce((sum, record) => sum + (record.amount || 0), 0);

  holidayBonus = roundMoneyValue(holidayBonus);
  totalBonus += holidayBonus;
  totalBonus = roundMoneyValue(totalBonus);
  const roundedTotalPenalty = roundMoneyValue(totalPenalty);
  const roundedTotalAdvance = roundMoneyValue(totalAdvance);

  let badDebt = 0;
  if (isSalesPosition(emp.position)) {
    const myCustomers = allCustomers.filter(c => c.empId === empId);
    badDebt = myCustomers.reduce((sum, cus) => sum + getCustomerDebt(cus.id, allOrders, allPayments), 0);
    if (badDebt < 0) badDebt = 0;
  }
  badDebt = roundMoneyValue(badDebt);

  const grossSalary = roundMoneyValue(baseSalaryCalc + supportSalaryCalc + responsibilitySalaryCalc + experienceSalaryCalc + commission + tieredBonus + overtimePay + totalBonus);
  const deductionTotal = roundMoneyValue(roundedTotalPenalty + roundedTotalAdvance + badDebt);
  const netSalary = roundMoneyValue(grossSalary - deductionTotal);

  return {
    monthKey,
    workDays,
    workDaysProbation,
    workDaysOfficial,
    expMonths,
    experienceCycles,
    experienceCycleLabel,
    perf: { ...perf, revenue: effectiveRevenue },
    baseSalaryCalc,
    supportSalary: supportSalaryCalc,
    responsibilitySalary: responsibilitySalaryCalc,
    experienceSalary: experienceSalaryCalc,
    commission,
    tieredBonus,
    overtimePay,
    totalBonus,
    holidayBonus,
    totalPenalty: roundedTotalPenalty,
    totalAdvance: roundedTotalAdvance,
    badDebt,
    grossSalary,
    deductionTotal,
    netSalary,
    attendanceEntries,
    bonusRecords,
    penaltyRecords,
    advanceRecords
  };
};

