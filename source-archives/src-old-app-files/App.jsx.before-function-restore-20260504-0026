        <button onClick={() => setIsOpen(true)} className="bg-gradient-to-r from-emerald-500 to-teal-500 text-white p-3.5 rounded-full shadow-[0_4px_20px_rgba(16,185,129,0.5)] flex items-center justify-center hover:scale-105 transition-transform active:scale-95 border-2 border-white">
          <Sparkles size={24} className="animate-pulse" />
        </button>
      </div>

      {isOpen && (
        <div className="fixed inset-0 bg-black/50 z-[60] flex items-end sm:items-center justify-center p-0 sm:p-4 backdrop-blur-sm">
          <div className="bg-gray-50 w-full h-[85vh] sm:h-[600px] sm:max-w-md sm:rounded-2xl rounded-t-3xl shadow-2xl flex flex-col animate-in slide-in-from-bottom-full duration-300 overflow-hidden border border-gray-200">
            <div className="bg-gradient-to-r from-emerald-600 to-emerald-500 text-white p-4 flex justify-between items-center shrink-0 shadow-sm">
              <div className="flex items-center gap-3">
                <div className="bg-white/20 p-2 rounded-full shadow-inner"><Bot size={22} /></div>
                <div>
                  <h3 className="font-bold text-sm flex items-center gap-1">Trợ lý AI <span className="bg-emerald-400 text-[9px] px-1.5 py-0.5 rounded-full uppercase tracking-wider">Pro</span></h3>
        <p className="text-[10px] text-emerald-100 font-medium">{hasCloudAi ? 'Trực tuyến' : 'Demo local'} • Hỗ trợ {getEmployeePositionLabel(employee?.position)}</p>
                </div>
              </div>
              <button onClick={() => setIsOpen(false)} className="hover:bg-white/20 p-1.5 rounded-full transition-colors"><X size={20} /></button>
            </div>
            
            <div className="flex-1 overflow-y-auto p-4 space-y-5 flex flex-col">
              {messages.map((msg, idx) => (
                <div key={idx} className={`max-w-[85%] rounded-2xl px-4 py-3 text-sm leading-relaxed ${msg.role === 'model' ? 'bg-white border border-gray-100 text-gray-800 self-start shadow-sm rounded-tl-sm' : 'bg-emerald-500 text-white self-end shadow-md rounded-tr-sm'}`}>
                  {msg.text}
                </div>
              ))}
              {isLoading && (
                <div className="bg-white border border-gray-100 text-gray-500 self-start shadow-sm rounded-2xl rounded-tl-sm px-4 py-3 flex items-center gap-2 text-sm font-medium">
                  <Loader2 size={16} className="animate-spin text-emerald-500" /> AI đang phân tích dữ liệu...
                </div>
              )}
            </div>

            <div className="p-3 bg-white border-t border-gray-100 shrink-0 pb-safe">
              <form onSubmit={handleSend} className="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-full p-1.5 pl-4 focus-within:border-emerald-400 focus-within:ring-2 focus-within:ring-emerald-100 transition-all">
                <input type="text" value={input} onChange={e => setInput(capitalizeFirst(e.target.value))} placeholder="Nhập câu hỏi tại đây..." className="flex-1 bg-transparent border-none outline-none text-sm text-gray-700 placeholder-gray-400" />
                <button type="submit" disabled={isLoading || !input.trim()} className="bg-emerald-500 text-white p-2.5 rounded-full hover:bg-emerald-600 disabled:opacity-50 transition-colors shadow-sm">
                  <Send size={16} className="ml-0.5" />
                </button>
              </form>
            </div>
          </div>
        </div>
      )}
    </>
  );
}

// --- APP ENTRY POINT ---
export default function App() {
  const [firebaseUser, setFirebaseUser] = useState(null);
  const [isFirebaseLoading, setIsFirebaseLoading] = useState(true);
  const persistedSession = useMemo(() => loadAppSession(), []);

  const [currentUser, setCurrentUser] = useState(persistedSession.currentUser); 
  const [currentCompany, setCurrentCompany] = useState(persistedSession.currentCompany);
  const [activeTab, setActiveTab] = useState(persistedSession.activeTab);
  const [currentDate, setCurrentDate] = useState(getTodayString());

  // RAW DATA
  const [rawCompanies, setRawCompanies] = useState([]);
  const [rawEmployees, setRawEmployees] = useState([]);
  const [rawAttendance, setRawAttendance] = useState({});
  const [rawFinancials, setRawFinancials] = useState([]);
  const [rawAdvanceRequests, setRawAdvanceRequests] = useState([]); 
  const [rawPerformance, setRawPerformance] = useState({});
  const [rawCustomers, setRawCustomers] = useState([]);
  const [rawProducts, setRawProducts] = useState([]);
  const [rawOrders, setRawOrders] = useState([]);
  const [rawOrderRequests, setRawOrderRequests] = useState([]);
  const [rawWarehouseDispatches, setRawWarehouseDispatches] = useState([]);
  const [rawPayments, setRawPayments] = useState([]);
  const [rawExpenses, setRawExpenses] = useState([]); 
  const [rawHolidays, setRawHolidays] = useState([]);

  useEffect(() => {
    saveAppSession({ currentUser, currentCompany, activeTab });
  }, [currentUser, currentCompany, activeTab]);

  useEffect(() => {
    if (!isFirebaseConfigured) return;
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) { console.error("Lỗi xác thực:", err); }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, (u) => { setFirebaseUser(u); setIsFirebaseLoading(false); });
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (!firebaseUser || !isFirebaseConfigured) return;
    const listeners = [];

    const bindCollection = (colName, setFn, isObject = false, parser = null) => {
      const unsub = onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', colName), (snap) => {
        if (isObject) {
          const obj = {};
          snap.forEach(d => { obj[d.id] = parser ? parser(d.data()) : d.data(); });
          setFn(obj);
        } else {
          const arr = [];
          snap.forEach(d => { arr.push(parser ? parser(d.data()) : d.data()); });
          setFn(arr);
        }
      }, console.error);
      listeners.push(unsub);
    };

    bindCollection('companies', setRawCompanies);
    bindCollection('employees', setRawEmployees);
    bindCollection('customers', setRawCustomers);
    bindCollection('products', setRawProducts);
    bindCollection('orders', setRawOrders);
    bindCollection('orderRequests', setRawOrderRequests);
    bindCollection('warehouseDispatches', setRawWarehouseDispatches);
    bindCollection('payments', setRawPayments);
    bindCollection('advances', setRawAdvanceRequests);
    bindCollection('financials', setRawFinancials);
    bindCollection('expenses', setRawExpenses);
    bindCollection('holidays', setRawHolidays); 
    bindCollection('performance', setRawPerformance, true);
    bindCollection('attendance', setRawAttendance, true, (data) => ({
      ...data,
      checkIn: data.checkIn ? new Date(data.checkIn) : null,
      checkOut: data.checkOut ? new Date(data.checkOut) : null,
    }));

    return () => { listeners.forEach(unsub => unsub()); };
  }, [firebaseUser]);

  useEffect(() => {
    if (!currentUser) return;
    const matchedCompany = rawCompanies.find(comp => comp.id === currentUser.companyId);
    if (matchedCompany && matchedCompany.id !== currentCompany?.id) {
      setCurrentCompany(matchedCompany);
    }
  }, [rawCompanies, currentUser, currentCompany]);

  const myCompanyId = currentUser?.companyId;

  const employees = useMemo(() => rawEmployees.filter(e => e.companyId === myCompanyId), [rawEmployees, myCompanyId]);
  const customers = useMemo(() => rawCustomers.filter(c => c.companyId === myCompanyId), [rawCustomers, myCompanyId]);
  const products = useMemo(() => rawProducts.filter(p => p.companyId === myCompanyId), [rawProducts, myCompanyId]);
  const orders = useMemo(() => rawOrders.filter(o => o.companyId === myCompanyId), [rawOrders, myCompanyId]);
  const orderRequests = useMemo(() => rawOrderRequests.filter(request => request.companyId === myCompanyId), [rawOrderRequests, myCompanyId]);
  const warehouseDispatches = useMemo(() => rawWarehouseDispatches.filter(dispatch => dispatch.companyId === myCompanyId), [rawWarehouseDispatches, myCompanyId]);
  const payments = useMemo(() => rawPayments.filter(p => p.companyId === myCompanyId), [rawPayments, myCompanyId]);
  const expenses = useMemo(() => rawExpenses.filter(e => e.companyId === myCompanyId), [rawExpenses, myCompanyId]);
  const advanceRequests = useMemo(() => rawAdvanceRequests.filter(a => a.companyId === myCompanyId), [rawAdvanceRequests, myCompanyId]);
  const financials = useMemo(() => rawFinancials.filter(f => f.companyId === myCompanyId), [rawFinancials, myCompanyId]);
  const holidays = useMemo(() => rawHolidays.filter(h => h.companyId === myCompanyId), [rawHolidays, myCompanyId]);
  
  const attendanceRecords = useMemo(() => {
    const filtered = {};
    Object.keys(rawAttendance).forEach(key => {
      if (rawAttendance[key]?.companyId === myCompanyId) filtered[key] = rawAttendance[key];
    });
    return filtered;
  }, [rawAttendance, myCompanyId]);

  const performanceRecords = useMemo(() => {
    const filtered = {};
    Object.keys(rawPerformance).forEach(key => {
      if (rawPerformance[key]?.companyId === myCompanyId) filtered[key] = rawPerformance[key];
    });
    return filtered;
  }, [rawPerformance, myCompanyId]);

  const aggregatedPerformance = useMemo(() => {
    const agg = { ...performanceRecords };
    employees.forEach(emp => {
      if (!agg[emp.id]) agg[emp.id] = { overtime: 0 };
      agg[emp.id].revenue = calculateMonthRevenue(emp.id, orders, customers);
    });
    return agg;
  }, [performanceRecords, orders, employees, customers]);

  const handleRegisterCompany = async (companyName, phone) => {
    if (!firebaseUser) return { success: false, message: "Lỗi kết nối máy chủ." };
    const exist = rawEmployees.find(e => e.phone === phone);
    if (exist) return { success: false, message: "Số điện thoại này đã được đăng ký!" };

    const newCompanyId = `comp_${Date.now()}`;
    const newEmpId = `emp_${Date.now()}`;
    const defaultCompanyPaymentSettings = {
      bankId: DEFAULT_INVOICE_TRANSFER_PROFILE.bankId,
      bankName: DEFAULT_INVOICE_TRANSFER_PROFILE.bankName,
      bankAccountName: DEFAULT_INVOICE_TRANSFER_PROFILE.accountName,
      bankAccountNumber: DEFAULT_INVOICE_TRANSFER_PROFILE.accountNumber,
      invoiceQrTemplate: DEFAULT_INVOICE_TRANSFER_PROFILE.template,
      autoReconcileByOrderCode: true,
      customerLoyaltyEnabled: DEFAULT_CUSTOMER_LOYALTY_SETTINGS.enabled,
      loyaltyEarnAmountPerPoint: DEFAULT_CUSTOMER_LOYALTY_SETTINGS.earnAmountPerPoint,
      loyaltyRedeemValuePerPoint: DEFAULT_CUSTOMER_LOYALTY_SETTINGS.redeemValuePerPoint
    };

    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'companies', newCompanyId), {
      id: newCompanyId, name: companyName, ownerPhone: phone, createdAt: getTodayString(), status: 'trial', expiresAt: new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString(),
      ...defaultCompanyPaymentSettings
    });

    const adminData = {
      id: newEmpId, companyId: newCompanyId, phone: phone, name: 'Chủ doanh nghiệp', position: 'Chủ doanh nghiệp', role: 'super_admin', 
      startDate: getTodayString(), probationDuration: 0, probationUnit: 'days', probationRate: 100,
      basicSalary: 0, supportSalary: 0, responsibilitySalary: 0, experienceSalary: 0, experienceSalaryPeriod: 'months', commissionRate: 0, targetRevenue: 0, overtimeRate: 0, latePenaltyRate: 0
    };
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', newEmpId), adminData);

    setCurrentUser({ role: 'super_admin', id: newEmpId, companyId: newCompanyId });
    setCurrentCompany({ id: newCompanyId, name: companyName, status: 'trial', ...defaultCompanyPaymentSettings });
    setActiveTab('home');
    return { success: true };
  };

  const handleLogin = (phone) => {
    const emp = rawEmployees.find(e => e.phone === phone);
    if (emp) { 
      const comp = rawCompanies.find(c => c.id === emp.companyId);
      setCurrentUser({ role: emp.role || 'employee', id: emp.id, companyId: emp.companyId }); 
      setCurrentCompany(comp);
      setActiveTab('home'); 
      return true; 
    }
    return false;
  };

  const handleLogout = () => { setCurrentUser(null); setCurrentCompany(null); setActiveTab('home'); };

  const handleCheckIn = async (empId, method) => {
    if (!firebaseUser) return;
    const now = new Date(); const key = `${currentDate}_${empId}`;
    const employee = employees.find(emp => emp.id === empId);
    const methodInfo = normalizeAttendanceMethod(method, 'Chấm công');
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'attendance', key), {
      companyId: myCompanyId,
      checkIn: now.toISOString(),
      checkInMethod: methodInfo.label,
      checkInMethodMeta: methodInfo.meta,
      status: calculateCheckInStatus(employee, now, currentDate)
    }, { merge: true });
  };
  
  const handleCheckOut = async (empId, method) => {
    if (!firebaseUser) return;
    const now = new Date(); const key = `${currentDate}_${empId}`;
    const methodInfo = normalizeAttendanceMethod(method, 'Chấm công');
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'attendance', key), {
      companyId: myCompanyId,
      checkOut: now.toISOString(),
      checkOutMethod: methodInfo.label,
      checkOutMethodMeta: methodInfo.meta
    }, { merge: true });
  };
  
  const handleLeave = async (empId) => {
    if (!firebaseUser) return;
    const key = `${currentDate}_${empId}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'attendance', key), { companyId: myCompanyId, status: 'leave', checkIn: null, checkOut: null }, { merge: true });
  };

  const handleEditAttendance = async (empId, targetDate, editData) => {
    if (!firebaseUser) return;
    const key = `${targetDate}_${empId}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'attendance', key), { 
      ...editData, companyId: myCompanyId,
      checkIn: editData.checkIn ? editData.checkIn.toISOString() : null,
      checkOut: editData.checkOut ? editData.checkOut.toISOString() : null,
      checkInMethod: 'Kế toán điều chỉnh' 
    }, { merge: true });
  };

  const handleAddAdvanceRequest = async (empId, amount, reason) => {
    if (!firebaseUser) return;
    const id = `adv_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'advances', id), { id, companyId: myCompanyId, empId, amount: parseInt(amount), reason, date: getTodayString(), status: 'pending' });
  };
  
  const handleApproveAdvance = async (reqId) => {
    if (!firebaseUser) return;
    const req = advanceRequests.find(r => r.id === reqId);
    if (req && req.status === 'pending') {
      await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'advances', reqId), { status: 'approved' }, { merge: true });
      await addFinancialRecord(req.empId, 'advance', req.amount, req.reason);
    }
  };

  const handleRejectAdvance = async (reqId) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'advances', reqId), { status: 'rejected' }, { merge: true });
  };

  const handleToggleArchive = async (collectionName, itemId, currentStatus) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', collectionName, itemId), { isArchived: !currentStatus }, { merge: true });
  };

  const handleUpdateCompanySettings = async (settingsData) => {
    if (!firebaseUser || !myCompanyId) return { success: false, message: 'Phiên làm việc không hợp lệ.' };
    const currentTransferProfile = getInvoiceTransferProfile(currentCompany);
    const currentLoyaltySettings = getCustomerLoyaltySettings(currentCompany);
    const normalizedLoyaltyEarnAmount = parseInt(settingsData.loyaltyEarnAmountPerPoint ?? currentLoyaltySettings.earnAmountPerPoint, 10);
    const normalizedLoyaltyRedeemValue = parseInt(settingsData.loyaltyRedeemValuePerPoint ?? currentLoyaltySettings.redeemValuePerPoint, 10);
    const nextLogoUrl = settingsData.logoUrl !== undefined
      ? `${settingsData.logoUrl || ''}`.trim()
      : getCompanyLogoUrl(currentCompany);
    const normalizedSettings = {
      name: settingsData.name !== undefined ? `${settingsData.name || ''}`.trim() : (currentCompany?.name || ''),
      displayName: settingsData.displayName !== undefined ? `${settingsData.displayName || ''}`.trim() : (currentCompany?.displayName || ''),
      companyPhone: settingsData.companyPhone !== undefined ? `${settingsData.companyPhone || ''}`.trim() : (currentCompany?.companyPhone || currentCompany?.ownerPhone || ''),
      companyAddress: settingsData.companyAddress !== undefined ? `${settingsData.companyAddress || ''}`.trim() : (currentCompany?.companyAddress || currentCompany?.address || ''),
      logoUrl: nextLogoUrl,
      logo: nextLogoUrl,
      bankId: settingsData.bankId !== undefined ? `${settingsData.bankId || ''}`.trim().toUpperCase() : currentTransferProfile.bankId,
      bankName: settingsData.bankName !== undefined ? normalizeLeadingLabel(settingsData.bankName || '') : currentTransferProfile.bankName,
      bankAccountName: settingsData.bankAccountName !== undefined ? `${settingsData.bankAccountName || ''}`.trim().toUpperCase() : currentTransferProfile.accountName,
      bankAccountNumber: settingsData.bankAccountNumber !== undefined ? `${settingsData.bankAccountNumber || ''}`.trim() : currentTransferProfile.accountNumber,
      invoiceQrTemplate: settingsData.invoiceQrTemplate || currentCompany?.invoiceQrTemplate || 'compact2',
      autoReconcileByOrderCode: settingsData.autoReconcileByOrderCode ?? isOrderCodeAutoMatchEnabled(currentCompany),
      customerLoyaltyEnabled: settingsData.customerLoyaltyEnabled ?? currentLoyaltySettings.enabled,
      loyaltyEarnAmountPerPoint: normalizedLoyaltyEarnAmount > 0 ? normalizedLoyaltyEarnAmount : DEFAULT_CUSTOMER_LOYALTY_SETTINGS.earnAmountPerPoint,
      loyaltyRedeemValuePerPoint: normalizedLoyaltyRedeemValue > 0 ? normalizedLoyaltyRedeemValue : DEFAULT_CUSTOMER_LOYALTY_SETTINGS.redeemValuePerPoint,
      updatedAt: new Date().toISOString()
    };

    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'companies', myCompanyId), normalizedSettings, { merge: true });
    setCurrentCompany(prev => ({ ...(prev || {}), id: myCompanyId, ...normalizedSettings }));
    return { success: true };
  };

  const handleResetCompanyDemoData = async () => {
    if (!firebaseUser || !myCompanyId) return { success: false, message: 'Phiên làm việc không hợp lệ.' };

    const deletionPlan = [
      ['customers', customers.map(item => item.id)],
      ['products', products.map(item => item.id)],
      ['orders', orders.map(item => item.id)],
      ['orderRequests', orderRequests.map(item => item.id)],
      ['warehouseDispatches', warehouseDispatches.map(item => item.id)],
      ['payments', payments.map(item => item.id)],
      ['advances', advanceRequests.map(item => item.id)],
      ['financials', financials.map(item => item.id)],
      ['expenses', expenses.map(item => item.id)],
      ['holidays', holidays.map(item => item.id)],
      ['attendance', Object.keys(attendanceRecords || {})],
      ['performance', Object.keys(performanceRecords || {})]
    ];

    const deleteTasks = [];
    deletionPlan.forEach(([collectionName, ids]) => {
      ids.filter(Boolean).forEach(id => {
        deleteTasks.push(deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', collectionName, id)));
      });
    });

    if (deleteTasks.length === 0) return { success: true, message: 'Không còn dữ liệu demo để xóa.' };

    await Promise.all(deleteTasks);
    return {
      success: true,
      message: ''
    };
  };

  const handleAddPayment = async (paymentData) => {
    if (!firebaseUser) return;
    const id = `p_${Date.now()}`;
    const matchedOrder = resolveMatchedOrderFromTransfer({ paymentData, orders, company: currentCompany });
    const resolvedCustomerId = matchedOrder?.customerId || paymentData.customerId || '';
    const normalizedNote = capitalizeFirst(paymentData.note || paymentData.bankContent || '');

    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'payments', id), {
      ...paymentData,
      customerId: resolvedCustomerId,
      note: normalizedNote,
      matchedOrderId: matchedOrder?.id || paymentData.matchedOrderId || null,
      matchedOrderCode: matchedOrder ? formatOrderCode(matchedOrder.id) : paymentData.matchedOrderCode || '',
      autoMatchedByOrderCode: Boolean(matchedOrder && !paymentData.orderId && isOrderCodeAutoMatchEnabled(currentCompany)),
      bankContent: paymentData.bankContent || normalizedNote,
      id,
      companyId: myCompanyId,
      isArchived: false
    });
  };

  const handleDeletePayment = async (paymentId) => {
    if (!firebaseUser) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'payments', paymentId));
  };

  const handleAddExpense = async (empId, expenseData) => {
    if (!firebaseUser) return;
    const id = `exp_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'expenses', id), {
      ...expenseData,
      category: normalizeExpenseCategoryLabel(expenseData.category || 'Chi phí khác'),
      note: normalizeLeadingLabel(expenseData.note || 'Khoản chi'),
      sourceType: expenseData.sourceType || 'manual_accounting_expense',
      empId,
      id,
      companyId: myCompanyId,
      isArchived: false
    });
  };

  const handleDeleteExpense = async (expenseId) => {
    if (!firebaseUser) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'expenses', expenseId));
  };

  const addFinancialRecord = async (empId, type, amount, reason) => {
    if (!firebaseUser) return;
    const id = `f_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'financials', id), { id, companyId: myCompanyId, empId, type, amount: parseInt(amount), reason, date: getTodayString(), isArchived: false });
  };

  const updatePerformance = async (empId, overtime) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'performance', empId), { companyId: myCompanyId, overtime: Math.max(0, parseFloat(overtime) || 0) }, { merge: true });
  };

  const handleAddEmployee = async (newEmpData) => {
    if (!firebaseUser) return;
    const id = Date.now().toString();
    const normalizedPosition = normalizeEmployeePosition(newEmpData.position);
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', id), {
      ...newEmpData,
      position: normalizedPosition,
      role: newEmpData.role || (isOwnerPosition(normalizedPosition) ? 'super_admin' : 'employee'),
      id,
      companyId: myCompanyId
    });
  };

  const handleEditEmployee = async (empId, updatedData) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', empId), {
      ...updatedData,
      position: normalizeEmployeePosition(updatedData.position)
    }, { merge: true });
  };

  const handleAddCustomer = async (empId, customerData) => {
    if (!firebaseUser) return;
    const normalizedPhone = buildCustomerPhoneDuplicateKey(customerData?.phone);
    if (!normalizedPhone) {
      throw new Error('permission_denied');
    }
    const duplicatedCustomer = rawCustomers.find((customer) =>
      customer.companyId === myCompanyId &&
      customer.id !== customerData?.id &&
      buildCustomerPhoneDuplicateKey(customer.phone) === normalizedPhone
    );
    if (duplicatedCustomer) {
      throw new Error(`Không thể tạo khách hàng "${typedCustomerName}" trên hệ thống.`);
    }
    const id = `c_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'customers', id), { ...customerData, phone: `${customerData?.phone || ''}`.trim(), empId, id, companyId: myCompanyId, isArchived: false, allowedDriverIds: customerData.allowedDriverIds || [] });
    return id;
  };

  const handleEditCustomer = async (customerId, updatedData) => {
    if (!firebaseUser) return;
    const currentCustomer = rawCustomers.find(customer => customer.id === customerId);
    const nextPhone = `${updatedData?.phone ?? currentCustomer?.phone ?? ''}`.trim();
    const normalizedPhone = buildCustomerPhoneDuplicateKey(nextPhone);
    if (!normalizedPhone) {
      throw new Error('permission_denied');
    }
    const duplicatedCustomer = rawCustomers.find((customer) =>
      customer.companyId === myCompanyId &&
      customer.id !== customerId &&
      buildCustomerPhoneDuplicateKey(customer.phone) === normalizedPhone
    );
    if (duplicatedCustomer) {
      throw new Error(`Không thể tạo khách hàng "${typedCustomerName}" trên hệ thống.`);
    }
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'customers', customerId), { ...updatedData, phone: nextPhone }, { merge: true });
  };

  const handleDeleteCustomer = async (customerId) => {
