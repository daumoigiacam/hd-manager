const normalizeLookupText = (value = '') => `${value}`
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .replace(/đ/g, 'd')
  .replace(/Đ/g, 'D')
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, ' ')
  .trim();

const findBestEntityMatch = (keyword = '', collection = [], getLabel = (item) => item?.name || '') => {
  const needle = normalizeLookupText(keyword);
  if (!needle) return null;

  const exact = collection.find((item) => normalizeLookupText(getLabel(item)) === needle);
  if (exact) return exact;

  const startsWith = collection.find((item) => {
    const label = normalizeLookupText(getLabel(item));
    return label.startsWith(needle) || needle.startsWith(label);
  });
  if (startsWith) return startsWith;

  return collection.find((item) => {
    const label = normalizeLookupText(getLabel(item));
    return label.includes(needle) || needle.includes(label);
  }) || null;
};

const parseLooseQuantityValue = (value) => {
  if (value === undefined || value === null || value === '') return 0;
  if (typeof value === 'number') return Number.isFinite(value) ? Math.max(0, value) : 0;
  const matched = `${value}`.replace(/\s+/g, '').replace(',', '.').match(/-?\d+(?:\.\d+)?/);
  return matched ? Math.max(0, parseFloat(matched[0]) || 0) : 0;
};

const parseLooseMoneyValue = (value) => {
  if (value === undefined || value === null || value === '') return 0;
  if (typeof value === 'number') return Math.max(0, Math.round(value));
  const digits = `${value}`.replace(/[^\d]/g, '');
  return digits ? parseInt(digits, 10) : 0;
};

const normalizeAiOrderDate = (value) => {
  if (!value) return getTodayString();
  const raw = `${value}`.trim();
  if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;

  const slashMatch = raw.match(/^(\d{1,2})[\/\-](\d{1,2})(?:[\/\-](\d{2,4}))?$/);
  if (slashMatch) {
    const day = parseInt(slashMatch[1], 10);
    const month = parseInt(slashMatch[2], 10);
    let year = slashMatch[3] ? parseInt(slashMatch[3], 10) : new Date().getFullYear();
    if (year < 100) year += 2000;
    const parsed = new Date(year, month - 1, day);
    if (!Number.isNaN(parsed.getTime())) return toDateInputString(parsed);
  }

  const parsed = new Date(raw);
  return Number.isNaN(parsed.getTime()) ? getTodayString() : toDateInputString(parsed);
};

const readFileAsGeminiInlineData = (file) => new Promise((resolve, reject) => {
  const reader = new FileReader();
  reader.onload = () => {
    const raw = `${reader.result || ''}`;
    const [, data = ''] = raw.split(',');
    resolve({
      mimeType: file?.type || 'image/jpeg',
      data
    });
  };
  reader.onerror = () => reject(new Error('Không thể đọc ảnh để gửi cho AI.'));
  reader.readAsDataURL(file);
});

const extractJsonPayload = (text = '') => {
  const raw = `${text || ''}`.trim();
  if (!raw) throw new Error('AI chưa trả về nội dung nếu xử lý.');

  const fenced = raw.match(/```json\s*([\s\S]*?)```/i) || raw.match(/```\s*([\s\S]*?)```/i);
  const source = fenced ? fenced[1].trim() : raw;
  const startIndex = source.search(/[\[{]/);
  const endIndex = Math.max(source.lastIndexOf('}'), source.lastIndexOf(']'));
  const candidate = startIndex >= 0 && endIndex >= startIndex
    ? source.slice(startIndex, endIndex + 1)
    : source;

  return JSON.parse(candidate);
};

const requestNotebookOrderDraftsFromGemini = async (file) => {
  if (!GEMINI_API_KEY) {
    throw new Error('Chưa cấu hình Gemini API key.');
  }

  const inlineData = await readFileAsGeminiInlineData(file);
  const url = buildGeminiGenerateUrl();
  const prompt = [
    'Bạn là AI OCR chuyên đọc sổ bán hàng viết tay hoặc chụp sổ sách tiếng Việt.',
    'Hãy tách nội dung ảnh thành nhiều đơn hàng độc lập.',
    'Chi trả về JSON hợp lệ, không thêm giải thích, không markdown.',
    'Schema phải là {"orders":[{"customer_name":"","date":"YYYY-MM-DD hoặc rỗng","note":"","items":[{"description":"","quantity_kg":0,"unit_price_vnd":0}]}]}.',
    'Quy tắc:',
    '1. Mỗi khách hàng là một đơn riêng.',
    '2. quantity_kg là số kg hoặc số lượng thực tế nhìn thấy.',
    '3. unit_price_vnd là đơn giá, trả về dạng số nguyên VND, không dấu chấm ngăn cách.',
    '4. Nếu không chắc hãy trả giá trị gần đúng nhất có thể đọc từ ảnh.',
    '5. Không tự bÞa thêm khách hàng hoặc mặt hàng không có trong ảnh.'
  ].join('\n');

  let response;
  try {
    response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{
          role: 'user',
          parts: [
            { text: prompt },
            { inlineData: { mimeType: inlineData.mimeType, data: inlineData.data } }
          ]
        }],
        generationConfig: {
          responseMimeType: 'application/json'
        }
      })
    });
  } catch (error) {
    throw new Error('Không kết nối được tới Gemini. Bạn hãy kiểm tra mạng rồi thử lại.');
  }

  const data = await response.json().catch(() => null);
  if (!response.ok) {
    const apiMessage = data?.error?.message || '';
    if (/quota|rate|busy|overloaded/i.test(apiMessage)) {
      throw new Error('Gemini đang bận hoặc tạm vượt giới hạn. Bạn hãy thử lại sau ít phút.');
    }
    throw new Error(apiMessage || 'Gemini chưa đọc được ảnh sổ sách này. Bạn hãy thử ảnh rõ hơn.');
  }

  const rawText = (data?.candidates?.[0]?.content?.parts || [])
    .map((part) => part?.text || '')
    .join('')
    .trim();
  const parsed = extractJsonPayload(rawText);
  const orders = Array.isArray(parsed) ? parsed : parsed?.orders;

  if (!Array.isArray(orders) || orders.length === 0) {
    throw new Error('AI chưa tách ra được đơn hàng nào từ ảnh này.');
  }

  return orders;
};

