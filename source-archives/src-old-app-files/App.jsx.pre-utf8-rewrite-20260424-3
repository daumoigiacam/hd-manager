function SalaryViewLegacy({ employees, attendance, financials, performance, customers, orders, payments, holidays, onAddFinancial, onUpdatePerformance, advanceRequests, onApproveAdvance, onRejectAdvance }) {
  const [selectedEmp, setSelectedEmp] = useState(null);
  const [showModal, setShowModal] = useState(false);
  const [modalType, setModalType] = useState('bonus'); 
  const [amountInput, setAmountInput] = useState('');
