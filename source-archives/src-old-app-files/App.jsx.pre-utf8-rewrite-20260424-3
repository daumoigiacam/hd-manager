      <SmartAIAssistant employee={employee} company={currentCompany} activeTab={activeTab} customers={customers} orders={orders} expenses={expenses} employees={employees} attendance={attendance} holidays={holidays} products={products} />

      <nav className="absolute bottom-0 left-0 right-0 bg-white border-t border-gray-100 z-40 pb-safe shadow-[0_-4px_10px_rgba(0,0,0,0.03)]">
