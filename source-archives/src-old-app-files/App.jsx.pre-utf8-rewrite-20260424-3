    const headerSearchOpen = activeTab === 'finance'
      ? financeSearchOpen
      : activeTab === 'orders'
        ? orderSearchOpen
        : activeTab === 'debt'
          ? debtSearchOpen
          : customerSearchOpen;
    const toggleHeaderSearch = () => {
      if (activeTab === 'finance') setFinanceSearchOpen(prev => !prev);
      else if (activeTab === 'orders') setOrderSearchOpen(prev => !prev);
      else if (activeTab === 'debt') setDebtSearchOpen(prev => !prev);
      else if (activeTab === 'customers') setCustomerSearchOpen(prev => !prev);
