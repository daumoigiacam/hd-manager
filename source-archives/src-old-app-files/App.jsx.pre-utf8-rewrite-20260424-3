  );
}

function AttendanceView({ currentEmployee, isAccounting, employees, attendance, date, onCheckIn, onCheckOut, onLeave, onEditAttendance, onOverrideCheckIn, onOverrideCheckOut }) {
  const [selectedEmployee, setSelectedEmployee] = useState(null);
  const [showEditModal, setShowEditModal] = useState(false);
  const [formData, setFormData] = useState({ status: 'present', checkIn: '', checkOut: '' });
  const [positionFilter, setPositionFilter] = useState('Tất cả');
  const [searchKeyword, setSearchKeyword] = useState('');
  const [selfMethod, setSelfMethod] = useState('gps');
  const [selfWifiLabel, setSelfWifiLabel] = useState('');
  const [selfWifiLookup, setSelfWifiLookup] = useState(EMPTY_WIFI_LOOKUP_STATE);
  const [selfStatusMsg, setSelfStatusMsg] = useState('');
  const [bulkStatusMsg, setBulkStatusMsg] = useState('');
  const [isSelfSubmitting, setIsSelfSubmitting] = useState(false);
  const [isBulkSubmitting, setIsBulkSubmitting] = useState(false);

  const displayDate = new Date(date).toLocaleDateString('vi-VN');

  const positions = useMemo(() => ['Tất cả', ...new Set(employees.map(emp => getEmployeePositionLabel(emp.position)).filter(Boolean))], [employees]);

  useEffect(() => {
    if (!positions.includes(positionFilter)) setPositionFilter('Tất cả');
  }, [positions, positionFilter]);

  const getRecord = (empId) => attendance[`${date}_${empId}`];

  const getStatusMeta = (record) => {
    if (record?.status === 'leave') {
      return { label: 'Nghỉ phép', classes: 'bg-amber-50 text-amber-700 border border-amber-200' };
    }

    if (record?.checkIn && record?.checkOut) {
      return { label: 'Đã hoàn thành ca', classes: 'bg-emerald-50 text-emerald-700 border border-emerald-200' };
    }

    if (record?.checkIn) {
      return { label: record?.status === 'late' ? 'Đang làm việc, vào trễ' : 'Đang làm việc', classes: 'bg-blue-50 text-blue-700 border border-blue-200' };
    }

    return { label: 'Chưa chấm công', classes: 'bg-gray-50 text-gray-600 border border-gray-200' };
  };

  const filteredEmployees = useMemo(() => {
    const keyword = searchKeyword.trim().toLowerCase();
    return employees.filter(emp => {
      if (positionFilter !== 'Tất cả' && getEmployeePositionLabel(emp.position) !== positionFilter) return false;
      if (!keyword) return true;

      const haystack = [emp.name, emp.phone, getEmployeePositionLabel(emp.position)].filter(Boolean).join(' ').toLowerCase();
      return haystack.includes(keyword);
    });
  }, [employees, positionFilter, searchKeyword]);

  const summary = useMemo(() => {
    return filteredEmployees.reduce((acc, emp) => {
      const record = getRecord(emp.id);

      if (record?.status === 'leave') acc.leave += 1;
      else if (record?.checkIn && record?.checkOut) acc.completed += 1;
      else if (record?.checkIn) acc.working += 1;
      else acc.pending += 1;

      return acc;
    }, { completed: 0, working: 0, leave: 0, pending: 0 });
  }, [filteredEmployees, attendance, date]);

  const filteredAlerts = useMemo(() => filteredEmployees
    .map(emp => {
      const anomaly = getAttendanceAnomaly(emp, getRecord(emp.id), date);
      return anomaly ? { emp, ...anomaly } : null;
    })
    .filter(Boolean), [filteredEmployees, attendance, date]);

  const currentRecord = currentEmployee ? getRecord(currentEmployee.id) : null;
  const currentStatusMeta = getStatusMeta(currentRecord);
  const currentShiftPolicy = resolveEmployeeShiftPolicy(currentEmployee);
  const selfWifiReady = isWifiAttendanceReady(selfWifiLookup, selfWifiLabel);
  const isSelfActionDisabled = isSelfSubmitting || (selfMethod === 'wifi' && !selfWifiReady);

  const lookupSelfWifi = async () => {
    setSelfWifiLookup({ loading: true, success: false, message: 'Dang do WiFi hien tai...', failureCode: null });
    const detectedWifi = await getCurrentConnectedWifi();

    if (detectedWifi.supported) {
      setSelfWifiLabel(detectedWifi.ssid);
      setSelfWifiLookup({ loading: false, success: true, message: detectedWifi.message, failureCode: null });
      return;
    }

    if (isAndroidNativeRuntime()) {
      setSelfWifiLabel('');
    }
    setSelfWifiLookup({ loading: false, success: false, message: detectedWifi.message, failureCode: detectedWifi.failureCode || null });
  };

  useEffect(() => {
    if (selfMethod !== 'wifi') {
      setSelfWifiLookup(EMPTY_WIFI_LOOKUP_STATE);
      return;
    }

    lookupSelfWifi();
  }, [selfMethod]);

  const openEditModal = (employee, record) => {
    if (!isAccounting) return;
    setSelectedEmployee(employee);
    setFormData({
      status: record?.status || 'present',
      checkIn: record?.checkIn ? formatTime(record.checkIn) : '',
      checkOut: record?.checkOut ? formatTime(record.checkOut) : ''
    });
    setShowEditModal(true);
  };

  const closeEditModal = () => {
    setShowEditModal(false);
    setSelectedEmployee(null);
    setFormData({ status: 'present', checkIn: '', checkOut: '' });
  };

  const buildDateTime = (timeValue) => {
    if (!timeValue) return null;
    return new Date(`${date}T${timeValue}:00`);
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!selectedEmployee) return;

    const nextStatus = formData.status || 'present';
    const editData = {
      status: nextStatus,
      checkIn: nextStatus === 'leave' ? null : buildDateTime(formData.checkIn),
      checkOut: nextStatus === 'leave' ? null : buildDateTime(formData.checkOut)
    };

    onEditAttendance(selectedEmployee.id, date, editData);
    closeEditModal();
  };

  const handleSelfAttendance = async (type) => {
    if (!currentEmployee?.id) return;
    if (selfMethod === 'wifi' && !selfWifiReady) {
      setSelfStatusMsg(selfWifiLookup.message || 'Chưa xác minh được WiFi hiện tại, nên không thể chấm công bằng WiFi.');
      return;
    }

    try {
      setIsSelfSubmitting(true);
      setSelfStatusMsg('');
      const methodPayload = await buildAttendanceMethodPayload(selfMethod, selfWifiLabel);
      if (type === 'in') await onCheckIn(currentEmployee.id, methodPayload);
      else await onCheckOut(currentEmployee.id, methodPayload);
      setSelfStatusMsg(type === 'in' ? 'Đã chấm vào ca thành công.' : 'Đã chấm ra ca thành công.');
      if (selfMethod === 'wifi') {
        setSelfWifiLabel('');
        setSelfWifiLookup(EMPTY_WIFI_LOOKUP_STATE);
      }
    } catch (error) {
      setSelfStatusMsg(error?.message || 'Không thể chấm công với phương thức này.');
    } finally {
      setIsSelfSubmitting(false);
    }
  };

  const handleBulkOverride = async (type) => {
    if (!isAccounting) return;

    const eligibleEmployees = filteredEmployees.filter(emp => {
      const record = getRecord(emp.id);
      if (type === 'in') return !record?.checkIn && record?.status !== 'leave';
      return Boolean(record?.checkIn) && !record?.checkOut && record?.status !== 'leave';
    });

    if (eligibleEmployees.length === 0) {
      setBulkStatusMsg(type === 'in' ? 'Không còn ai cần chấm vào hộ theo bộ lọc hiện tại.' : 'Không còn ai cần chấm ra hộ theo bộ lọc hiện tại.');
      return;
    }

    try {
      setIsBulkSubmitting(true);
      setBulkStatusMsg('');
      for (const emp of eligibleEmployees) {
        if (type === 'in') await onOverrideCheckIn(emp.id);
        else await onOverrideCheckOut(emp.id);
      }
      setBulkStatusMsg(type === 'in'
        ? `Đã chấm vào hộ ${eligibleEmployees.length} nhân sự theo bộ lọc hiện tại.`
        : `Đã chấm ra hộ ${eligibleEmployees.length} nhân sự theo bộ lọc hiện tại.`);
    } finally {
      setIsBulkSubmitting(false);
    }
  };

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      <div className="bg-gradient-to-r from-purple-500 to-indigo-600 text-white rounded-2xl p-5 shadow-md">
        <p className="text-[11px] uppercase tracking-[0.18em] text-purple-100 font-bold mb-1">Chấm công ngày {displayDate}</p>
        <h2 className="text-2xl font-black mb-4">Theo dõi ca làm theo vị trí</h2>
        <div className="grid grid-cols-2 gap-3">
          <div className="bg-white/10 rounded-xl p-3">
            <p className="text-[10px] uppercase text-purple-100 mb-1">Đã hoàn thành</p>
            <p className="text-xl font-bold">{summary.completed}</p>
          </div>
          <div className="bg-white/10 rounded-xl p-3">
            <p className="text-[10px] uppercase text-purple-100 mb-1">Đang làm</p>
            <p className="text-xl font-bold">{summary.working}</p>
          </div>
          <div className="bg-white/10 rounded-xl p-3">
            <p className="text-[10px] uppercase text-purple-100 mb-1">Nghỉ phép</p>
            <p className="text-xl font-bold">{summary.leave}</p>
          </div>
          <div className="bg-white/10 rounded-xl p-3">
            <p className="text-[10px] uppercase text-purple-100 mb-1">Chưa chấm</p>
            <p className="text-xl font-bold">{summary.pending}</p>
          </div>
        </div>
      </div>

      <div className="bg-amber-50 border border-amber-200 rounded-2xl p-4 text-sm text-amber-900 shadow-sm">
        <p className="font-bold uppercase text-[11px] tracking-[0.16em] text-amber-700 mb-2">Nguyên tắc công bằng</p>
        <p className="leading-relaxed">Nhân viên quên chấm vào hoặc quên chấm ra sẽ được app nhắc trên tài khoản cá nhân và tài khoản kế toán nhân sự. Tăng ca không tự suy ra từ việc ra ca muộn hoặc bỏ quên chấm ra, chỉ cộng khi đã đối chiếu và duyệt ở bảng lương.</p>
      </div>

      {currentEmployee && (
        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <div className="flex items-start justify-between gap-3">
            <div>
              <h3 className="font-bold text-gray-800 text-base">Chấm công của bạn</h3>
              <p className="text-xs text-gray-500 mt-1">{currentEmployee.name} • {currentEmployee.position}</p>
              <p className="text-[11px] text-gray-500 mt-1">{currentShiftPolicy.shiftName}: {currentShiftPolicy.shiftStart} - {currentShiftPolicy.shiftEnd}</p>
              <span className={`inline-flex mt-2 px-2.5 py-1 rounded-full text-[11px] font-bold ${currentStatusMeta.classes}`}>
                {currentStatusMeta.label}
              </span>
            </div>
            <div className="text-right text-xs text-gray-500">
              <div>Vào: <strong className="text-gray-800">{formatTime(currentRecord?.checkIn)}</strong></div>
              <div className="mt-1">Ra: <strong className="text-gray-800">{formatTime(currentRecord?.checkOut)}</strong></div>
            </div>
          </div>

          <div className="grid grid-cols-2 gap-3 mt-4">
            <button type="button" onClick={() => setSelfMethod('gps')} className={`rounded-xl border px-3 py-2.5 text-sm font-bold transition-colors ${selfMethod === 'gps' ? 'border-emerald-500 bg-emerald-50 text-emerald-600' : 'border-gray-200 bg-white text-gray-600'}`}>
              GPS vị trí
            </button>
            <button type="button" onClick={() => setSelfMethod('wifi')} className={`rounded-xl border px-3 py-2.5 text-sm font-bold transition-colors ${selfMethod === 'wifi' ? 'border-blue-500 bg-blue-50 text-blue-600' : 'border-gray-200 bg-white text-gray-600'}`}>
              WiFi nội bộ
            </button>
          </div>

          {selfMethod === 'wifi' && (
            <div className="mt-3">
              <div className="flex items-center justify-between gap-3 mb-1">
                <label className="block text-xs font-semibold text-gray-700">{isAndroidNativeRuntime() ? 'WiFi đang kết nối' : 'Tên WiFi / khu vực'}</label>
                <button
                  type="button"
                  onClick={lookupSelfWifi}
                  disabled={selfWifiLookup.loading}
                  className="text-[11px] font-bold text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full disabled:opacity-60"
                >
