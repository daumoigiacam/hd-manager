              {record?.checkInMethodMeta?.type === 'wifi' && (
                <p className="text-[11px] text-gray-500 mt-1">
                  WiFi vào ca: {record.checkInMethodMeta.ssid || record.checkInMethodMeta.networkLabel || '--'}
                  {record.checkInMethodMeta.bssid ? ` • BSSID ${record.checkInMethodMeta.bssid}` : ''}
                </p>
              )}

              {record?.checkOutMethodMeta?.type === 'wifi' && (
                <p className="text-[11px] text-gray-500 mt-1">
                  WiFi ra ca: {record.checkOutMethodMeta.ssid || record.checkOutMethodMeta.networkLabel || '--'}
                  {record.checkOutMethodMeta.bssid ? ` • BSSID ${record.checkOutMethodMeta.bssid}` : ''}
