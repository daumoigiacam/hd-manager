  const addFinancialRecord = async (empId, type, amount, reason) => {
    if (!firebaseUser) return;
    const id = `f_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'financials', id), { id, companyId: myCompanyId, empId, type, amount: parseInt(amount), reason, date: getTodayString(), isArchived: false });
  };

  const updatePerformance = async (empId, overtime) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'performance', empId), { companyId: myCompanyId, overtime: Math.max(0, parseFloat(overtime) || 0) }, { merge: true });
  };

  const handleAddEmployee = async (newEmpData) => {
    if (!firebaseUser) return;
    const id = Date.now().toString();
    const normalizedPosition = normalizeEmployeePosition(newEmpData.position);
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', id), {
      ...newEmpData,
      position: normalizedPosition,
      role: newEmpData.role || (isOwnerPosition(normalizedPosition) ? 'super_admin' : 'employee'),
      id,
      companyId: myCompanyId
    });
  };

  const handleEditEmployee = async (empId, updatedData) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', empId), {
      ...updatedData,
      position: normalizeEmployeePosition(updatedData.position)
    }, { merge: true });
  };

  const handleAddCustomer = async (empId, customerData) => {
    if (!firebaseUser) return;
    const id = `c_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'customers', id), { ...customerData, empId, id, companyId: myCompanyId, isArchived: false, allowedDriverIds: customerData.allowedDriverIds || [] });
    return id;
  };

  const handleEditCustomer = async (customerId, updatedData) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'customers', customerId), updatedData, { merge: true });
  };

  const handleAddProduct = async (productData) => {
    if (!firebaseUser) return;
    const id = `prod_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'products', id), { ...productData, id, companyId: myCompanyId, isArchived: false });
  };

  const handleEditProduct = async (prodId, updatedData) => {
    if (!firebaseUser) return;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'products', prodId), updatedData, { merge: true });
  };

  const handleDeleteProduct = async (prodId) => {
    if (!firebaseUser) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'products', prodId));
  };

  const handleAddOrder = async (empId, orderData) => {
    if (!firebaseUser) return;
    const id = `o_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`;
    const customer = customers.find(c => c.id === orderData.customerId);
    const salesEmpId = orderData.salesEmpId || customer?.empId || empId;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', id), {
      ...orderData,
      empId,
      createdByEmpId: empId,
      salesEmpId,
      id,
      companyId: myCompanyId,
      isArchived: false
    });
    return id;
  };

  const handleDeleteOrder = async (orderId) => {
    if (!firebaseUser) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', orderId));
  };

  const handleAddHoliday = async (holidayData) => {
    if (!firebaseUser) return;
    const id = `hol_${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'holidays', id), { ...holidayData, id, companyId: myCompanyId });
  };

  const handleDeleteHoliday = async (holidayId) => {
    if (!firebaseUser) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'holidays', holidayId));
  };

  const employeeInfo = currentUser ? employees.find(e => e.id === currentUser.id) : null;
  const companyInfo = currentUser ? (rawCompanies.find(comp => comp.id === currentUser.companyId) || currentCompany) : null;
  const isSessionRecovering = Boolean(currentUser) && (rawCompanies.length === 0 || rawEmployees.length === 0);
  const isSessionInvalid = Boolean(currentUser) && !isSessionRecovering && (!employeeInfo || !companyInfo);

  useEffect(() => {
    if (isSessionInvalid) {
      setCurrentUser(null);
      setCurrentCompany(null);
      setActiveTab('home');
    }
  }, [isSessionInvalid]);

  if (!isFirebaseConfigured) return <MissingFirebaseError />;
  if (isFirebaseLoading) return <div className="flex h-screen items-center justify-center bg-gray-50"><p className="text-emerald-600 font-medium flex items-center animate-pulse"><CalendarDays className="mr-2 animate-spin"/> Đang kết nối Đám mây...</p></div>;
  
  if (!currentUser) {
    return (
      <>
        <style dangerouslySetInnerHTML={{__html: `@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap'); body { font-family: 'Plus Jakarta Sans', sans-serif !important; }`}} />
        <LoginRegisterView onLogin={handleLogin} onRegister={handleRegisterCompany} />
      </>
    );
  }

  if (isSessionRecovering) {
    return (
      <>
        <style dangerouslySetInnerHTML={{__html: `@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap'); body { font-family: 'Plus Jakarta Sans', sans-serif !important; }`}} />
        <div className="min-h-screen bg-[#f4f6f8] flex items-center justify-center p-6">
          <div className="w-full max-w-md bg-white rounded-3xl shadow-xl p-6 text-center border border-gray-100">
            <div className="w-14 h-14 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center mx-auto mb-4">
              <Loader2 size={24} className="animate-spin" />
            </div>
            <h2 className="text-xl font-bold text-gray-800 mb-2">Đang khôi phục dữ liệu</h2>
            <p className="text-sm text-gray-600 leading-6">App đang nạp lại phiên làm việc và dữ liệu cục bộ để tránh lỗi trang trắng lúc mở.</p>
          </div>
        </div>
      </>
    );
  }

  if (isSessionInvalid) {
    return (
      <>
        <style dangerouslySetInnerHTML={{__html: `@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap'); body { font-family: 'Plus Jakarta Sans', sans-serif !important; }`}} />
        <div className="min-h-screen bg-[#f4f6f8] flex items-center justify-center p-6">
          <div className="w-full max-w-md bg-white rounded-3xl shadow-xl p-6 text-center border border-amber-100">
            <div className="w-14 h-14 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center mx-auto mb-4">
              <AlertCircle size={24} />
            </div>
            <h2 className="text-xl font-bold text-gray-800 mb-2">Phi?n l?m vi?c c? kh?ng c?n h?p l?</h2>
            <p className="text-sm text-gray-600 leading-6 mb-4">M?nh ?ang ??a app v? m?n h?nh ??ng nh?p ?? tr?nh b? tr?ng trang do d? li?u phi?n c?.</p>
            <button
              type="button"
              onClick={handleLogout}
              className="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-2xl transition-colors"
            >
              Về màn hình đăng nhập
            </button>
          </div>
        </div>
      </>
    );
  }

  return (
    <>
      <style dangerouslySetInnerHTML={{__html: `@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap'); body { font-family: 'Plus Jakarta Sans', sans-serif !important; }`}} />
      <MainAppView 
        currentUser={currentUser} employee={employeeInfo} currentCompany={companyInfo} activeTab={activeTab} setActiveTab={setActiveTab}
        employees={employees} attendance={attendanceRecords} date={currentDate} financials={financials} performance={aggregatedPerformance}
        customers={customers} orders={orders} payments={payments} products={products} advanceRequests={advanceRequests} expenses={expenses} holidays={holidays}
        onCheckIn={handleCheckIn} onCheckOut={handleCheckOut} onLeave={handleLeave} onLogout={handleLogout}
        onAddCustomer={handleAddCustomer} onEditCustomer={handleEditCustomer} onAddOrder={handleAddOrder} onDeleteOrder={handleDeleteOrder}
        onAddPayment={handleAddPayment} onDeletePayment={handleDeletePayment}
        onAddExpense={handleAddExpense} onDeleteExpense={handleDeleteExpense}
        onAddAdvanceRequest={handleAddAdvanceRequest} onEditAttendance={handleEditAttendance}
        onAddFinancial={addFinancialRecord} onUpdatePerformance={updatePerformance}
        onApproveAdvance={handleApproveAdvance} onRejectAdvance={handleRejectAdvance}
        onAddEmployee={handleAddEmployee} onEditEmployee={handleEditEmployee}
        onOverrideCheckIn={handleCheckIn} onOverrideCheckOut={handleCheckOut}
        onAddProduct={handleAddProduct} onEditProduct={handleEditProduct} onDeleteProduct={handleDeleteProduct}
        onAddHoliday={handleAddHoliday} onDeleteHoliday={handleDeleteHoliday}
        onToggleArchiveOrder={(id, status) => handleToggleArchive('orders', id, status)}
        onToggleArchivePayment={(id, status) => handleToggleArchive('payments', id, status)}
        onToggleArchiveExpense={(id, status) => handleToggleArchive('expenses', id, status)}
        onToggleArchiveProduct={(id, status) => handleToggleArchive('products', id, status)}
      />
    </>
  );
}

// --- MAIN LAYOUT ---
function MainAppView({ 
  currentUser, employee, currentCompany, activeTab, setActiveTab, employees, attendance, date, financials, performance, customers, orders, payments, products, advanceRequests, expenses, holidays,
  onCheckIn, onCheckOut, onLeave, onLogout, onAddCustomer, onEditCustomer, onAddOrder, onDeleteOrder, onAddPayment, onDeletePayment, onAddExpense, onDeleteExpense, onAddAdvanceRequest, onEditAttendance, onAddFinancial, onUpdatePerformance, onApproveAdvance, onRejectAdvance, onAddEmployee, onEditEmployee, onOverrideCheckIn, onOverrideCheckOut, onAddProduct, onEditProduct, onDeleteProduct, onAddHoliday, onDeleteHoliday,
  onToggleArchiveOrder, onToggleArchivePayment, onToggleArchiveExpense, onToggleArchiveProduct
}) {
  const isSuperAdmin = currentUser?.role === 'super_admin';
  const position = getEmployeePositionLabel(employee?.position || '');
  const isAccounting = isSuperAdmin || isAccountingPosition(position);
  const isSales = isSalesPosition(position);
  const isDriver = isDriverPosition(position);

  const [showAuthModal, setShowAuthModal] = useState(false);
  const [authType, setAuthType] = useState('in'); 
  const [authMethod, setAuthMethod] = useState('gps');
  const [authWifiLabel, setAuthWifiLabel] = useState('');
  const [authWifiLookup, setAuthWifiLookup] = useState(EMPTY_WIFI_LOOKUP_STATE);
  const [authError, setAuthError] = useState('');
  const [isAuthSubmitting, setIsAuthSubmitting] = useState(false);
  
  const [showAdvanceModal, setShowAdvanceModal] = useState(false);
  const [advanceAmount, setAdvanceAmount] = useState('');
  const [advanceReason, setAdvanceReason] = useState('');
  const [financeSearchKeyword, setFinanceSearchKeyword] = useState('');
  const [financeSearchOpen, setFinanceSearchOpen] = useState(false);
  const [financeFilterOpen, setFinanceFilterOpen] = useState(false);
  const [orderSearchKeyword, setOrderSearchKeyword] = useState('');
  const [orderSearchOpen, setOrderSearchOpen] = useState(false);
  const [orderFilterOpen, setOrderFilterOpen] = useState(false);
  const [debtSearchKeyword, setDebtSearchKeyword] = useState('');
  const [debtSearchOpen, setDebtSearchOpen] = useState(false);
  const [debtFilterOpen, setDebtFilterOpen] = useState(false);
  const [customerSearchKeyword, setCustomerSearchKeyword] = useState('');
  const [customerSearchOpen, setCustomerSearchOpen] = useState(false);
  const [customerFilterOpen, setCustomerFilterOpen] = useState(false);

  const record = attendance[`${date}_${employee?.id}`];
  const isCheckedIn = record?.checkIn;
  const isCheckedOut = record?.checkOut;
  const isLeave = record?.status === 'leave';
  const authWifiReady = isWifiAttendanceReady(authWifiLookup, authWifiLabel);
  const isAuthConfirmDisabled = isAuthSubmitting || (authMethod === 'wifi' && !authWifiReady);
  const currentAttendanceAlert = getAttendanceAnomaly(employee, record, date);
  const attendanceAlerts = useMemo(() => employees
    .map(emp => {
      const empRecord = attendance[`${date}_${emp.id}`];
      const anomaly = getAttendanceAnomaly(emp, empRecord, date);
      return anomaly ? { emp, record: empRecord, ...anomaly } : null;
    })
    .filter(Boolean), [employees, attendance, date]);

  const details = buildSalaryDetails(employee?.id, employees, attendance, financials, performance, customers, orders, payments, holidays) || { netSalary: 0, grossSalary: 0, deductionTotal: 0, workDays: 0, workDaysProbation: 0, workDaysOfficial: 0, expMonths: 0, experienceCycles: 0, experienceCycleLabel: 'tháng', baseSalaryCalc: 0, supportSalary: 0, responsibilitySalary: 0, experienceSalary: 0, commission: 0, tieredBonus: 0, overtimePay: 0, totalBonus: 0, holidayBonus: 0, totalPenalty: 0, totalAdvance: 0, badDebt: 0, perf: {overtime: 0}, attendanceEntries: [], bonusRecords: [], penaltyRecords: [], advanceRecords: [] };

  const lookupAuthWifi = async () => {
    setAuthWifiLookup({ loading: true, success: false, message: 'Dang do WiFi hien tai...', failureCode: null });
    const detectedWifi = await getCurrentConnectedWifi();

    if (detectedWifi.supported) {
      setAuthWifiLabel(detectedWifi.ssid);
      setAuthWifiLookup({ loading: false, success: true, message: detectedWifi.message, failureCode: null });
      return;
    }

    if (isAndroidNativeRuntime()) {
      setAuthWifiLabel('');
    }
    setAuthWifiLookup({ loading: false, success: false, message: detectedWifi.message, failureCode: detectedWifi.failureCode || null });
  };

  useEffect(() => {
    if (!showAuthModal || authMethod !== 'wifi') {
      setAuthWifiLookup(EMPTY_WIFI_LOOKUP_STATE);
      return;
    }

    lookupAuthWifi();
  }, [showAuthModal, authMethod]);

  const openAuthModal = (type) => {
    setAuthType(type);
    setAuthMethod('gps');
    setAuthWifiLabel('');
    setAuthWifiLookup(EMPTY_WIFI_LOOKUP_STATE);
    setAuthError('');
    setShowAuthModal(true);
  };

  const handleConfirmAuth = async () => {
    if (!employee?.id) return;
    if (authMethod === 'wifi' && !authWifiReady) {
      setAuthError(authWifiLookup.message || 'Chưa xác minh được WiFi hiện tại, nên không thể chấm công bằng WiFi.');
      return;
    }

    try {
      setIsAuthSubmitting(true);
      setAuthError('');
      const methodPayload = await buildAttendanceMethodPayload(authMethod, authWifiLabel);
      if (authType === 'in') await onCheckIn(employee.id, methodPayload);
      else await onCheckOut(employee.id, methodPayload);
      setShowAuthModal(false);
      setAuthWifiLabel('');
      setAuthWifiLookup(EMPTY_WIFI_LOOKUP_STATE);
      setAuthMethod('gps');
    } catch (error) {
      setAuthError(error?.message || 'Không thể chấm công với phương thức này.');
    } finally {
      setIsAuthSubmitting(false);
    }
  };
  
  const handleAdvanceSubmit = (e) => {
    e.preventDefault();
    if(advanceAmount && parseInt(parseInputCurrency(advanceAmount)) > 0) {
      onAddAdvanceRequest(employee.id, parseInputCurrency(advanceAmount), advanceReason);
      setShowAdvanceModal(false);
      setAdvanceAmount(''); setAdvanceReason('');
    }
  };

  const renderHeader = () => {
    if (activeTab === 'home') return null;
    if (activeTab === 'more') {
      return (
        <header className="bg-emerald-500 text-white p-4 shadow-sm shrink-0">
          <h1 className="text-xl font-bold">Thêm</h1>
        </header>
      );
    }
    const hideHeaderSearchFilter = activeTab === 'products' || activeTab === 'report';
