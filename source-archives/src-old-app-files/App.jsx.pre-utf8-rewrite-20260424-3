  const [overtimeInput, setOvertimeInput] = useState('');
  const [expandedEmp, setExpandedEmp] = useState(null);
  const currentMonth = getTodayString().substring(0, 7);
  const currentMonthLabel = `Tháng ${currentMonth.substring(5, 7)}/${currentMonth.substring(0, 4)}`;

  const salaryRows = useMemo(() => employees.map(emp => ({
    emp,
    details: buildSalaryDetails(emp.id, employees, attendance, financials, performance, customers, orders, payments, holidays, currentMonth)
  })).filter(row => row.details), [employees, attendance, financials, performance, customers, orders, payments, holidays, currentMonth]);

  const aggregateData = useMemo(() => {
    const totals = salaryRows.reduce((acc, row) => {
      acc.totalSalary += row.details.netSalary;
      acc.totalDays += row.details.workDays;
      acc.totalAdvance += row.details.totalAdvance;
      acc.totalPenalty += row.details.totalPenalty;
      return acc;
    }, {
      totalSalary: 0,
      totalDays: 0,
      totalAdvance: 0,
      totalPenalty: 0
    });

    return {
      ...totals,
      avgDaily: totals.totalDays > 0 ? totals.totalSalary / totals.totalDays : 0
    };
  }, [salaryRows]);

  const handleSubmit = (e) => {
    e.preventDefault();
    if (modalType === 'performance') onUpdatePerformance(selectedEmp.id, overtimeInput);
    else { 
      const val = parseInputCurrency(amountInput);
      if (!val || isNaN(val)) return; 
      onAddFinancial(selectedEmp.id, modalType, val, capitalizeFirst(reasonInput)); 
    }
    setShowModal(false);
  };

  const pendingAdvances = advanceRequests ? advanceRequests.filter(r => r.status === 'pending') : [];

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      {pendingAdvances.length > 0 && (
        <div className="bg-orange-50 border border-orange-200 p-4 rounded-2xl shadow-sm mb-6">
