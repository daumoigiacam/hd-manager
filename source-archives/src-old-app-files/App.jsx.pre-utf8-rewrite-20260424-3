function DebtManagementView({ isAccounting, isDriver, employee, customers, orders, payments, employees, onAddPayment, onDeletePayment, searchKeyword: externalSearchKeyword, setSearchKeyword: setExternalSearchKeyword, showSearchBox: externalShowSearchBox, setShowSearchBox: setExternalShowSearchBox, showFilterPanel: externalShowFilterPanel, setShowFilterPanel: setExternalShowFilterPanel }) {
  const [selectedCustomerId, setSelectedCustomerId] = useState(null);
  const [showPaymentModal, setShowPaymentModal] = useState(false);
  const [localSearchKeyword, setLocalSearchKeyword] = useState('');
  const [localShowSearchBox, setLocalShowSearchBox] = useState(false);
  const [localShowFilterPanel, setLocalShowFilterPanel] = useState(false);
  const [debtViewFilter, setDebtViewFilter] = useState('all');
  const [debtShareStatus, setDebtShareStatus] = useState('');
  const [newPayment, setNewPayment] = useState({
    amount: '',
    note: '',
    date: getTodayString(),
    method: 'Chuyển khoản',
    sourceType: 'accounting_recovery'
  });
  const searchKeyword = externalSearchKeyword ?? localSearchKeyword;
  const setSearchKeyword = setExternalSearchKeyword ?? setLocalSearchKeyword;
  const showSearchBox = externalShowSearchBox ?? localShowSearchBox;
  const setShowSearchBox = setExternalShowSearchBox ?? setLocalShowSearchBox;
  const showFilterPanel = externalShowFilterPanel ?? localShowFilterPanel;
  const setShowFilterPanel = setExternalShowFilterPanel ?? setLocalShowFilterPanel;

  const customerLedgers = useMemo(() => customers.map(customer => {
    const ledger = buildCustomerLedger(customer.id, orders, payments);
    const manager = employees.find(emp => emp.id === customer.empId);
    return {
      ...customer,
      ledger,
      managerName: manager?.name || 'Chưa gán'
    };
  }), [customers, orders, payments, employees]);

  const accessibleCustomers = useMemo(() => customerLedgers.filter(customer => {
    if (customer.isArchived) return false;
    if (!isDriver) return true;
    return (customer.allowedDriverIds || []).includes(employee?.id);
  }), [customerLedgers, isDriver, employee?.id]);

  const selectedCustomer = useMemo(
    () => accessibleCustomers.find(customer => customer.id === selectedCustomerId) || null,
    [accessibleCustomers, selectedCustomerId]
  );

  useEffect(() => {
    if (selectedCustomerId && !accessibleCustomers.some(customer => customer.id === selectedCustomerId)) {
      setSelectedCustomerId(null);
      setShowPaymentModal(false);
    }
  }, [selectedCustomerId, accessibleCustomers]);

  useEffect(() => {
    setDebtShareStatus('');
  }, [selectedCustomerId]);

  const filteredCustomers = useMemo(() => {
    const keyword = searchKeyword.trim().toLowerCase();
    return accessibleCustomers
      .filter(customer => {
        if (debtViewFilter === 'debt') return customer.ledger.currentDebt > 0;
        if (debtViewFilter === 'credit') return customer.ledger.creditBalance > 0;
        return customer.ledger.currentDebt > 0 || customer.ledger.creditBalance > 0;
      })
      .filter(customer => {
        if (!keyword) return true;
        const haystack = [customer.name, customer.phone, customer.address, customer.managerName].filter(Boolean).join(' ').toLowerCase();
        return haystack.includes(keyword);
      })
      .sort((a, b) => {
        if (b.ledger.currentDebt !== a.ledger.currentDebt) return b.ledger.currentDebt - a.ledger.currentDebt;
        return (a.name || '').localeCompare(b.name || '', 'vi');
      });
  }, [accessibleCustomers, debtViewFilter, searchKeyword]);

  const debtSummary = useMemo(() => filteredCustomers.reduce((acc, customer) => {
    acc.totalDebt += customer.ledger.currentDebt;
    acc.totalCredit += customer.ledger.creditBalance;
    return acc;
  }, { totalDebt: 0, totalCredit: 0 }), [filteredCustomers]);

  const handlePaymentSubmit = (e) => {
    e.preventDefault();
    if (!selectedCustomer || !isAccounting) return;

    const sourceLabel = newPayment.sourceType === 'driver_cash'
      ? 'Tài xế nộp tiền mặt'
      : newPayment.sourceType === 'customer_transfer'
        ? 'Khách chuyển khoản'
        : 'Kế toán thu hồi công nợ';

    onAddPayment({
      customerId: selectedCustomer.id,
      amount: parseInt(parseInputCurrency(newPayment.amount)) || 0,
      note: capitalizeFirst(newPayment.note) || sourceLabel,
      date: newPayment.date,
      method: newPayment.method,
      sourceType: newPayment.sourceType,
      sourceLabel
    });

    setShowPaymentModal(false);
    setNewPayment({
      amount: '',
      note: '',
      date: getTodayString(),
      method: 'Chuyển khoản',
      sourceType: 'accounting_recovery'
    });
  };

  const resolveDebtShareStatusMessage = (result, channel) => {
    if (result.status === 'shared') {
      if (channel === 'native') return 'Đã mở bảng chia sẻ của máy. Bạn có thể chọn Zalo, Facebook, Messenger hoặc ứng dụng khác để gửi ngay.';
      return `Đã mở bảng chia sẻ. Hãy chọn ${getShareChannelLabel(channel)} nếu máy đã cài ứng dụng đó.`;
    }
    if (result.status === 'copied') {
      return `Nội dung công nợ đã được sao chép. Bạn có thể dán vào ${getShareChannelLabel(channel)} hoặc tin nhắn để gửi cho khách.`;
    }
    if (result.status === 'cancelled') return 'Bạn đã đóng bảng chia sẻ.';
    return 'Thiết bị này chưa hỗ trợ chia sẻ trực tiếp. Bạn có thể dùng nút sao chép hoặc lưu file.';
  };

  const buildDebtShareText = (customer) => {
    if (!customer) return '';
    const { ledger } = customer;

    const lines = [
      `THÔNG BÁO CÔNG NỢ - ${customer.name || 'Khách hàng'}`,
      `Ngày cập nhật: ${formatDateTimeLabel(new Date())}`,
      `Số điện thoại: ${customer.phone || 'Chưa có'}`,
      `Địa chỉ: ${customer.address || 'Chưa có'}`,
      `Nhân viên phụ trách: ${customer.managerName || 'Chưa gán'}`,
      '',
      `Tổng doanh thu: ${formatCurrency(ledger.totalRevenue || 0)} đ`,
      `Đã thanh toán: ${formatCurrency(ledger.totalPaid || 0)} đ`,
      `Còn nợ hiện tại: ${formatCurrency(ledger.currentDebt || 0)} đ`,
      `Nợ khách: ${formatCurrency(ledger.creditBalance || 0)} đ`,
      '',
      'Danh sách đơn hàng:'
    ];

    if ((ledger.orders || []).length === 0) {
      lines.push('- Chưa có đơn hàng nào.');
    } else {
      ledger.orders.forEach((order, index) => {
        lines.push(`${index + 1}. ${formatOrderCode(order.id)} - ${formatDateLabel(order.date)} - Tổng ${formatCurrency(order.amount || 0)} đ - Còn nợ ${formatCurrency(order.outstandingAmount || 0)} đ`);
      });
    }

    lines.push('', 'Lịch sử thanh toán:');
    if ((ledger.payments || []).length === 0) {
      lines.push('- Chưa có khoản thu nào.');
    } else {
      ledger.payments.forEach((payment, index) => {
        lines.push(`${index + 1}. ${formatDateLabel(payment.date)} - ${getPaymentMethodLabel(payment)} - Thu ${formatCurrency(payment.amount || 0)} đ - Đã trừ nợ ${formatCurrency(payment.appliedAmount || 0)} đ`);
      });
    }

    return lines.join('\n');
  };

  const buildDebtShareHtml = (customer) => {
    const { ledger } = customer || {};
    const orderRows = (ledger?.orders || []).map((order) => `
      <tr>
        <td style="padding:10px;border-bottom:1px solid #e5e7eb;">${escapeHtml(formatOrderCode(order.id))}</td>
        <td style="padding:10px;border-bottom:1px solid #e5e7eb;">${escapeHtml(formatDateLabel(order.date))}</td>
        <td style="padding:10px;border-bottom:1px solid #e5e7eb;text-align:right;">${escapeHtml(formatCurrency(order.amount || 0))} đ</td>
        <td style="padding:10px;border-bottom:1px solid #e5e7eb;text-align:right;">${escapeHtml(formatCurrency(order.outstandingAmount || 0))} đ</td>
      </tr>
    `).join('');

    const paymentRows = (ledger?.payments || []).map((payment) => `
      <tr>
        <td style="padding:10px;border-bottom:1px solid #eef2f7;">${escapeHtml(formatDateLabel(payment.date))}</td>
        <td style="padding:10px;border-bottom:1px solid #eef2f7;">${escapeHtml(getPaymentMethodLabel(payment))}</td>
        <td style="padding:10px;border-bottom:1px solid #eef2f7;text-align:right;">${escapeHtml(formatCurrency(payment.amount || 0))} đ</td>
        <td style="padding:10px;border-bottom:1px solid #eef2f7;text-align:right;">${escapeHtml(formatCurrency(payment.appliedAmount || 0))} đ</td>
      </tr>
    `).join('');

    return `
      <!doctype html>
      <html lang="vi">
        <head>
          <meta charset="utf-8" />
          <title>${escapeHtml(customer?.name || 'Công nợ khách hàng')}</title>
        </head>
        <body style="font-family: Arial, sans-serif; background:#f3f4f6; padding:24px; color:#111827;">
          <div style="max-width:860px; margin:0 auto; background:#ffffff; border-radius:20px; padding:24px; border:1px solid #e5e7eb;">
            <h1 style="margin:0 0 8px; font-size:28px;">Thông báo công nợ</h1>
            <p style="margin:0 0 16px; color:#6b7280;">Khách hàng: ${escapeHtml(customer?.name || 'Khách hàng')} • Cập nhật: ${escapeHtml(formatDateTimeLabel(new Date()))}</p>
            <div style="margin-top:20px; background:#f9fafb; border-radius:16px; padding:16px;">
              <p style="margin:0 0 8px;">Tổng doanh thu: <strong>${escapeHtml(formatCurrency(ledger?.totalRevenue || 0))} đ</strong></p>
              <p style="margin:0 0 8px;">Đã thanh toán: <strong>${escapeHtml(formatCurrency(ledger?.totalPaid || 0))} đ</strong></p>
              <p style="margin:0 0 8px;">Còn nợ hiện tại: <strong>${escapeHtml(formatCurrency(ledger?.currentDebt || 0))} đ</strong></p>
              <p style="margin:0;">Nợ khách: <strong>${escapeHtml(formatCurrency(ledger?.creditBalance || 0))} đ</strong></p>
            </div>
            <h2 style="margin:24px 0 12px; font-size:18px;">Đơn hàng và công nợ</h2>
            <table style="width:100%; border-collapse:collapse;">
              <thead style="background:#f9fafb;">
                <tr>
                  <th style="padding:10px;text-align:left;">Mã đơn</th>
                  <th style="padding:10px;text-align:left;">Ngày</th>
                  <th style="padding:10px;text-align:right;">Tổng đơn</th>
                  <th style="padding:10px;text-align:right;">Còn nợ</th>
                </tr>
              </thead>
              <tbody>${orderRows || '<tr><td colspan="4" style="padding:12px;text-align:center;color:#6b7280;">Chưa có đơn hàng nào</td></tr>'}</tbody>
            </table>
            <h2 style="margin:24px 0 12px; font-size:18px;">Lịch sử thanh toán</h2>
            <table style="width:100%; border-collapse:collapse;">
              <thead style="background:#f9fafb;">
                <tr>
                  <th style="padding:10px;text-align:left;">Ngày</th>
                  <th style="padding:10px;text-align:left;">Phương thức</th>
                  <th style="padding:10px;text-align:right;">Số tiền thu</th>
                  <th style="padding:10px;text-align:right;">Đã trừ nợ</th>
                </tr>
              </thead>
              <tbody>${paymentRows || '<tr><td colspan="4" style="padding:12px;text-align:center;color:#6b7280;">Chưa có khoản thu nào</td></tr>'}</tbody>
            </table>
          </div>
        </body>
      </html>
    `;
  };

  const handleShareDebt = async (channel = 'native') => {
    if (!selectedCustomer) return;
    const result = await shareTextContent({
      title: `Công nợ - ${selectedCustomer.name || 'Khách hàng'}`,
      text: buildDebtShareText(selectedCustomer),
      dialogTitle: channel === 'native' ? 'Chia sẻ công nợ' : `Chia sẻ qua ${getShareChannelLabel(channel)}`
    });
    setDebtShareStatus(resolveDebtShareStatusMessage(result, channel));
  };

  const handleCopyDebt = async () => {
    if (!selectedCustomer) return;
    const copied = await copyTextToClipboard(buildDebtShareText(selectedCustomer));
    setDebtShareStatus(copied ? 'Đã sao chép thông tin công nợ. Bạn có thể dán vào Zalo, Facebook, Messenger hoặc email.' : 'Không thể sao chép thông tin công nợ trên thiết bị này.');
  };

  const handleDownloadDebt = async () => {
    if (!selectedCustomer) return;
    const safeName = (selectedCustomer.name || 'khach-hang').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'khach-hang';
    const result = await saveContentFile(`cong-no-${safeName}.html`, buildDebtShareHtml(selectedCustomer), 'text/html;charset=utf-8');
    if (result.status === 'saved') {
      setDebtShareStatus('Đã lưu file công nợ vào bộ nhớ máy để bạn xem lại hoặc gửi tiếp cho khách.');
      return;
    }
    if (result.status === 'downloaded') {
      setDebtShareStatus('Đã tải file công nợ về máy để bạn lưu hoặc gửi tiếp cho khách.');
      return;
    }
    setDebtShareStatus('Không thể lưu file trên thiết bị này. Bạn vẫn có thể dùng nút chia sẻ hoặc sao chép.');
  };

  if (selectedCustomer) {
    const { ledger } = selectedCustomer;

    return (
      <div className="space-y-4 animate-in fade-in pb-16">
        <button onClick={() => setSelectedCustomerId(null)} className="text-gray-500 flex items-center text-sm font-semibold mb-2"><ChevronLeft size={18} className="mr-1" /> Trở về danh sách</button>

        <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
          <div className="flex items-start justify-between gap-3">
            <div>
              <h2 className="font-bold text-xl text-gray-800">{selectedCustomer.name}</h2>
              <p className="text-sm text-gray-500 mt-1">{selectedCustomer.phone || 'Chưa có số điện thoại'} • {selectedCustomer.managerName}</p>
              <p className="text-sm text-gray-500 mt-1">{selectedCustomer.address || 'Chưa có địa chỉ'}</p>
            </div>
            <div className={`px-3 py-2 rounded-xl text-right min-w-[132px] ${ledger.currentDebt > 0 ? 'bg-red-50 text-red-600' : ledger.creditBalance > 0 ? 'bg-blue-50 text-blue-600' : 'bg-emerald-50 text-emerald-600'}`}>
              <p className="text-[10px] font-bold uppercase tracking-wide">{ledger.currentDebt > 0 ? 'Còn phải thu' : ledger.creditBalance > 0 ? 'Nợ khách' : 'Đã cân bằng'}</p>
              <p className="text-lg font-black">{formatCurrency(ledger.currentDebt > 0 ? ledger.currentDebt : ledger.creditBalance)} đ</p>
            </div>
          </div>

          <div className="grid grid-cols-2 gap-3 mt-4">
            <div className="bg-white border border-gray-100 rounded-xl p-3">
              <p className="text-[10px] uppercase font-bold text-gray-500 mb-1">Tổng doanh thu</p>
              <p className="text-lg font-black text-gray-800">{formatCurrency(ledger.totalRevenue)} đ</p>
            </div>
            <div className="bg-white border border-gray-100 rounded-xl p-3">
              <p className="text-[10px] uppercase font-bold text-gray-500 mb-1">Đã thanh toán</p>
              <p className="text-lg font-black text-emerald-600">{formatCurrency(ledger.totalPaid)} đ</p>
            </div>
          </div>

          {isAccounting ? (
            <button onClick={() => setShowPaymentModal(true)} className="w-full mt-4 py-4 rounded-xl font-bold text-white shadow-lg flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700">
              <Wallet size={20}/> Ghi nhận khoản thu
            </button>
          ) : (
            <div className="mt-4 bg-blue-50 border border-blue-100 text-blue-700 rounded-xl p-3 text-sm leading-relaxed">
              Tài xế chỉ được xem công nợ để chủ động thu tiền. Khi đã nhận tiền mặt hoặc xác nhận khách chuyển khoản đúng, kế toán sẽ là người thu nợ trên hệ thống.
            </div>
          )}
        </div>

        <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div className="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <h3 className="font-bold text-gray-800">Đơn hàng và công nợ</h3>
            <span className="text-xs text-gray-400">{ledger.orders.length} đơn</span>
          </div>
          <div className="divide-y divide-gray-50">
            {ledger.orders.length === 0 && <p className="p-4 text-center text-sm text-gray-400">Khách hàng này chưa có đơn hàng.</p>}
            {ledger.orders.map(order => (
              <div key={order.id} className="p-4">
                <div className="flex items-start justify-between gap-3">
                  <div>
                    <h4 className="font-bold text-gray-800">HD{(order.id || '').slice(-6).toUpperCase()}</h4>
                    <p className="text-xs text-gray-500 mt-1">{new Date(order.date).toLocaleDateString('vi-VN')}</p>
                  </div>
                  <div className="text-right">
                    <p className="font-black text-gray-800">{formatCurrency(order.amount)} đ</p>
                    <p className={`text-[11px] mt-1 font-bold ${order.outstandingAmount > 0 ? 'text-red-600' : 'text-emerald-600'}`}>{order.outstandingAmount > 0 ? `Còn nợ ${formatCurrency(order.outstandingAmount)} đ` : 'Đã thanh toán hết'}</p>
                  </div>
                </div>
                <div className="flex flex-wrap gap-2 mt-2">
                  {order.creditApplied > 0 && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-blue-50 text-blue-600">Đã trừ từ tiền dư {formatCurrency(order.creditApplied)} đ</span>}
                  {order.appliedAmount > order.creditApplied && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-emerald-50 text-emerald-600">Đã thanh toán {formatCurrency(order.appliedAmount)} đ</span>}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div className="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <h3 className="font-bold text-gray-800">Lịch sử thu tiền</h3>
            <span className="text-xs text-gray-400">{ledger.payments.length} lần thu</span>
          </div>
          <div className="divide-y divide-gray-50">
            {ledger.payments.length === 0 && <p className="p-4 text-center text-sm text-gray-400">Chưa có khoản thu nào.</p>}
            {ledger.payments.map(payment => (
              <div key={payment.id} className="p-4 relative">
                {isAccounting && onDeletePayment && (
                  <button onClick={() => { if (window.confirm('Xóa phiếu thu này?')) onDeletePayment(payment.id); }} className="absolute top-3 right-3 text-gray-300 hover:text-red-500">
                    <Trash2 size={14} />
                  </button>
                )}
                <div className="pr-6">
                  <div className="flex items-start justify-between gap-3">
                    <div>
                      <p className="font-semibold text-gray-800">{payment.note || 'Thu công nợ'}</p>
                      <p className="text-xs text-gray-500 mt-1">{new Date(payment.date).toLocaleDateString('vi-VN')} • {getPaymentMethodLabel(payment)} • {getPaymentSourceLabel(payment)}</p>
                    </div>
                    <p className="font-black text-emerald-600">+{formatCurrency(payment.amount)} đ</p>
                  </div>
                  <div className="flex flex-wrap gap-2 mt-2">
                    <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-emerald-50 text-emerald-600">Đã trừ nợ {formatCurrency(payment.appliedAmount || 0)} đ</span>
                    {(payment.overpaidAmount || 0) > 0 && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-blue-50 text-blue-600">Khách dư {formatCurrency(payment.overpaidAmount)} đ</span>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {showPaymentModal && isAccounting && (
          <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
            <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
              <h3 className="font-bold text-lg mb-4">Ghi nhận thanh toán</h3>
              <form onSubmit={handlePaymentSubmit} className="space-y-3">
                <input required type="tel" value={formatInputCurrency(newPayment.amount)} onChange={e=>setNewPayment({...newPayment, amount: parseInputCurrency(e.target.value)})} className="w-full border p-3 rounded-xl text-lg font-bold text-emerald-600 outline-none" placeholder="Số tiền (VNĐ)" />
                <select value={newPayment.method} onChange={e=>setNewPayment({...newPayment, method: e.target.value})} className="w-full border p-3 rounded-xl text-sm bg-white outline-none">
                  <option value="Tiền mặt">Tiền mặt</option>
                  <option value="Chuyển khoản">Chuyển khoản</option>
                </select>
                <select value={newPayment.sourceType} onChange={e=>setNewPayment({...newPayment, sourceType: e.target.value})} className="w-full border p-3 rounded-xl text-sm bg-white outline-none">
                  <option value="accounting_recovery">Kế toán thu hồi công nợ</option>
                  <option value="customer_transfer">Khách chuyển khoản</option>
                </select>
                <input required type="text" value={newPayment.note} onChange={e=>setNewPayment({...newPayment, note: capitalizeFirst(e.target.value)})} className="w-full border p-3 rounded-xl text-sm outline-none" placeholder="Ghi chú" />
                <input type="date" value={newPayment.date} onChange={e=>setNewPayment({...newPayment, date: e.target.value})} className="w-full border p-3 rounded-xl text-sm bg-white outline-none" />
                <div className="flex gap-2 mt-4">
                  <button type="button" onClick={() => setShowPaymentModal(false)} className="flex-1 bg-gray-100 py-3 rounded-xl text-gray-700 font-bold">Hủy</button>
                  <button type="submit" className="flex-1 bg-emerald-500 text-white py-3 rounded-xl font-bold">Xác nhận thu</button>
                </div>
              </form>
            </div>
          </div>
        )}
      </div>
    );
  }

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      {isAccounting && (
        <div className="grid grid-cols-2 gap-3">
          <div className="bg-gradient-to-r from-red-500 to-orange-500 p-5 rounded-[26px] shadow-md text-white border border-white/10 min-h-[120px] flex flex-col items-center justify-center text-center">
            <p className="text-red-100 text-[10px] font-bold uppercase tracking-[0.18em]">Khách nợ</p>
            <h3 className="text-[26px] font-black mt-2 leading-none">{formatCurrency(debtSummary.totalDebt)} đ</h3>
          </div>
          <div className="bg-gradient-to-r from-blue-500 to-cyan-500 p-5 rounded-[26px] shadow-md text-white border border-white/10 min-h-[120px] flex flex-col items-center justify-center text-center">
            <p className="text-blue-100 text-[10px] font-bold uppercase tracking-[0.18em]">Nợ khách</p>
            <h3 className="text-[26px] font-black mt-2 leading-none">{formatCurrency(debtSummary.totalCredit)} đ</h3>
          </div>
        </div>
      )}

      {(showSearchBox || searchKeyword || showFilterPanel) && (
        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 space-y-3">
          {(showSearchBox || searchKeyword) && (
            <div className="bg-gray-50 border border-gray-100 rounded-2xl px-3 py-2 flex items-center gap-2">
              <Search size={16} className="text-gray-400 shrink-0" />
              <input
                type="text"
                value={searchKeyword}
                onChange={(e) => setSearchKeyword(e.target.value)}
                placeholder="Tìm khách nợ hoặc nợ khách..."
                className="flex-1 bg-transparent text-sm outline-none"
              />
              {searchKeyword && (
                <button type="button" onClick={() => setSearchKeyword('')} className="text-gray-400 hover:text-gray-600">
                  <X size={16} />
                </button>
              )}
            </div>
          )}
          {showFilterPanel && (
            <div className="space-y-3">
              <div className="grid grid-cols-3 gap-2">
                <button type="button" onClick={() => setDebtViewFilter('all')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${debtViewFilter === 'all' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Tất cả</button>
                <button type="button" onClick={() => setDebtViewFilter('debt')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${debtViewFilter === 'debt' ? 'border-rose-200 bg-rose-50 text-rose-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Cần thu</button>
                <button type="button" onClick={() => setDebtViewFilter('credit')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${debtViewFilter === 'credit' ? 'border-blue-200 bg-blue-50 text-blue-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Nợ khách</button>
              </div>
              <p className="text-[11px] text-gray-500">Đang hiển thị {filteredCustomers.length} khách phù hợp với bộ lọc hiện tại.</p>
            </div>
          )}
        </div>
      )}

      <div className="space-y-3">
        {filteredCustomers.map(customer => (
          <div key={customer.id} onClick={() => setSelectedCustomerId(customer.id)} className="bg-white p-4 rounded-xl shadow-sm border border-gray-50 flex justify-between items-center cursor-pointer hover:bg-gray-50 transition">
            <div>
              <h3 className="font-bold text-gray-800 text-sm">{customer.name}</h3>
              <span className="text-[10px] text-gray-500 flex items-center mt-1"><MapPin size={10} className="mr-1"/> {customer.address || 'Chưa có địa chỉ'}</span>
            </div>
            <div className="text-right">
              {customer.ledger.currentDebt > 0 ? (
                <>
                  <span className="block font-bold text-red-500">{formatCurrency(customer.ledger.currentDebt)} đ</span>
                  <span className="text-[10px] text-gray-400">Cần thu</span>
                </>
              ) : (
                <>
                  <span className="block font-bold text-blue-500">{formatCurrency(customer.ledger.creditBalance)} đ</span>
                  <span className="text-[10px] text-gray-400">Nợ khách</span>
                </>
              )}
            </div>
          </div>
        ))}

        {filteredCustomers.length === 0 && (
          <div className="bg-white rounded-xl border border-gray-100 p-6 text-center text-sm text-gray-400">
            {isDriver
              ? 'Bạn chưa được chủ doanh nghiệp cấp quyền xem công nợ cho khách hàng nào, hoặc các khách đã được cấp hiện không còn công nợ.'
              : 'Không có khách hàng nào đang nợ hoặc nợ khách theo bộ lọc hiện tại.'}
          </div>
        )}
      </div>
    </div>
  );
}

function LoginRegisterView({ onLogin, onRegister }) {
  const [isLogin, setIsLogin] = useState(true);
  const [loginPhone, setLoginPhone] = useState('');
  const [loginError, setLoginError] = useState('');
  const [regCompanyName, setRegCompanyName] = useState('');
  const [regPhone, setRegPhone] = useState('');
  const [regError, setRegError] = useState('');
  const [isRegistering, setIsRegistering] = useState(false);

  const handleLoginSubmit = (e) => {
    e.preventDefault();
    if (!loginPhone.trim()) { setLoginError('Vui lòng nhập số điện thoại'); return; }
    if (!onLogin(loginPhone)) setLoginError('Số điện thoại không đúng hoặc công ty chưa đăng ký.');
  };

  const handleRegisterSubmit = async (e) => {
    e.preventDefault();
    if (!regCompanyName.trim() || !regPhone.trim()) { setRegError('Vui lòng điền đủ thông tin'); return; }
    setIsRegistering(true);
    const result = await onRegister(toTitleCase(regCompanyName), regPhone);
    if (!result.success) setRegError(result.message);
    setIsRegistering(false);
  };

  return (
    <div className="flex flex-col h-screen bg-[#f4f6f8] max-w-md mx-auto relative overflow-hidden items-center justify-center p-6 font-sans">
      <div className="bg-white w-full p-8 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-50 animate-in fade-in zoom-in-95 duration-300">
        
        {/* --- KHU VỰC LOGO & THƯƠNG HIỆU --- */}
        <div className="flex flex-col items-center justify-center mb-8 space-y-3">
          <div className="w-24 h-24 bg-white rounded-2xl flex items-center justify-center shadow-[0_4px_20px_rgba(0,0,0,0.08)] overflow-hidden border border-gray-50 p-2">
            <img 
              src="https://api.dicebear.com/7.x/shapes/svg?seed=HDManager&backgroundColor=10b981" 
              alt="App Logo" 
              className="w-full h-full object-contain rounded-xl" 
            />
          </div>
          <h1 className="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500 tracking-tight uppercase">
            HD MANAGER
          </h1>
          <p className="text-[10px] text-gray-400 font-bold uppercase tracking-[0.2em]">Nền tảng quản lý số</p>
        </div>
        
        <div className="flex bg-gray-50 p-1.5 rounded-xl mb-8">
          <button onClick={() => {setIsLogin(true); setRegError(''); setLoginError('');}} className={`flex-1 py-2.5 text-sm font-bold rounded-lg transition-all duration-200 ${isLogin ? 'bg-white shadow-sm text-emerald-600' : 'text-gray-400 hover:text-gray-600'}`}>Đăng nhập</button>
          <button onClick={() => {setIsLogin(false); setRegError(''); setLoginError('');}} className={`flex-1 py-2.5 text-sm font-bold rounded-lg transition-all duration-200 ${!isLogin ? 'bg-white shadow-sm text-emerald-600' : 'text-gray-400 hover:text-gray-600'}`}>Tạo Công ty</button>
        </div>

        {isLogin ? (
          <div>
            <h2 className="text-xl font-bold text-center text-gray-800 mb-2">Đăng Nhập</h2>
            <p className="text-center text-xs text-gray-500 mb-6 font-medium">Dành cho chủ doanh nghiệp và các tài khoản bộ phận</p>
            {loginError && <div className="mb-4 text-xs text-red-500 bg-red-50/50 p-3 rounded-xl text-center font-semibold">{loginError}</div>}
            <form onSubmit={handleLoginSubmit} className="space-y-4">
              <input type="tel" value={loginPhone} onChange={(e) => { setLoginPhone(e.target.value); setLoginError(''); }} className="w-full border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-emerald-500 text-sm font-medium transition-colors" placeholder="Nhập số điện thoại..." />
              <button type="submit" className="w-full bg-emerald-500 hover:bg-emerald-600 text-white py-4 rounded-2xl font-bold shadow-lg shadow-emerald-500/30 transition-all active:scale-[0.98]">Vào Ứng Dụng</button>
            </form>
            <p className="mt-4 text-center text-[11px] text-emerald-700 bg-emerald-50 rounded-xl px-3 py-2 font-semibold">Tài khoản demo có sẵn: 0909000001</p>
          </div>
        ) : (
          <div>
            <h2 className="text-xl font-bold text-center text-gray-800 mb-2">Tạo Mới</h2>
            <p className="text-center text-xs text-gray-500 mb-6 font-medium">Tạo công ty và tài khoản chủ doanh nghiệp đầu tiên</p>
            {regError && <div className="mb-4 text-xs text-red-500 bg-red-50/50 p-3 rounded-xl text-center font-semibold">{regError}</div>}
            <form onSubmit={handleRegisterSubmit} className="space-y-4">
              <input type="text" value={regCompanyName} onChange={(e) => { setRegCompanyName(toTitleCase(e.target.value)); setRegError(''); }} className="w-full border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-emerald-500 text-sm font-medium transition-colors" placeholder="Tên Doanh Nghiệp (VD: Cty HD)" />
              <input type="tel" value={regPhone} onChange={(e) => { setRegPhone(e.target.value); setRegError(''); }} className="w-full border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-emerald-500 text-sm font-medium transition-colors" placeholder="SĐT Chủ Doanh Nghiệp" />
              <button type="submit" disabled={isRegistering} className="w-full bg-orange-500 hover:bg-orange-600 text-white py-4 rounded-2xl font-bold shadow-lg shadow-orange-500/30 transition-all active:scale-[0.98] mt-2">
                {isRegistering ? 'Đang khởi tạo Cloud...' : 'Bắt Đầu Miễn Phí'}
              </button>
            </form>
            <p className="mt-4 text-[11px] text-gray-500 leading-relaxed text-center">Sau khi tạo công ty, chủ doanh nghiệp đăng nhập rồi vào mục <strong>Nhân sự</strong> để tạo các tài khoản <strong>Kế toán & nhân sự</strong>, <strong>Tài xế</strong>, <strong>Sản xuất</strong>, <strong>Kinh doanh</strong>.</p>
          </div>
        )}
      </div>
      <p className="text-[10px] text-gray-400 mt-8 text-center px-8 font-medium leading-relaxed">Bằng việc đăng nhập, bạn đồng ý với Chính sách Bảo mật. Dữ liệu được mã hóa trên Cloud.</p>
    </div>
  );
}

