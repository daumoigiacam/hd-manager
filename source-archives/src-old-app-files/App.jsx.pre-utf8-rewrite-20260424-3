function CustomerCRMView({ employee, customers, orders, payments, onAddCustomer, onEditCustomer, employees, isSuperAdmin, searchKeyword: externalSearchKeyword, setSearchKeyword: setExternalSearchKeyword, showSearchBox: externalShowSearchBox, setShowSearchBox: setExternalShowSearchBox, showFilterPanel: externalShowFilterPanel, setShowFilterPanel: setExternalShowFilterPanel }) {
  const [showAddCustomer, setShowAddCustomer] = useState(false);
  const [selectedCustomerId, setSelectedCustomerId] = useState(null);
  const [localCustomerSearchKeyword, setLocalCustomerSearchKeyword] = useState('');
  const [localShowSearchBox, setLocalShowSearchBox] = useState(false);
  const [localShowFilterPanel, setLocalShowFilterPanel] = useState(false);
  const [customerStatusFilter, setCustomerStatusFilter] = useState('all');
  const [customerManagerFilter, setCustomerManagerFilter] = useState('all');
  const [orderSearch, setOrderSearch] = useState('');
  const [orderMonth, setOrderMonth] = useState('');
  const [orderSort, setOrderSort] = useState('newest');
  const [allowedDriverIdsDraft, setAllowedDriverIdsDraft] = useState([]);
  const [isSavingDriverAccess, setIsSavingDriverAccess] = useState(false);
  const activeCustomers = customers.filter(c => !c.isArchived);

  const isSales = isSalesPosition(employee?.position);
  const salesEmployees = employees ? employees.filter(e => isSalesPosition(e.position)) : [];
  const customerSearch = externalSearchKeyword ?? localCustomerSearchKeyword;
  const setCustomerSearch = setExternalSearchKeyword ?? setLocalCustomerSearchKeyword;
  const showSearchBox = externalShowSearchBox ?? localShowSearchBox;
  const setShowSearchBox = setExternalShowSearchBox ?? setLocalShowSearchBox;
  const showFilterPanel = externalShowFilterPanel ?? localShowFilterPanel;
  const setShowFilterPanel = setExternalShowFilterPanel ?? setLocalShowFilterPanel;
  const [newCus, setNewCus] = useState({ name: '', phone: '', address: '', customerGroup: '', empId: employee?.id || '' });

  const driverEmployees = useMemo(() => employees ? employees.filter(e => isDriverPosition(e.position)) : [], [employees]);
  const customerManagerOptions = useMemo(
    () => [{ value: 'all', label: 'Tất cả NVKD' }, ...salesEmployees.map(emp => ({ value: emp.id, label: emp.name }))],
    [salesEmployees]
  );

  const customerSummaries = useMemo(() => activeCustomers.map(cus => {
    const ledger = buildCustomerLedger(cus.id, orders, payments);
    const customerOrders = [...ledger.orders].sort((a, b) => new Date(b.date) - new Date(a.date));
    const customerPayments = [...ledger.payments].sort((a, b) => new Date(b.date) - new Date(a.date));
    const manager = employees.find(emp => emp.id === cus.empId);

    return {
      ...cus,
      orders: customerOrders,
      payments: customerPayments,
      totalRevenue: ledger.totalRevenue,
      totalPaid: ledger.totalPaid,
      currentDebt: ledger.currentDebt,
      creditBalance: ledger.creditBalance,
      orderCount: customerOrders.length,
      managerName: manager?.name || 'Chưa gán',
      lastOrderDate: customerOrders[0]?.date || '',
      allowedDriverIds: cus.allowedDriverIds || [],
      allowedDriverNames: (cus.allowedDriverIds || [])
        .map(driverId => employees.find(emp => emp.id === driverId && isDriverPosition(emp.position))?.name)
        .filter(Boolean)
    };
  }), [activeCustomers, orders, payments, employees]);

  const filteredCustomers = useMemo(() => {
    const keyword = customerSearch.trim().toLowerCase();
    const baseList = [...customerSummaries].sort((a, b) => {
      if (b.totalRevenue !== a.totalRevenue) return b.totalRevenue - a.totalRevenue;
      return (a.name || '').localeCompare(b.name || '', 'vi');
    });
    return baseList.filter(cus => {
      if (customerStatusFilter === 'debt' && !(cus.currentDebt > 0)) return false;
      if (customerStatusFilter === 'credit' && !(cus.creditBalance > 0)) return false;
      if (customerStatusFilter === 'balanced' && (cus.currentDebt > 0 || cus.creditBalance > 0)) return false;
      if (customerManagerFilter !== 'all' && cus.empId !== customerManagerFilter) return false;
      if (!keyword) return true;
      const haystack = [
        cus.name,
        cus.phone,
        cus.address,
        cus.customerGroup,
        cus.managerName
      ].filter(Boolean).join(' ').toLowerCase();
      return haystack.includes(keyword);
    });
  }, [customerSummaries, customerSearch, customerStatusFilter, customerManagerFilter]);

  const selectedCustomer = useMemo(
    () => customerSummaries.find(cus => cus.id === selectedCustomerId) || null,
    [customerSummaries, selectedCustomerId]
  );

  useEffect(() => {
    if (selectedCustomerId && !customerSummaries.some(cus => cus.id === selectedCustomerId)) {
      setSelectedCustomerId(null);
    }
  }, [selectedCustomerId, customerSummaries]);

  useEffect(() => {
    setAllowedDriverIdsDraft(selectedCustomer?.allowedDriverIds || []);
  }, [selectedCustomer]);

  const availableOrderMonths = useMemo(() => {
    if (!selectedCustomer) return [];
    return [...new Set(selectedCustomer.orders.map(order => order.date?.substring(0, 7)).filter(Boolean))].sort((a, b) => b.localeCompare(a));
  }, [selectedCustomer]);

  const filteredOrders = useMemo(() => {
    if (!selectedCustomer) return [];

    const keyword = orderSearch.trim().toLowerCase();
    const list = selectedCustomer.orders.filter(order => {
      if (orderMonth && !order.date.startsWith(orderMonth)) return false;
      if (!keyword) return true;

      const orderCode = `HD${(order.id || '').slice(-6).toUpperCase()}`;
      const productNames = (order.items || []).map(item => item.description).join(' ');
      const haystack = [orderCode, order.date, productNames].join(' ').toLowerCase();
      return haystack.includes(keyword);
    });

    return list.sort((a, b) => {
      if (orderSort === 'oldest') return new Date(a.date) - new Date(b.date);
      if (orderSort === 'amount_desc') return (b.amount || 0) - (a.amount || 0);
      if (orderSort === 'amount_asc') return (a.amount || 0) - (b.amount || 0);
      return new Date(b.date) - new Date(a.date);
    });
  }, [selectedCustomer, orderMonth, orderSearch, orderSort]);

  const dashboardStats = useMemo(() => filteredCustomers.reduce((acc, cus) => {
    acc.totalRevenue += cus.totalRevenue;
    acc.totalDebt += cus.currentDebt;
    acc.totalOrders += cus.orderCount;
    return acc;
  }, { totalRevenue: 0, totalDebt: 0, totalOrders: 0 }), [filteredCustomers]);

  const handleOpenCustomer = (customerId) => {
    setSelectedCustomerId(customerId);
    setOrderSearch('');
    setOrderMonth('');
    setOrderSort('newest');
    setShowSearchBox(false);
    setShowFilterPanel(false);
  };

  const handleResetCustomerFilters = () => {
    setCustomerSearch('');
    setCustomerStatusFilter('all');
    setCustomerManagerFilter('all');
    setShowSearchBox(false);
    setShowFilterPanel(false);
  };

  const handleAddCustomerSubmit = (e) => {
    e.preventDefault();
    const finalEmpId = isSales ? employee.id : newCus.empId;
    if (!finalEmpId) return;
    onAddCustomer(finalEmpId, { name: newCus.name, phone: newCus.phone, address: newCus.address, customerGroup: newCus.customerGroup, allowedDriverIds: [] });
    setShowAddCustomer(false);
    setNewCus({ name: '', phone: '', address: '', customerGroup: '', empId: employee?.id || '' });
  };

  const toggleAllowedDriver = (driverId) => {
    setAllowedDriverIdsDraft(prev => prev.includes(driverId)
      ? prev.filter(id => id !== driverId)
      : [...prev, driverId]
    );
  };

  const handleSaveDriverAccess = async () => {
    if (!selectedCustomer || !onEditCustomer) return;
    setIsSavingDriverAccess(true);
    try {
      await onEditCustomer(selectedCustomer.id, { allowedDriverIds: allowedDriverIdsDraft });
    } finally {
      setIsSavingDriverAccess(false);
    }
  };

  if (selectedCustomer) {
    return (
      <div className="space-y-4 animate-in fade-in pb-16">
        <button onClick={() => setSelectedCustomerId(null)} className="text-gray-600 flex items-center text-sm font-semibold">
          <ChevronLeft size={18} className="mr-1" /> Trở về danh sách khách hàng
        </button>

        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
          <div className="flex items-start justify-between gap-3">
            <div>
              <div className="flex items-center gap-2 flex-wrap">
                <h2 className="text-xl font-bold text-gray-800">{selectedCustomer.name}</h2>
                {selectedCustomer.customerGroup && <span className="text-[11px] bg-emerald-50 text-emerald-700 px-2 py-1 rounded-full font-bold">Nhóm KH: {selectedCustomer.customerGroup}</span>}
              </div>
              <p className="text-sm text-gray-500 mt-2 flex items-center gap-2"><Phone size={14}/> {selectedCustomer.phone || 'Chưa có số điện thoại'}</p>
              <p className="text-sm text-gray-500 mt-1 flex items-center gap-2"><MapPin size={14}/> {selectedCustomer.address || 'Chưa có địa chỉ giao hàng'}</p>
              <p className="text-sm text-gray-500 mt-1 flex items-center gap-2"><UserCircle size={14}/> NVKD phụ trách: {selectedCustomer.managerName}</p>
            </div>
            <div className={`px-3 py-2 rounded-xl text-right min-w-[118px] ${selectedCustomer.currentDebt > 0 ? 'bg-red-50 text-red-600' : selectedCustomer.creditBalance > 0 ? 'bg-blue-50 text-blue-600' : 'bg-emerald-50 text-emerald-600'}`}>
              <p className="text-[10px] font-bold uppercase tracking-wide">{selectedCustomer.creditBalance > 0 && selectedCustomer.currentDebt === 0 ? 'Khách đang dư tiền' : 'Công nợ hiện tại'}</p>
              <p className="text-lg font-black">{formatCurrency(selectedCustomer.creditBalance > 0 && selectedCustomer.currentDebt === 0 ? selectedCustomer.creditBalance : selectedCustomer.currentDebt)} đ</p>
            </div>
          </div>
        </div>

        <div className="grid grid-cols-2 gap-3">
          <div className="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
            <p className="text-[10px] uppercase font-bold text-gray-500 mb-1">Tổng doanh thu</p>
            <p className="text-lg font-black text-emerald-600">{formatCurrency(selectedCustomer.totalRevenue)} đ</p>
          </div>
          <div className="bg-white rounded-2xl border border-gray-100 p-4 shadow-sm">
            <p className="text-[10px] uppercase font-bold text-gray-500 mb-1">Số đơn hàng</p>
            <p className="text-lg font-black text-gray-800">{selectedCustomer.orderCount}</p>
          </div>
