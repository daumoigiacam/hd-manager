const mapLocationErrorMessage = (error, source = 'web') => {
  const rawMessage = `${error?.message || ''}`.toLowerCase();
  const code = error?.code;
  const isNative = source === 'native';

  if (code === 1 || rawMessage.includes('permission') || rawMessage.includes('denied')) {
    return isNative
      ? 'App chưa được cấp quyền vị trí. Hãy vào Cài đặt > Ứng dụng > HD Manager > Quyền > Vị trí và bật quyền, rồi thử lại.'
      : 'Trình duyệt đang chặn quyền vị trí. Hãy cho phép Location/GPS cho trang này rồi thử lại.';
  }

  if (
    code === 2 ||
    rawMessage.includes('services are not enabled') ||
    rawMessage.includes('location services are disabled') ||
    (rawMessage.includes('gps') && rawMessage.includes('disabled')) ||
    rawMessage.includes('location unavailable') ||
    rawMessage.includes('unavailable')
  ) {
    return 'Điện thoại đang tắt GPS/Dịch vụ vị trí hoặc chưa bắt được tín hiệu. Hãy bật GPS, ra khu vực thoáng hơn rồi thử lại.';
  }

  if (code === 3 || rawMessage.includes('timeout')) {
    return 'Lấy vị trí GPS bị quá thời gian chờ. Hãy kiểm tra GPS, mạng và thử lại sau ít giây.';
  }

  if (rawMessage.includes('not supported') || rawMessage.includes('not available')) {
    return isNative
      ? 'Thiết bị này không sẵn sàng để lấy vị trí GPS. Hãy cập nhật dịch vụ vị trí và thử lại.'
      : 'Môi trường này chưa hỗ trợ lấy vị trí GPS. Nếu đang xem trên máy tính, hãy thử trên điện thoại hoặc APK Android.';
  }

  return isNative
    ? 'Không lấy được vị trí GPS. Hãy kiểm tra quyền vị trí và đảm bảo GPS của điện thoại đang bật.'
    : 'Không lấy được vị trí GPS. Hãy kiểm tra quyền truy cập vị trí của trình duyệt.';
};

const getBrowserGeolocationPermissionState = async () => {
  if (typeof navigator === 'undefined' || !navigator.permissions?.query) return 'prompt';
  try {
    const status = await navigator.permissions.query({ name: 'geolocation' });
    return status?.state || 'prompt';
  } catch (error) {
    return 'prompt';
  }
};

const ensureNativeLocationPermission = async () => {
  try {
    const status = await Geolocation.checkPermissions();
    if (status?.location === 'granted') return status;

    const requested = await Geolocation.requestPermissions({ permissions: ['location'] });
    if (requested?.location !== 'granted') {
      throw new Error('permission_denied');
    }
    return requested;
  } catch (error) {
    throw new Error(mapLocationErrorMessage(error, 'native'));
  }
};

const mapWifiFailureMessage = (failureCode = '', fallbackMessage = '') => {
  switch (failureCode) {
    case 'wifi_disabled':
      return 'WiFi trên điện thoại đang tắt. Hãy bật WiFi rồi thử lại.';
    case 'not_connected_to_wifi':
      return 'Máy chưa kết nối WiFi hiện tại. Hãy vào đúng WiFi nội bộ của công ty rồi thử lại.';
    case 'location_permission_denied':
      return 'Chưa cấp quyền vị trí. Hãy vào Cài đặt > Ứng dụng > HD Manager > Quyền > Vị trí và bật quyền rồi thử lại.';
    case 'nearby_wifi_permission_denied':
      return 'Chưa cấp quyền Nearby devices. Hãy vào Cài đặt > Ứng dụng > HD Manager > Quyền > Thiết bị lân cận rồi thử lại.';
    case 'location_services_off':
      return 'Điện thoại đang tắt Dịch vụ vị trí. Hãy bật Vị trí/GPS của máy rồi thử lại.';
    case 'ssid_unavailable':
      return 'Đã kết nối WiFi nhưng Android chưa trả SSID. Hãy bật WiFi, bật Dịch vụ vị trí và thử dò lại.';
    case 'unsupported':
      return fallbackMessage || 'Thiết bị này chưa hỗ trợ đọc WiFi nội bộ theo cách xác minh tự động.';
    default:
      return fallbackMessage || 'Không đọc được WiFi hiện tại. Hãy kiểm tra quyền và kết nối WiFi rồi thử lại.';
  }
};

