                <button type="submit" className="flex-1 bg-purple-600 text-white py-3 rounded-xl font-bold hover:bg-purple-700 transition-colors">
                  Lưu chỉnh sửa
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

function SettingsView({ isAccounting, holidays, onAddHoliday, onDeleteHoliday }) {
  const [showForm, setShowForm] = useState(false);
  const [newHoliday, setNewHoliday] = useState({ date: getTodayString(), name: '', type: 'fixed', value: '' });

  const handleSubmit = (e) => {
    e.preventDefault();
    if (!newHoliday.name || !newHoliday.value) return;
    onAddHoliday({ ...newHoliday, value: parseInt(newHoliday.value) || 0 });
    setShowForm(false);
    setNewHoliday({ date: getTodayString(), name: '', type: 'fixed', value: '' });
  };

  if (!isAccounting) return <div className="p-4 text-center">Bạn không có quyền truy cập.</div>;

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      <div className="flex justify-between items-center mb-2">
        <h2 className="text-lg font-bold text-gray-800">Cấu Hình Lễ Tết</h2>
        <button onClick={() => setShowForm(true)} className="bg-purple-600 text-white p-2 rounded-full shadow-sm hover:bg-purple-700"><Plus size={20} /></button>
      </div>

      <div className="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
        <p className="text-sm text-gray-600 mb-4 leading-relaxed">Nhân viên có lịch sử đi làm (hoặc đi trễ) vào các ngày được cấu hình dưới đây sẽ tự động được cộng thêm tiền thưởng vào Bảng Lương tháng.</p>
        
        <div className="space-y-3">
          {holidays.length === 0 ? <p className="text-center text-sm text-gray-400 py-4">Chưa có cấu hình ngày lễ nào.</p> : null}
          {[...holidays].sort((a,b) => new Date(b.date) - new Date(a.date)).map(h => (
            <div key={h.id} className="p-3 border border-purple-100 bg-purple-50/30 rounded-xl relative group">
              <button onClick={() => { if(window.confirm('Xóa cấu hình này?')) onDeleteHoliday(h.id); }} className="absolute top-3 right-3 text-gray-400 hover:text-red-500"><Trash2 size={16}/></button>
              <h3 className="font-bold text-gray-800 mb-1">{h.name}</h3>
              <p className="text-xs text-gray-500 flex items-center gap-1 mb-1"><Calendar size={12}/> {new Date(h.date).toLocaleDateString('vi-VN')}</p>
              <p className="text-sm font-semibold text-purple-600">
                Thưởng: {h.type === 'fixed' ? `+${formatCurrency(h.value)} đ` : `+${h.value}% lương ngày`}
              </p>
            </div>
          ))}
        </div>
      </div>

      {showForm && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4 text-gray-800">Thêm Ngày Lễ</h3>
            <form onSubmit={handleSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-bold text-gray-500 uppercase mb-1">Tên Ngày Lễ</label>
                <input required type="text" value={newHoliday.name} onChange={e=>setNewHoliday({...newHoliday, name: capitalizeFirst(e.target.value)})} className="w-full border border-gray-300 p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-purple-500" placeholder="VD: Quốc Khánh 2/9" />
              </div>
              <div>
                <label className="block text-xs font-bold text-gray-500 uppercase mb-1">Chọn Ngày</label>
                <input required type="date" value={newHoliday.date} onChange={e=>setNewHoliday({...newHoliday, date: e.target.value})} className="w-full border border-gray-300 p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-purple-500 bg-white" />
              </div>
              <div>
                <label className="block text-xs font-bold text-gray-500 uppercase mb-1">Hình Thức Thưởng</label>
                <select value={newHoliday.type} onChange={e=>setNewHoliday({...newHoliday, type: e.target.value})} className="w-full border border-gray-300 p-3 rounded-xl text-sm outline-none bg-white focus:ring-2 focus:ring-purple-500">
                  <option value="fixed">Tiền mặt cố định (VNĐ)</option>
                  <option value="percentage">Phần trăm (%) Lương ngày</option>
                </select>
              </div>
              <div>
                <label className="block text-xs font-bold text-gray-500 uppercase mb-1">Mức thưởng</label>
                <input required type="tel" value={formatInputCurrency(newHoliday.value)} onChange={e=>setNewHoliday({...newHoliday, value: parseInputCurrency(e.target.value)})} className="w-full border border-gray-300 p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-purple-500 font-bold text-purple-600" placeholder={newHoliday.type === 'fixed' ? 'VD: 500.000' : 'VD: 200'} />
              </div>
              <div className="flex gap-2 pt-2">
                <button type="button" onClick={()=>setShowForm(false)} className="flex-1 bg-gray-100 text-gray-600 py-3.5 rounded-xl font-bold transition-colors">Hủy</button>
                <button type="submit" className="flex-[2] bg-purple-600 text-white py-3.5 rounded-xl font-bold transition-colors shadow-md shadow-purple-500/30">Lưu Cấu Hình</button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

