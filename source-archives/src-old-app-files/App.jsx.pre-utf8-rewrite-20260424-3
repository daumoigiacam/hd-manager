    </div>
  );
}

function FinanceViewLegacy({ isAccounting, employee, expenses, payments, onAddExpense, onAddPayment, onToggleArchiveExpense, onToggleArchivePayment, onDeleteExpense, onDeletePayment, employees, customers }) {
  const [filterMonth, setFilterMonth] = useState(getTodayString().substring(0, 7));
  const [showExpenseModal, setShowExpenseModal] = useState(false);
  const [showPaymentModal, setShowPaymentModal] = useState(false);
  const [actionItem, setActionItem] = useState(null);

  const [newExpense, setNewExpense] = useState({ category: 'Chi mua hàng hóa', amount: '', note: '', date: getTodayString() });
  const [newPayment, setNewPayment] = useState({ customerId: '', amount: '', note: 'Thu nợ', date: getTodayString() });

  const categories = ['Chi mua hàng hóa', 'Chi xăng dầu', 'Chi phí văn phòng', 'Chi phí khác'];

  const allTransactions = useMemo(() => {
    const list = [
      ...expenses.map(e => ({ ...e, isExpense: true })),
      ...payments.map(p => ({ ...p, isExpense: false }))
    ];
    return list.filter(t => t.date.startsWith(filterMonth) && !t.isArchived).sort((a,b) => new Date(b.date) - new Date(a.date));
  }, [expenses, payments, filterMonth]);

  const totalExpense = allTransactions.filter(t => t.isExpense).reduce((sum, t) => sum + (t.amount || 0), 0);
  const totalIncome = allTransactions.filter(t => !t.isExpense).reduce((sum, t) => sum + (t.amount || 0), 0);
  const balance = totalIncome - totalExpense;

  const handleExpenseSubmit = (e) => {
    e.preventDefault();
    if (newExpense.amount > 0) onAddExpense({ ...newExpense, note: capitalizeFirst(newExpense.note) });
    setShowExpenseModal(false);
    setNewExpense({ category: 'Chi mua hàng hóa', amount: '', note: '', date: getTodayString() });
  };
  const handlePaymentSubmit = (e) => {
    e.preventDefault();
    if (newPayment.amount > 0 && newPayment.customerId) onAddPayment({ ...newPayment, note: capitalizeFirst(newPayment.note) });
    setShowPaymentModal(false);
    setNewPayment({ customerId: '', amount: '', note: 'Thu nợ', date: getTodayString() });
  };

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      <div className="flex gap-2 mb-4">
        <select className="bg-white border border-gray-200 rounded-full px-3 py-1.5 text-xs font-semibold outline-none" value={filterMonth} onChange={e=>setFilterMonth(e.target.value)}>
          <option value={getTodayString().substring(0, 7)}>Tháng này</option>
          <option value="">Tất cả</option>
        </select>
        <button className="bg-white border border-gray-200 rounded-full px-3 py-1.5 text-xs font-semibold outline-none flex items-center gap-1">Khách hàng <ChevronDown size={12}/></button>
      </div>

      <div className="bg-white rounded-xl shadow-sm border border-gray-50 p-4">
        <div className="flex justify-between items-end mb-4 border-b border-gray-100 pb-4">
          <span className="text-xs font-bold text-gray-500 uppercase">Chênh lệch</span>
          <span className="text-2xl font-bold text-gray-800">{formatCurrency(balance)} đ</span>
        </div>
        <div className="grid grid-cols-2 gap-3">
          <div className="bg-orange-50/50 border border-orange-100 rounded-lg p-3">
            <p className="text-[10px] text-orange-800 font-bold mb-1 flex items-center gap-1"><ArrowRightLeft size={12} className="rotate-90"/> TỔNG CHI</p>
            <p className="font-bold text-orange-600">{formatCurrency(totalExpense)}</p>
          </div>
          <div className="bg-emerald-50/50 border border-emerald-100 rounded-lg p-3">
            <p className="text-[10px] text-emerald-800 font-bold mb-1 flex items-center gap-1"><ArrowRightLeft size={12} className="-rotate-90"/> TỔNG THU</p>
            <p className="font-bold text-emerald-600">{formatCurrency(totalIncome)}</p>
          </div>
        </div>
      </div>

      <div className="space-y-0 bg-white rounded-xl border border-gray-50 shadow-sm overflow-hidden">
        {allTransactions.length === 0 ? <p className="p-4 text-center text-sm text-gray-400">Chưa có giao dịch.</p> : 
          allTransactions.map(t => {
            const isChi = t.isExpense;
            const empName = employees.find(e => e.id === t.empId)?.name || 'Admin';
            const cusName = isChi ? null : customers.find(c => c.id === t.customerId)?.name || 'Khách vô danh';
            return (
              <div key={t.id} className="p-3 border-b border-gray-50 last:border-0 relative group flex items-start gap-3 bg-white">
                {isAccounting && <button onClick={() => { if(window.confirm('Xóa vĩnh viễn giao dịch này?')) isChi ? onDeleteExpense(t.id) : onDeletePayment(t.id); }} className="absolute top-3 right-3 text-gray-300 hover:text-red-500"><Trash2 size={14}/></button>}
                <div className={`mt-1 w-6 h-6 rounded-full flex items-center justify-center shrink-0 border ${isChi ? 'border-orange-200 text-orange-500 bg-orange-50' : 'border-emerald-200 text-emerald-500 bg-emerald-50'}`}>
                  {isChi ? <MinusCircle size={14}/> : <PlusCircle size={14}/>}
                </div>
                <div className="flex-1 pr-6">
                  <div className="flex justify-between items-start mb-1">
                    <h3 className="font-bold text-sm text-gray-800 line-clamp-1">{isChi ? t.note : cusName}</h3>
                    <span className={`font-bold shrink-0 ${isChi ? 'text-orange-600' : 'text-emerald-600'}`}>{isChi ? '-' : '+'}{formatCurrency(t.amount)}</span>
                  </div>
                  <p className="text-xs text-gray-600 mb-0.5">{isChi ? t.category : t.note}</p>
                  <p className="text-[10px] text-gray-400">{new Date(t.date).toLocaleDateString('vi-VN')} • Tạo bởi: {empName}</p>
                </div>
              </div>
            )
          })
        }
      </div>

      <div className="fixed bottom-[70px] left-0 w-full px-4 flex gap-3 pointer-events-none">
        <div className="w-full max-w-md mx-auto flex gap-3 pointer-events-auto">
          <button onClick={() => setShowExpenseModal(true)} className="flex-1 bg-orange-500 text-white rounded-xl py-3 font-bold shadow-lg flex items-center justify-center gap-2 hover:bg-orange-600"><MinusCircle size={18}/> Khoản chi</button>
          <button onClick={() => setShowPaymentModal(true)} className="flex-1 bg-emerald-500 text-white rounded-xl py-3 font-bold shadow-lg flex items-center justify-center gap-2 hover:bg-emerald-600"><PlusCircle size={18}/> Khoản thu</button>
        </div>
      </div>

      {showExpenseModal && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">Tạo Khoản Chi</h3>
            <form onSubmit={handleExpenseSubmit} className="space-y-3">
              <select value={newExpense.category} onChange={e=>setNewExpense({...newExpense, category: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">{categories.map(c=><option key={c}>{c}</option>)}</select>
              <input required type="tel" value={formatInputCurrency(newExpense.amount)} onChange={e=>setNewExpense({...newExpense, amount: parseInputCurrency(e.target.value)})} placeholder="Số tiền" className="w-full border p-2.5 rounded-xl text-sm" />
              <input required type="text" value={newExpense.note} onChange={e=>setNewExpense({...newExpense, note: capitalizeFirstPreservingSpacing(e.target.value)})} placeholder="Nội dung" className="w-full border p-2.5 rounded-xl text-sm" />
              <div className="flex gap-2">
                <button type="button" onClick={()=>setShowExpenseModal(false)} className="flex-1 bg-gray-100 py-3 rounded-xl text-gray-700 font-bold">Hủy</button>
                <button type="submit" className="flex-1 bg-orange-500 text-white py-3 rounded-xl font-bold">Lưu chi</button>
              </div>
            </form>
          </div>
        </div>
      )}

      {showPaymentModal && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">Tạo Khoản Thu</h3>
            <form onSubmit={handlePaymentSubmit} className="space-y-3">
              <select required value={newPayment.customerId} onChange={e=>setNewPayment({...newPayment, customerId: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">
                <option value="">-- Chọn khách hàng --</option>
                {customers.map(c=><option key={c.id} value={c.id}>{c.name}</option>)}
              </select>
              <input required type="tel" value={formatInputCurrency(newPayment.amount)} onChange={e=>setNewPayment({...newPayment, amount: parseInputCurrency(e.target.value)})} placeholder="Số tiền" className="w-full border p-2.5 rounded-xl text-sm" />
              <input required type="text" value={newPayment.note} onChange={e=>setNewPayment({...newPayment, note: capitalizeFirst(e.target.value)})} placeholder="Nội dung (Mặc định: Thu nợ)" className="w-full border p-2.5 rounded-xl text-sm" />
              <div className="flex gap-2">
                <button type="button" onClick={()=>setShowPaymentModal(false)} className="flex-1 bg-gray-100 py-3 rounded-xl text-gray-700 font-bold">Hủy</button>
                <button type="submit" className="flex-1 bg-emerald-500 text-white py-3 rounded-xl font-bold">Lưu thu</button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

function NavButton({ icon, label, active, onClick }) { 
  return (
    <button onClick={onClick} className={`flex flex-col items-center justify-center space-y-1 w-16 shrink-0 transition-colors ${active ? 'text-emerald-600' : 'text-gray-400 hover:text-gray-600'}`}>
      {React.cloneElement(icon, { size: 22, className: active ? 'stroke-2' : 'stroke-[1.5px]' })}
      <span className={`text-[10px] whitespace-nowrap ${active ? 'font-bold' : 'font-medium'}`}>{label}</span>
    </button>
  ); 
}

function FinanceView({ isAccounting, employee, expenses, payments, orders, onAddExpense, onAddPayment, onDeleteExpense, onDeletePayment, employees, customers, searchKeyword: externalSearchKeyword, setSearchKeyword: setExternalSearchKeyword, showSearchBox: externalShowSearchBox, setShowSearchBox: setExternalShowSearchBox, showFilterPanel: externalShowFilterPanel, setShowFilterPanel: setExternalShowFilterPanel }) {
  const [filterDate, setFilterDate] = useState(getTodayString());
  const [periodType, setPeriodType] = useState('day');
  const [transactionTypeFilter, setTransactionTypeFilter] = useState('all');
  const [localSearchKeyword, setLocalSearchKeyword] = useState('');
  const [localShowSearchBox, setLocalShowSearchBox] = useState(false);
  const [localShowFilterPanel, setLocalShowFilterPanel] = useState(false);
  const [showExpenseModal, setShowExpenseModal] = useState(false);
  const [showPaymentModal, setShowPaymentModal] = useState(false);
  const [newExpense, setNewExpense] = useState({ category: 'Chi mua hàng hóa', customCategory: '', amount: '', note: '', date: getTodayString() });
  const [newPayment, setNewPayment] = useState({
    customerId: '',
    amount: '',
    note: '',
    date: getTodayString(),
    method: 'Tiền mặt',
    sourceType: 'driver_cash'
  });

  const expenseCategories = useMemo(() => {
    const base = ['Chi mua hàng hóa', 'Chi xăng dầu', 'Chi phí văn phòng', 'Chi phí khác'];
    const dynamic = [...new Set(expenses.map(expense => normalizeExpenseCategoryLabel(expense.category)).filter(Boolean))];
    return [...new Set([...base, ...dynamic])];
  }, [expenses]);
  const normalizedExpenseCategory = normalizeExpenseCategoryLabel(newExpense.category);
  const isNewExpenseCategory = Boolean(normalizedExpenseCategory) && !expenseCategories.includes(normalizedExpenseCategory);

  const employeeNameMap = useMemo(
    () => Object.fromEntries(employees.map(emp => [emp.id, emp.name])),
    [employees]
  );

  const customerNameMap = useMemo(
    () => Object.fromEntries(customers.map(customer => [customer.id, customer.name])),
    [customers]
  );
  const searchKeyword = externalSearchKeyword ?? localSearchKeyword;
  const setSearchKeyword = setExternalSearchKeyword ?? setLocalSearchKeyword;
  const showSearchBox = externalShowSearchBox ?? localShowSearchBox;
  const setShowSearchBox = setExternalShowSearchBox ?? setLocalShowSearchBox;
  const showFilterPanel = externalShowFilterPanel ?? localShowFilterPanel;
  const setShowFilterPanel = setExternalShowFilterPanel ?? setLocalShowFilterPanel;

  const periodRange = useMemo(
    () => getDateRangeForPeriod(filterDate, periodType),
    [filterDate, periodType]
  );

  const periodLabel = useMemo(
    () => buildPeriodLabel(periodType, periodRange),
    [periodType, periodRange]
  );

  const customerLedgerMap = useMemo(() => Object.fromEntries(
    customers.map(customer => [customer.id, buildCustomerLedger(customer.id, orders, payments)])
  ), [customers, orders, payments]);

  const paymentStatusMap = useMemo(() => {
    const map = {};
    Object.values(customerLedgerMap).forEach(ledger => {
      ledger.payments.forEach(payment => {
        map[payment.id] = payment;
      });
    });
    return map;
  }, [customerLedgerMap]);

  const periodTransactions = useMemo(() => {
    const list = [
      ...expenses
        .filter(expense => !expense.isArchived && expense.date >= periodRange.startDate && expense.date <= periodRange.endDate)
        .map(expense => ({ ...expense, transactionType: 'expense' })),
      ...payments
        .filter(payment => !payment.isArchived && payment.date >= periodRange.startDate && payment.date <= periodRange.endDate)
        .map(payment => ({
        ...payment,
        ...(paymentStatusMap[payment.id] || {}),
        transactionType: 'payment'
      }))
    ];

    return list.sort((a, b) => {
      if ((b.date || '') !== (a.date || '')) return (b.date || '').localeCompare(a.date || '');
      return (b.id || '').localeCompare(a.id || '');
    });
  }, [expenses, payments, paymentStatusMap, periodRange]);

  const filteredTransactions = useMemo(() => {
    const keyword = searchKeyword.trim().toLowerCase();

    return periodTransactions.filter(transaction => {
      if (transactionTypeFilter !== 'all' && transaction.transactionType !== transactionTypeFilter) return false;
      if (!keyword) return true;

      const employeeName = employeeNameMap[transaction.empId] || 'K? to?n';
      const customerName = customerNameMap[transaction.customerId] || 'Khách hàng';
      const haystack = [
        transaction.note,
        transaction.category,
        customerName,
        transaction.date,
        employeeName,
        formatCurrency(transaction.amount),
        getPaymentMethodLabel(transaction),
        getPaymentSourceLabel(transaction)
      ].filter(Boolean).join(' ').toLowerCase();

      return haystack.includes(keyword);
    });
  }, [periodTransactions, transactionTypeFilter, searchKeyword, employeeNameMap, customerNameMap]);

  const totalExpense = filteredTransactions.filter(item => item.transactionType === 'expense').reduce((sum, item) => sum + (item.amount || 0), 0);
  const totalIncome = filteredTransactions.filter(item => item.transactionType === 'payment').reduce((sum, item) => sum + (item.amount || 0), 0);
  const balance = totalIncome - totalExpense;

  const handleResetFilters = () => {
    setFilterDate(getTodayString());
    setPeriodType('day');
    setTransactionTypeFilter('all');
    setSearchKeyword('');
    setShowSearchBox(false);
    setShowFilterPanel(false);
  };

  const handleExpenseSubmit = (e) => {
    e.preventDefault();
    const selectedCategory = normalizeExpenseCategoryLabel(newExpense.category);
    if (!selectedCategory || !newExpense.amount) return;

    onAddExpense({
      category: selectedCategory,
      amount: parseInputCurrency(newExpense.amount),
      note: normalizeLeadingLabel(newExpense.note),
      date: newExpense.date
    });

    setShowExpenseModal(false);
    setNewExpense({ category: 'Chi mua hàng hóa', customCategory: '', amount: '', note: '', date: getTodayString() });
  };

  const paymentSourceOptions = [
    { value: 'driver_cash', label: 'Tài xế nộp tiền mặt', note: 'Tài xế nộp tiền mặt' },
    { value: 'customer_transfer', label: 'Khách chuyển khoản', note: 'Khách chuyển khoản thanh toán' },
    { value: 'accounting_recovery', label: 'Kế toán thu hồi công nợ', note: 'Kế toán thu hồi công nợ' }
  ];

  const handlePaymentSubmit = (e) => {
    e.preventDefault();
    if (!newPayment.customerId || !newPayment.amount) return;

    const selectedSource = paymentSourceOptions.find(option => option.value === newPayment.sourceType);

    onAddPayment({
      customerId: newPayment.customerId,
      amount: parseInputCurrency(newPayment.amount),
      note: capitalizeFirst(newPayment.note || selectedSource?.note || 'Thu công nợ'),
      date: newPayment.date,
      method: newPayment.method,
      sourceType: newPayment.sourceType,
      sourceLabel: selectedSource?.label || 'Thu công nợ'
    });

    setShowPaymentModal(false);
    setNewPayment({
      customerId: '',
      amount: '',
      note: '',
      date: getTodayString(),
      method: 'Tiền mặt',
      sourceType: 'driver_cash'
    });
  };

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      {(showSearchBox || searchKeyword || showFilterPanel) && (
        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
        {(showSearchBox || searchKeyword) && (
          <div className="bg-gray-50 border border-gray-100 rounded-2xl px-3 py-2 flex items-center gap-2">
            <Search size={14} />
            <input
              type="text"
              value={searchKeyword}
              onChange={(e) => setSearchKeyword(e.target.value)}
              placeholder="Tìm theo khách hàng, nội dung, loại chi phí, phương thức thu..."
              className="flex-1 bg-transparent text-sm outline-none"
            />
            {searchKeyword && (
              <button onClick={() => setSearchKeyword('')} className="text-gray-400 hover:text-gray-600">
                <X size={16} />
              </button>
            )}
          </div>
        )}
        {showFilterPanel && (
          <div className={`space-y-3 ${showSearchBox || searchKeyword ? 'mt-3' : ''}`}>
            <div className="grid grid-cols-2 gap-3">
              <select value={periodType} onChange={(e) => setPeriodType(e.target.value)} className="w-full border border-gray-200 rounded-xl p-3 text-sm outline-none bg-white">
                <option value="day">Theo ngày</option>
                <option value="week">Theo tuần</option>
                <option value="month">Theo tháng</option>
                <option value="year">Theo năm</option>
              </select>
              <select value={transactionTypeFilter} onChange={(e) => setTransactionTypeFilter(e.target.value)} className="w-full border border-gray-200 rounded-xl p-3 text-sm outline-none bg-white">
                <option value="all">Tất cả giao dịch</option>
                <option value="payment">Chỉ xem khoản thu</option>
                <option value="expense">Chỉ xem khoản chi</option>
              </select>
            </div>
            <input type="date" value={filterDate} onChange={(e) => setFilterDate(e.target.value)} className="w-full border border-gray-200 rounded-xl p-3 text-sm outline-none bg-white" />
            <div className="flex items-center justify-between gap-3 text-[11px] text-gray-500">
              <p>Khoảng lọc từ {parseDateInputValue(periodRange.startDate).toLocaleDateString('vi-VN')} đến {parseDateInputValue(periodRange.endDate).toLocaleDateString('vi-VN')}</p>
              <button onClick={handleResetFilters} className="text-blue-600 font-bold hover:text-blue-700">Đặt lại</button>
            </div>
          </div>
        )}
        </div>
      )}

      <div className="bg-gradient-to-br from-slate-900 to-slate-700 text-white rounded-2xl p-5 shadow-md">
        <p className="text-slate-200 text-xs font-bold uppercase tracking-[0.16em] mb-1">Tổng kết ngày {new Date(filterDate).toLocaleDateString('vi-VN')}</p>
        <h3 className={`text-3xl font-black ${balance < 0 ? 'text-red-300' : 'text-white'}`}>{formatCurrency(balance)} đ</h3>
        <p className="text-slate-300 text-xs mt-1">Chênh lệch thu chi trong ngày</p>
        <div className="grid grid-cols-2 gap-3 mt-4">
          <div className="bg-orange-500/10 border border-orange-300/20 rounded-xl p-3">
            <p className="text-[10px] uppercase font-bold text-orange-200 mb-1">Tổng chi</p>
            <p className="text-lg font-black text-orange-100">{formatCurrency(totalExpense)} đ</p>
          </div>
          <div className="bg-emerald-500/10 border border-emerald-300/20 rounded-xl p-3">
            <p className="text-[10px] uppercase font-bold text-emerald-200 mb-1">Tổng thu</p>
            <p className="text-lg font-black text-emerald-100">{formatCurrency(totalIncome)} đ</p>
          </div>
        </div>
      </div>

      <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div className="px-4 py-3 border-b border-gray-100">
          <h3 className="font-bold text-gray-800">Nhật ký thu chi trong ngày</h3>
        </div>
        {filteredTransactions.length === 0 ? (
          <p className="p-4 text-center text-sm text-gray-400">Chưa có giao dịch nào trong ngày đã chọn.</p>
        ) : (
          <div className="divide-y divide-gray-50">
            {filteredTransactions.map(transaction => {
              const isExpense = transaction.transactionType === 'expense';
              const empName = employees.find(emp => emp.id === transaction.empId)?.name || 'Kế toán';
              const customerName = customers.find(customer => customer.id === transaction.customerId)?.name || 'Khách hàng';

              return (
                <div key={transaction.id} className="p-4 flex gap-3 items-start relative">
                  {isAccounting && (
                    <button onClick={() => { if (window.confirm('Xóa giao dịch này?')) isExpense ? onDeleteExpense(transaction.id) : onDeletePayment(transaction.id); }} className="absolute top-3 right-3 text-gray-300 hover:text-red-500">
                      <Trash2 size={14} />
                    </button>
                  )}
                  <div className={`w-9 h-9 rounded-full border flex items-center justify-center shrink-0 ${isExpense ? 'bg-orange-50 text-orange-500 border-orange-100' : 'bg-emerald-50 text-emerald-500 border-emerald-100'}`}>
                    {isExpense ? <MinusCircle size={16} /> : <PlusCircle size={16} />}
                  </div>
                  <div className="flex-1 pr-6">
                    <div className="flex items-start justify-between gap-3">
                      <div>
                        <h4 className="font-bold text-sm text-gray-800">{isExpense ? normalizeLeadingLabel(transaction.note || transaction.category || 'Khoản chi') : customerName}</h4>
                        <p className="text-xs text-gray-500 mt-1">{isExpense ? normalizeExpenseCategoryLabel(transaction.category || 'Chi phí') : `${getPaymentMethodLabel(transaction)} • ${getPaymentSourceLabel(transaction)}`}</p>
                      </div>
                      <p className={`font-black ${isExpense ? 'text-orange-600' : 'text-emerald-600'}`}>{isExpense ? '-' : '+'}{formatCurrency(transaction.amount)} đ</p>
                    </div>
                    <p className="text-[11px] text-gray-400 mt-2">Ngày {new Date(transaction.date).toLocaleDateString('vi-VN')} • Tạo bởi {empName}</p>
                    {!isExpense && (
                      <div className="flex flex-wrap gap-2 mt-2">
                        <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-emerald-50 text-emerald-600">Đã trừ nợ {formatCurrency(transaction.appliedAmount || 0)} đ</span>
                        {(transaction.overpaidAmount || 0) > 0 && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-blue-50 text-blue-600">Khách dư {formatCurrency(transaction.overpaidAmount)} đ</span>}
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <div className="fixed bottom-[70px] left-0 w-full px-4 flex gap-3 pointer-events-none">
        <div className="w-full max-w-md mx-auto flex gap-3 pointer-events-auto">
          <button onClick={() => setShowExpenseModal(true)} className="flex-1 bg-orange-500 text-white rounded-xl py-3 font-bold shadow-lg flex items-center justify-center gap-2 hover:bg-orange-600"><MinusCircle size={18}/> Khoản chi</button>
          <button onClick={() => setShowPaymentModal(true)} className="flex-1 bg-emerald-500 text-white rounded-xl py-3 font-bold shadow-lg flex items-center justify-center gap-2 hover:bg-emerald-600"><PlusCircle size={18}/> Khoản thu</button>
        </div>
      </div>

      {showExpenseModal && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">Tạo khoản chi</h3>
            <form onSubmit={handleExpenseSubmit} className="space-y-3">
              <div>
                <input
                  required
                  type="text"
                  list="expense-category-list"
                  value={newExpense.category}
                  onChange={e=>setNewExpense({...newExpense, category: capitalizeFirstPreservingSpacing(e.target.value)})}
                  placeholder="Nhập hoặc chọn loại chi phí"
                  className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white"
                />
                <datalist id="expense-category-list">
                  {expenseCategories.map(category => <option key={category} value={category} />)}
                </datalist>
                <p className={`text-[11px] mt-2 ${isNewExpenseCategory ? 'text-blue-600 font-medium' : 'text-gray-500'}`}>
                  {isNewExpenseCategory ? `Loại chi phí "${normalizedExpenseCategory}" chưa có sẵn. Hệ thống sẽ tự tạo khi bạn lưu khoản chi.` : 'Có thể chọn loại chi sẵn có hoặc nhập loại mới ngay tại ô này.'}
                </p>
              </div>
              <input required type="tel" value={formatInputCurrency(newExpense.amount)} onChange={e=>setNewExpense({...newExpense, amount: parseInputCurrency(e.target.value)})} placeholder="Số tiền" className="w-full border p-2.5 rounded-xl text-sm" />
              <input required type="text" value={newExpense.note} onChange={e=>setNewExpense({...newExpense, note: capitalizeFirstPreservingSpacing(e.target.value)})} placeholder="Nội dung chi" className="w-full border p-2.5 rounded-xl text-sm" />
              <input type="date" value={newExpense.date} onChange={e=>setNewExpense({...newExpense, date: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm bg-white" />
              <div className="flex gap-2 pt-2">
                <button type="button" onClick={()=>setShowExpenseModal(false)} className="flex-1 bg-gray-100 py-3 rounded-xl text-gray-700 font-bold">Hủy</button>
                <button type="submit" className="flex-1 bg-orange-500 text-white py-3 rounded-xl font-bold">Lưu khoản chi</button>
              </div>
            </form>
          </div>
        </div>
      )}

      {showPaymentModal && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">Ghi nhận khoản thu</h3>
            <form onSubmit={handlePaymentSubmit} className="space-y-3">
              <select required value={newPayment.customerId} onChange={e=>setNewPayment({...newPayment, customerId: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">
                <option value="">-- Chọn khách hàng --</option>
                {customers.map(customer => {
                  const ledger = customerLedgerMap[customer.id];
                  return (
                    <option key={customer.id} value={customer.id}>
                      {customer.name} • Nợ {formatCurrency(ledger?.currentDebt || 0)} • Dư {formatCurrency(ledger?.creditBalance || 0)}
                    </option>
                  );
                })}
              </select>
              <select value={newPayment.method} onChange={e=>setNewPayment({...newPayment, method: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">
                <option value="Tiền mặt">Tiền mặt</option>
                <option value="Chuyển khoản">Chuyển khoản</option>
              </select>
              <select value={newPayment.sourceType} onChange={e=>setNewPayment({...newPayment, sourceType: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">
                {paymentSourceOptions.map(option => <option key={option.value} value={option.value}>{option.label}</option>)}
              </select>
              <input required type="tel" value={formatInputCurrency(newPayment.amount)} onChange={e=>setNewPayment({...newPayment, amount: parseInputCurrency(e.target.value)})} placeholder="Số tiền thu" className="w-full border p-2.5 rounded-xl text-sm" />
              <input type="text" value={newPayment.note} onChange={e=>setNewPayment({...newPayment, note: capitalizeFirst(e.target.value)})} placeholder="Ghi chú (không bắt buộc)" className="w-full border p-2.5 rounded-xl text-sm" />
              <input type="date" value={newPayment.date} onChange={e=>setNewPayment({...newPayment, date: e.target.value})} className="w-full border p-2.5 rounded-xl text-sm bg-white" />
              <div className="flex gap-2 pt-2">
                <button type="button" onClick={()=>setShowPaymentModal(false)} className="flex-1 bg-gray-100 py-3 rounded-xl text-gray-700 font-bold">Hủy</button>
                <button type="submit" className="flex-1 bg-emerald-500 text-white py-3 rounded-xl font-bold">Lưu khoản thu</button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

