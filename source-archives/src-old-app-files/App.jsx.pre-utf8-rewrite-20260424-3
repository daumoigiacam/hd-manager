                      {order.outstandingAmount > 0 ? `Còn nợ ${formatCurrency(order.outstandingAmount)} đ` : 'Đã thanh toán hết'}
                    </span>
                    {order.creditApplied > 0 && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-blue-50 text-blue-600">Đã trừ từ tiền dư {formatCurrency(order.creditApplied)} đ</span>}
                  </div>
                  {order.extraExpenseName && order.customerExtraExpense > 0 && (
                    <p className="text-xs text-blue-600 font-medium mt-2">Phụ phí tính cho khách: {order.extraExpenseName} ({formatCurrency(order.customerExtraExpense)} đ)</p>
                  )}
                </div>
              );
            })}
          </div>
        </div>

        <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
          <div className="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <h3 className="font-bold text-gray-800 flex items-center gap-2"><Wallet size={16}/> Lịch sử thanh toán</h3>
            <span className="text-xs text-gray-400">{selectedCustomer.payments.length} lần thu</span>
          </div>
          <div className="divide-y divide-gray-50">
            {selectedCustomer.payments.length === 0 && <p className="p-4 text-center text-sm text-gray-400">Khách hàng này chưa có lịch sử thanh toán.</p>}
            {selectedCustomer.payments.map(payment => (
              <div key={payment.id} className="p-4 flex items-start justify-between gap-3">
                <div>
                  <p className="font-semibold text-gray-800">{payment.note || 'Thu nợ'}</p>
                  <p className="text-xs text-gray-500 mt-1">{new Date(payment.date).toLocaleDateString('vi-VN')} • {getPaymentMethodLabel(payment)} • {getPaymentSourceLabel(payment)}</p>
                  <div className="flex flex-wrap gap-2 mt-2">
                    <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-emerald-50 text-emerald-600">Đã trừ nợ {formatCurrency(payment.appliedAmount || 0)} đ</span>
                    {(payment.overpaidAmount || 0) > 0 && <span className="text-[11px] px-2 py-1 rounded-full font-bold bg-blue-50 text-blue-600">Khách dư {formatCurrency(payment.overpaidAmount)} đ</span>}
                  </div>
                </div>
                <p className="font-black text-emerald-600">+{formatCurrency(payment.amount)} đ</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      <div className="bg-gradient-to-r from-emerald-500 to-teal-600 text-white rounded-2xl p-5 shadow-md">
        <p className="text-emerald-100 text-xs font-bold uppercase tracking-wider mb-1">Tổng quan khách hàng</p>
        <h3 className="text-3xl font-black">{filteredCustomers.length}</h3>
        <div className="grid grid-cols-3 gap-3 mt-4 border-t border-white/20 pt-3">
          <div>
            <p className="text-[10px] text-emerald-100 uppercase mb-1">Doanh thu</p>
            <p className="font-bold text-sm">{formatCurrency(dashboardStats.totalRevenue)}</p>
          </div>
          <div>
            <p className="text-[10px] text-emerald-100 uppercase mb-1">Đơn hàng</p>
            <p className="font-bold text-sm">{dashboardStats.totalOrders}</p>
          </div>
          <div>
            <p className="text-[10px] text-emerald-100 uppercase mb-1">Công nợ</p>
            <p className="font-bold text-sm">{formatCurrency(dashboardStats.totalDebt)}</p>
          </div>
        </div>
      </div>

      {(showSearchBox || customerSearch || showFilterPanel) && (
        <div className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 space-y-3">
          {(showSearchBox || customerSearch) && (
            <div className="bg-gray-50 border border-gray-100 rounded-2xl px-3 py-2 flex items-center gap-2">
              <Search size={16} className="text-gray-400 shrink-0" />
              <input
                type="text"
                value={customerSearch}
                onChange={(e) => setCustomerSearch(e.target.value)}
                placeholder="Tìm theo tên, SĐT, nhóm KH, NVKD..."
                className="flex-1 bg-transparent text-sm outline-none"
              />
              {customerSearch && (
                <button type="button" onClick={() => setCustomerSearch('')} className="text-gray-400 hover:text-gray-600">
                  <X size={16} />
                </button>
              )}
            </div>
          )}
          {showFilterPanel && (
            <div className="space-y-3">
              <div className="grid grid-cols-3 gap-2">
                <button type="button" onClick={() => setCustomerStatusFilter('all')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${customerStatusFilter === 'all' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Tất cả</button>
                <button type="button" onClick={() => setCustomerStatusFilter('debt')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${customerStatusFilter === 'debt' ? 'border-rose-200 bg-rose-50 text-rose-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Còn nợ</button>
                <button type="button" onClick={() => setCustomerStatusFilter('credit')} className={`rounded-xl border px-3 py-3 text-xs font-bold transition-colors ${customerStatusFilter === 'credit' ? 'border-blue-200 bg-blue-50 text-blue-700' : 'border-gray-200 bg-white text-gray-600 hover:bg-gray-50'}`}>Dư tiền</button>
              </div>
              <div>
                <label className="block text-[11px] font-bold uppercase tracking-[0.14em] text-gray-500 mb-2">Lọc theo NVKD</label>
                <select value={customerManagerFilter} onChange={e => setCustomerManagerFilter(e.target.value)} className="w-full border border-gray-200 rounded-xl p-3 text-sm bg-white outline-none">
                  {customerManagerOptions.map(option => <option key={option.value} value={option.value}>{option.label}</option>)}
                </select>
              </div>
              <div className="flex items-center justify-between gap-3">
                <p className="text-[11px] text-gray-500">Đang hiển thị {filteredCustomers.length}/{customerSummaries.length} khách hàng.</p>
                <button type="button" onClick={handleResetCustomerFilters} className="text-blue-600 font-bold hover:text-blue-700">Đặt lại</button>
              </div>
            </div>
          )}
        </div>
      )}

      <div className="space-y-3">
        {filteredCustomers.length === 0 && (
          <div className="bg-white rounded-xl shadow-sm border border-gray-50 p-6 text-center text-sm text-gray-400">
            Không tìm thấy khách hàng phù hợp.
          </div>
        )}

        {filteredCustomers.map(cus => {
          const initials = (cus.name || '').split(' ').map(part => part[0]).join('').substring(0, 2).toUpperCase();
          return (
            <div key={cus.id} onClick={() => handleOpenCustomer(cus.id)} className="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 cursor-pointer hover:bg-gray-50 transition">
              <div className="flex items-start gap-3">
                <div className="w-11 h-11 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center font-bold text-sm shrink-0">
                  {initials}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="flex items-start justify-between gap-3">
                    <div>
                      <h3 className="font-bold text-gray-800 text-sm">{cus.name}</h3>
                      <p className="text-xs text-gray-500 mt-1">{cus.phone || cus.address || 'Chưa có thông tin liên hệ'}</p>
                    </div>
                    <ChevronRight size={16} className="text-gray-300 shrink-0 mt-1" />
                  </div>

                  <div className="flex flex-wrap gap-2 mt-2">
                    {cus.customerGroup && <span className="text-[11px] bg-emerald-50 text-emerald-700 px-2 py-1 rounded-full font-medium">Nhóm: {cus.customerGroup}</span>}
                    <span className="text-[11px] bg-gray-100 text-gray-600 px-2 py-1 rounded-full font-medium">NVKD: {cus.managerName}</span>
                  </div>

                  <div className="grid grid-cols-3 gap-2 mt-3">
                    <div className="bg-gray-50 rounded-xl p-2.5">
                      <p className="text-[10px] uppercase text-gray-500 font-bold mb-1">Doanh thu</p>
                      <p className="font-bold text-emerald-600 text-xs">{formatCurrency(cus.totalRevenue)}</p>
                    </div>
                    <div className="bg-gray-50 rounded-xl p-2.5">
                      <p className="text-[10px] uppercase text-gray-500 font-bold mb-1">Đơn hàng</p>
                      <p className="font-bold text-gray-800 text-xs">{cus.orderCount}</p>
                    </div>
                    <div className={`rounded-xl p-2.5 ${cus.currentDebt > 0 ? 'bg-red-50' : 'bg-emerald-50'}`}>
                      <p className={`text-[10px] uppercase font-bold mb-1 ${cus.currentDebt > 0 ? 'text-red-500' : 'text-emerald-500'}`}>Công nợ</p>
                      <p className={`font-bold text-xs ${cus.currentDebt > 0 ? 'text-red-600' : 'text-emerald-600'}`}>{formatCurrency(cus.currentDebt)}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div className="fixed bottom-[70px] right-4 pointer-events-none flex justify-end">
        <button onClick={() => setShowAddCustomer(true)} className="pointer-events-auto bg-blue-600 text-white rounded-full px-5 py-3 font-bold shadow-lg flex items-center gap-2 hover:bg-blue-700">
          <Plus size={18}/> Tạo khách hàng
        </button>
      </div>

      {showAddCustomer && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl p-5 w-full max-w-sm animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">Thêm Khách Hàng</h3>
            <form onSubmit={handleAddCustomerSubmit} className="space-y-4">
              <input required type="text" value={newCus.name} onChange={e=>setNewCus({...newCus, name: toTitleCase(e.target.value)})} className="w-full border p-3 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 text-sm" placeholder="Tên khách hàng/Công ty" />
              <input required type="tel" value={newCus.phone} onChange={e=>setNewCus({...newCus, phone: e.target.value})} className="w-full border p-3 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 text-sm" placeholder="Số điện thoại" />
              <input type="text" value={newCus.address} onChange={e=>setNewCus({...newCus, address: toTitleCase(e.target.value)})} className="w-full border p-3 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 text-sm" placeholder="Địa chỉ giao hàng" />
              <div>
                <label className="block text-xs font-bold text-gray-500 mb-1">Nhóm KH</label>
                <input type="text" value={newCus.customerGroup} onChange={e=>setNewCus({...newCus, customerGroup: toTitleCase(e.target.value)})} className="w-full border p-3 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 text-sm" placeholder="Ví dụ: Đại lý, VIP, Tạp hóa" />
              </div>
              {!isSales && (
                <div>
                  <label className="block text-xs font-bold text-gray-500 mb-1">Nhân viên phụ trách</label>
                  <select required value={newCus.empId} onChange={e=>setNewCus({...newCus, empId: e.target.value})} className="w-full border p-3 rounded-xl outline-none bg-white text-sm">
                    <option value="">-- Chọn Sales phụ trách --</option>
                    {salesEmployees.map(e => <option key={e.id} value={e.id}>{e.name}</option>)}
                  </select>
                </div>
              )}
              <button type="submit" className="w-full bg-emerald-500 text-white py-3 rounded-xl font-bold mt-2">Lưu Khách Hàng</button>
              <button type="button" onClick={()=>setShowAddCustomer(false)} className="w-full bg-gray-100 text-gray-600 py-3 rounded-xl font-bold">Hủy</button>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}

const createEmployeeFormState = (position = 'Kế toán & nhân sự', overrides = {}) => {
  const shiftDefaults = getPositionShiftDefaults(position);
  return {
    name: '',
    phone: '',
    position,
    startDate: getTodayString(),
    probationDuration: '0',
    probationUnit: 'days',
    probationRate: '100',
    basicSalary: '',
    salaryMonthDays: `${BASE_SALARY_MONTH_DAYS}`,
    supportSalary: '',
    responsibilitySalary: '',
    experienceSalary: '',
    experienceSalaryPeriod: 'months',
    commissionRate: '',
    targetRevenue: '',
    overtimeRate: '',
    latePenaltyRate: '',
    shiftName: shiftDefaults.shiftName,
    shiftStart: shiftDefaults.shiftStart,
    shiftEnd: shiftDefaults.shiftEnd,
    graceMinutes: shiftDefaults.graceMinutes,
    missingAlertMinutes: shiftDefaults.missingAlertMinutes,
    ...overrides
  };
};

function EmployeeView({ employees, onAddEmployee, onEditEmployee, isSuperAdmin }) {
  const [showForm, setShowForm] = useState(false);
  const [editingEmp, setEditingEmp] = useState(null);
  const [empData, setEmpData] = useState(createEmployeeFormState());
  const isEditingOwner = Boolean(editingEmp) && (editingEmp.role === 'super_admin' || isOwnerPosition(editingEmp.position));

  if (!isSuperAdmin) {
    return <div className="p-4 text-center text-sm text-gray-500">Chỉ chủ doanh nghiệp mới được tạo và quản lý tài khoản bộ phận.</div>;
  }

  const handlePositionChange = (position) => {
    const shiftDefaults = getPositionShiftDefaults(position);
    setEmpData(prev => ({
      ...prev,
      position,
      shiftName: shiftDefaults.shiftName,
      shiftStart: shiftDefaults.shiftStart,
      shiftEnd: shiftDefaults.shiftEnd,
      graceMinutes: shiftDefaults.graceMinutes,
      missingAlertMinutes: shiftDefaults.missingAlertMinutes
    }));
  };

  const handleOpenEdit = (emp) => {
    setEditingEmp(emp);
    const shiftPolicy = resolveEmployeeShiftPolicy(emp);
    setEmpData({ 
      name: emp.name, phone: emp.phone, position: getEmployeePositionLabel(emp.position), 
      startDate: emp.startDate || getTodayString(), 
      probationDuration: emp.probationDuration || 0,
      probationUnit: emp.probationUnit || 'days',
      probationRate: emp.probationRate !== undefined ? emp.probationRate : 100,
      basicSalary: emp.basicSalary,
      salaryMonthDays: emp.salaryMonthDays || BASE_SALARY_MONTH_DAYS,
      supportSalary: emp.supportSalary || 0, responsibilitySalary: emp.responsibilitySalary || 0, experienceSalary: emp.experienceSalary || 0, experienceSalaryPeriod: emp.experienceSalaryPeriod || 'months', commissionRate: emp.commissionRate || 0, targetRevenue: emp.targetRevenue || 0, overtimeRate: emp.overtimeRate || 0, latePenaltyRate: emp.latePenaltyRate || 0,
      shiftName: shiftPolicy.shiftName,
      shiftStart: shiftPolicy.shiftStart,
      shiftEnd: shiftPolicy.shiftEnd,
      graceMinutes: shiftPolicy.graceMinutes,
      missingAlertMinutes: shiftPolicy.missingAlertMinutes
    });
    setShowForm(true);
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const normalizedPosition = normalizeEmployeePosition(empData.position);
    const pData = { 
      ...empData,
      position: normalizedPosition,
      probationDuration: parseInt(empData.probationDuration)||0,
      probationRate: parseInt(empData.probationRate)||100,
      basicSalary: parseInt(empData.basicSalary)||0, 
      salaryMonthDays: parseInt(empData.salaryMonthDays)||BASE_SALARY_MONTH_DAYS,
      supportSalary: parseInt(empData.supportSalary)||0, 
      responsibilitySalary: parseInt(empData.responsibilitySalary)||0,
      experienceSalary: parseInt(empData.experienceSalary)||0, 
      commissionRate: parseFloat(empData.commissionRate)||0, 
      targetRevenue: parseInt(empData.targetRevenue)||0, 
      overtimeRate: parseInt(empData.overtimeRate)||0,
      latePenaltyRate: parseInt(empData.latePenaltyRate)||0,
      graceMinutes: parseMinutesInput(empData.graceMinutes, getPositionShiftDefaults(empData.position).graceMinutes),
      missingAlertMinutes: parseMinutesInput(empData.missingAlertMinutes, getPositionShiftDefaults(empData.position).missingAlertMinutes)
    };
    if (editingEmp) onEditEmployee(editingEmp.id, pData); else onAddEmployee(pData);
    setShowForm(false);
  };

  return (
    <div className="space-y-4 animate-in fade-in pb-16">
      <div className="flex justify-between items-center mb-2">
        <h2 className="text-lg font-bold text-gray-800">Tài khoản bộ phận</h2>
        <button onClick={() => { setEditingEmp(null); setEmpData(createEmployeeFormState()); setShowForm(true); }} className="bg-blue-600 text-white p-2 rounded-full shadow-sm hover:bg-blue-700"><Plus size={20} /></button>
      </div>
      <div className="bg-blue-50 border border-blue-100 rounded-2xl p-4 text-sm text-blue-900">
        <p className="font-bold uppercase text-[11px] tracking-[0.16em] text-blue-700 mb-2">Mô hình tài khoản</p>
        <p className="leading-relaxed">Mỗi công ty có một tài khoản <strong>Chủ doanh nghiệp</strong> được tạo khi đăng ký. Từ đây, chủ doanh nghiệp tạo thêm tài khoản cho 4 bộ phận mặc định: <strong>Kế toán & nhân sự</strong>, <strong>Tài xế</strong>, <strong>Sản xuất</strong>, <strong>Kinh doanh</strong>.</p>
      </div>
      <div className="space-y-3">
        {employees.map(emp => (
          <div key={emp.id} className="bg-white p-4 rounded-xl shadow-sm border border-gray-50 flex items-center justify-between">
            <div className="flex items-center space-x-3">
              <div className="w-12 h-12 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-600"><UserCircle size={28} /></div>
              <div>
                <h3 className="font-semibold text-gray-800">{emp.name}</h3>
                <span className={`text-[10px] font-medium px-2 py-0.5 rounded-full inline-block mt-1 ${isOwnerPosition(emp.position) || emp.role === 'super_admin' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600'}`}>{getEmployeePositionLabel(emp.position)}</span>
                <div className="text-[10px] text-gray-500 mt-1">LCB: <strong className="text-gray-700">{formatCurrency(emp.basicSalary)}</strong> đ</div>
                <div className="text-[10px] text-gray-500 mt-1">{resolveEmployeeShiftPolicy(emp).shiftName}: {resolveEmployeeShiftPolicy(emp).shiftStart} - {resolveEmployeeShiftPolicy(emp).shiftEnd}</div>
              </div>
            </div>
            <button onClick={() => handleOpenEdit(emp)} className="text-emerald-500 hover:bg-emerald-50 p-2 rounded-lg border border-emerald-100"><Edit3 size={18} /></button>
          </div>
        ))}
      </div>

      {showForm && (
        <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 overflow-y-auto">
          <div className="bg-white rounded-2xl p-5 w-full max-w-md my-auto animate-in zoom-in-95">
            <h3 className="font-bold text-lg mb-4">{editingEmp ? 'Sửa tài khoản' : 'Tạo tài khoản bộ phận'}</h3>
            <form onSubmit={handleSubmit} className="space-y-3 max-h-[70vh] overflow-y-auto pr-2">
              <input required type="text" placeholder={isEditingOwner ? 'Tên chủ doanh nghiệp' : 'Tên nhân sự / tài khoản bộ phận'} value={empData.name} onChange={e=>setEmpData({...empData, name: toTitleCase(e.target.value)})} className="w-full border p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-emerald-500"/>
              <div className="grid grid-cols-2 gap-3">
                <input required type="tel" placeholder="SĐT (Đăng nhập)" value={empData.phone} onChange={e=>setEmpData({...empData, phone: e.target.value})} className="w-full border p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-emerald-500"/>
                {isEditingOwner ? (
                  <div className="w-full border border-amber-200 bg-amber-50 px-3 py-3 rounded-xl text-sm font-bold text-amber-700 flex items-center">Chủ doanh nghiệp</div>
                ) : (
                  <select value={empData.position} onChange={e=>handlePositionChange(e.target.value)} className="w-full border p-3 rounded-xl text-sm bg-white outline-none focus:ring-2 focus:ring-emerald-500">
                    {DEPARTMENT_ACCOUNT_OPTIONS.map(option => <option key={option} value={option}>{option}</option>)}
                  </select>
                )}
              </div>
              <p className="text-[11px] text-gray-500 leading-relaxed">{isEditingOwner ? 'Tài khoản chủ doanh nghiệp là tài khoản gốc của công ty và không tạo thêm từ màn này.' : 'Bộ phận được chọn sẽ quyết định quyền truy cập và màn hình mặc định của tài khoản này.'}</p>
              
              <div className="bg-blue-50 p-3 rounded-xl border border-blue-100">
                <label className="block text-[10px] font-bold text-blue-700 uppercase mb-1">Ng?y b?t ??u v?o l?m (T?nh th?m ni?n)</label>
                <input required type="date" value={empData.startDate} onChange={e=>setEmpData({...empData, startDate: e.target.value})} className="w-full border border-blue-200 p-2.5 rounded-lg text-sm bg-white outline-none focus:ring-2 focus:ring-blue-500"/>
                <p className="text-[10px] text-blue-600 mt-1.5 font-medium">H? th?ng d?ng ng?y n?y ?? t?nh s? chu k? th?m ni?n ?? ho?n th?nh theo th?ng, qu? ho?c n?m.</p>
              </div>

              <div className="bg-amber-50 p-3 rounded-xl border border-amber-100 space-y-3">
                <div>
                  <h4 className="text-xs font-bold text-amber-800 border-b border-amber-200 pb-1">Ca l?m vi?c & C?nh b?o ch?m c?ng</h4>
                  <p className="text-[10px] text-amber-700 mt-1.5 leading-relaxed">App d?ng khung ca n?y ?? ph?t hi?n qu?n ch?m v?o, qu?n ch?m ra v? g?i c?nh b?o cho nh?n vi?n c?ng k? to?n nh?n s?. Vi?c qu?n ch?m ra kh?ng t? ??ng ???c hi?u l? t?ng ca.</p>
                </div>
                <div>
                  <label className="block text-[10px] font-bold text-amber-700 uppercase mb-1">T?n ca</label>
                  <input type="text" value={empData.shiftName} onChange={e=>setEmpData({...empData, shiftName: capitalizeFirst(e.target.value)})} className="w-full border border-amber-200 p-2.5 rounded-lg text-sm bg-white outline-none focus:ring-2 focus:ring-amber-500" placeholder="V? d?: Ca s?n xu?t s?m" />
                </div>
                <div className="grid grid-cols-2 gap-2">
                  <div>
                    <label className="block text-[10px] font-bold text-amber-700 uppercase mb-1">Gi? v?o chu?n</label>
