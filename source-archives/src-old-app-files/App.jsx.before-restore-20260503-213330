              <input type="text" value={newExpense.note} onChange={e=>setNewExpense({...newExpense, note: capitalizeFirstPreservingSpacing(e.target.value)})} placeholder="Nội dung chi (không bắt buộc)" className="w-full border p-2.5 rounded-xl text-sm" />
