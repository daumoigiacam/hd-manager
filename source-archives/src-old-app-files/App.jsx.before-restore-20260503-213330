              <input type="text" value={newPayment.note} onChange={e=>setNewPayment({...newPayment, note: capitalizeFirst(e.target.value)})} placeholder={newPayment.sourceType === 'customer_transfer' ? 'Nội dung chuyển khoản / mã hóa đơn' : 'Ghi chú (không bắt buộc)'} className="w-full border p-2.5 rounded-xl text-sm" />
              {newPayment.sourceType === 'customer_transfer' && (
                <p className="text-[11px] text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-xl px-3 py-2">
                  Nếu khách chuyển khoản đúng nội dung như <span className="font-bold">TT HD000001</span>, app sẽ tự tìm hóa đơn và trừ nợ tương ứng.
