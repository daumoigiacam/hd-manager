function WarehouseDispatchView({ employee, currentCompany, customers, products, orderRequests, warehouseDispatches, onAddWarehouseDispatch, onEditWarehouseDispatch, onDeleteWarehouseDispatch }) {
  const isOwner = isOwnerPosition(employee?.position);
  const isOwnerAccount = isOwner || employee?.role === 'super_admin';
  const isAccounting = isAccountingPosition(employee?.position);
  const isWarehouseScale = isWarehouseScalePosition(employee?.position);
  const canCreate = isOwnerAccount || isAccounting || isWarehouseScale;
  const canAccess = Boolean(employee);
  const workingDate = getTodayString();
  const [dispatchDraft, setDispatchDraft] = useState({ customerId: '', customerSearch: '', productId: '', productSearch: '', weightKg: '', note: '', transcript: '' });
  const [dispatchStatus, setDispatchStatus] = useState('');
  const [dispatchError, setDispatchError] = useState('');
  const [isDispatchExporting, setIsDispatchExporting] = useState(false);
  const [isVoiceListening, setIsVoiceListening] = useState(false);
  const [isVoiceProcessing, setIsVoiceProcessing] = useState(false);
  const [voiceStatus, setVoiceStatus] = useState('');
  const [dispatchPickerOpen, setDispatchPickerOpen] = useState('');
  const [inlineEditingDispatchId, setInlineEditingDispatchId] = useState('');
  const [inlineEditingDispatchDraft, setInlineEditingDispatchDraft] = useState({ customerId: '', customerSearch: '', productId: '', productSearch: '', weightKg: '', note: '' });
  const recognitionRef = useRef(null);
  const mediaRecorderRef = useRef(null);
  const mediaStreamRef = useRef(null);
  const voiceChunksRef = useRef([]);

  const resolveRequestDateKey = (request = {}) => {
    const rawDate = `${request?.date || ''}`.trim();
    if (rawDate && parseDateInputValue(rawDate)) return rawDate;
    const stamp = getEntityTimestamp(request);
    if (!stamp) return workingDate;
    const parsed = new Date(stamp);
    return `${parsed.getFullYear()}-${String(parsed.getMonth() + 1).padStart(2, '0')}-${String(parsed.getDate()).padStart(2, '0')}`;
  };

  const todayOrderRequests = useMemo(
    () => (orderRequests || []).filter(request => !request.isArchived && resolveRequestDateKey(request) === workingDate),
    [orderRequests, workingDate]
  );

  const requestCustomerOptions = useMemo(() => {
    const uniqueIds = [...new Set(todayOrderRequests.map(request => request.customerId).filter(Boolean))];
    const mapped = uniqueIds
      .map(customerId => customers.find(customer => customer.id === customerId))
      .filter(Boolean);
    return mapped.length > 0 ? mapped : customers.filter(customer => !customer.isArchived);
  }, [todayOrderRequests, customers]);

  const requestProductOptions = useMemo(() => {
    const collected = [];
    todayOrderRequests.forEach(request => {
      const requestItems = (request.items || []).length > 0 ? request.items : (request.primaryItem ? [request.primaryItem] : []);
      requestItems.forEach(item => {
        const matchedProduct = products.find(product => product.id === item.productId);
        if (matchedProduct) collected.push(matchedProduct);
      });
    });
    const deduped = Array.from(new Map(collected.map(product => [product.id, product])).values());
