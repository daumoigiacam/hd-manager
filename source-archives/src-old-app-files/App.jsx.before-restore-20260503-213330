    setShowExpenseModal(false);
    setNewExpense({ category: 'Chi mua hĂ ng hĂ³a', customCategory: '', amount: '', note: '', date: getTodayString() });
  };

  const paymentSourceOptions = [
    { value: 'driver_cash', label: 'TĂ i xáº¿ ná»™p tiá»n máº·t', note: 'TĂ i xáº¿ ná»™p tiá»n máº·t' },
    { value: 'customer_transfer', label: 'KhĂ¡ch chuyá»ƒn khoáº£n', note: 'KhĂ¡ch chuyá»ƒn khoáº£n' },
    { value: 'accounting_recovery', label: 'Káº¿ toĂ¡n thu há»“i cĂ´ng ná»£', note: 'Káº¿ toĂ¡n thu há»“i cĂ´ng ná»£' }
  ];

  const handlePaymentSubmit = (e) => {
    e.preventDefault();
    const canInferCustomerByNote = newPayment.sourceType === 'customer_transfer' && normalizeTransferMemoToken(newPayment.note).length >= 6;
    if ((!newPayment.customerId && !canInferCustomerByNote) || !newPayment.amount) return;

    const selectedSource = paymentSourceOptions.find(option => option.value === newPayment.sourceType);

    onAddPayment({
      customerId: newPayment.customerId,
      amount: parseInputCurrency(newPayment.amount),
      note: capitalizeFirst(newPayment.note || selectedSource?.note || 'Thu cĂ´ng ná»£'),
      bankContent: capitalizeFirst(newPayment.note || selectedSource?.note || 'Thu cï¿½â¬ï¿½ï¿½ï¿½Âï¿½â¬Â´ng nâ¬Â¡ï¿½â¬Â»ï¿½â¬Â£'),
      date: newPayment.date,
      method: newPayment.method,
      sourceType: newPayment.sourceType,
      sourceLabel: selectedSource?.label || 'Thu cĂ´ng ná»£'
