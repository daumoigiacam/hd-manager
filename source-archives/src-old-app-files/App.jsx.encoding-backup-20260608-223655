    const columnWidths = [
      Math.round(tableWidth * 0.32),
      Math.round(tableWidth * 0.30),
      Math.round(tableWidth * 0.18),
      tableWidth - Math.round(tableWidth * 0.32) - Math.round(tableWidth * 0.30) - Math.round(tableWidth * 0.18)
