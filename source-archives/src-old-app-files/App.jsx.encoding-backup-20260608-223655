  const remainingAmount = Math.max(0, limitAmount - currentDebt);
  const isNoDebt = config.mode === 'no_debt';

  return {
    mode: config.mode,
    enabled: true,
    limitAmount,
    currentDebt,
    exceeded,
    overAmount,
    remainingAmount,
    isNoDebt,
    label: isNoDebt ? 'KhĂ´ng cho ná»£' : `Cho ná»£ tá»‘i Ä‘a ${formatCurrency(limitAmount)} Ä‘`,
    shortLabel: isNoDebt ? 'KhĂ´ng ná»£' : `HM ${formatCurrency(limitAmount)} Ä‘`,
    message: exceeded
