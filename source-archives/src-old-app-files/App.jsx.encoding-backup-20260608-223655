const getAssetInspectionWarning = (asset = {}) => {
  if (!asset.inspectionExpiry) return null;
  const expiry = new Date(asset.inspectionExpiry);
  if (Number.isNaN(expiry.getTime())) return null;
  const today = new Date(getTodayString());
  const diffDays = Math.ceil((expiry.getTime() - today.getTime()) / 86400000);
  if (diffDays < 0) return { level: 'red', days: diffDays, text: `ÄÄƒng kiá»ƒm quĂ¡ háº¡n ${Math.abs(diffDays)} ngĂ y` };
  if (diffDays <= 7) return { level: 'red', days: diffDays, text: `ÄÄƒng kiá»ƒm cĂ²n ${diffDays} ngĂ y` };
  if (diffDays <= 30) return { level: 'yellow', days: diffDays, text: `ÄÄƒng kiá»ƒm cĂ²n ${diffDays} ngĂ y` };
  return { level: 'green', days: diffDays, text: `ÄÄƒng kiá»ƒm cĂ²n ${diffDays} ngĂ y` };
};

const getAssetCostWarnings = (log = {}, asset = {}, previousFuelLogs = []) => {
  const warnings = [];
  const liters = parseLooseQuantityValue(log.liters);
  const kmAt = parseLooseQuantityValue(log.kmAt);
  const tankCapacity = parseLooseQuantityValue(asset.tankCapacity);
  const previous = previousFuelLogs
    .filter(item => item.id !== log.id && parseLooseQuantityValue(item.kmAt) > 0)
    .sort((a, b) => parseLooseQuantityValue(b.kmAt) - parseLooseQuantityValue(a.kmAt))[0];
  const previousKm = parseLooseQuantityValue(previous?.kmAt);
  if (log.type === 'fuel') {
    if (!log.receiptImageUrl) warnings.push({ level: 'yellow', text: 'Thiáº¿u áº£nh hĂ³a Ä‘Æ¡n' });
    if (!log.odometerImageUrl) warnings.push({ level: 'yellow', text: 'Thiáº¿u áº£nh Ä‘á»“ng há»“ km' });
    if (previousKm > 0 && kmAt > 0 && kmAt < previousKm) warnings.push({ level: 'red', text: 'Km nhá» hÆ¡n láº§n trÆ°á»›c' });
    if (tankCapacity > 0 && liters > tankCapacity) warnings.push({ level: 'red', text: 'Sá»‘ lĂ­t vÆ°á»£t dung tĂ­ch bĂ¬nh' });
    if (previousKm > 0 && kmAt === previousKm && liters > 0) warnings.push({ level: 'red', text: 'Xe khĂ´ng cháº¡y nhÆ°ng phĂ¡t sinh nhiĂªn liá»‡u' });
    if (previousKm > 0 && kmAt > previousKm) {
      const deltaKm = kmAt - previousKm;
      const actual = deltaKm > 0 ? (liters / deltaKm) * 100 : 0;
      const norm = parseLooseQuantityValue(asset.fuelNorm);
      if (norm > 0 && actual > norm * 1.25) warnings.push({ level: 'red', text: `TiĂªu hao ${actual.toFixed(1)} L/100km vÆ°á»£t Ä‘á»‹nh má»©c` });
    }
  }
  return warnings;
};

const getAssetMetrics = (asset = {}, logs = []) => {
  const assetLogs = logs.filter(log => log.assetId === asset.id && !log.isArchived);
  const fuelLogs = assetLogs.filter(log => log.type === 'fuel');
  const maintenanceLogs = assetLogs.filter(log => ['maintenance', 'repair', 'oil', 'tire'].includes(log.costType || log.type));
  const latestKm = Math.max(parseLooseQuantityValue(asset.currentKm), parseLooseQuantityValue(asset.handoverKm), ...assetLogs.map(log => parseLooseQuantityValue(log.kmAt)));
  const startKm = parseLooseQuantityValue(asset.handoverKm);
  const totalKm = Math.max(0, latestKm - startKm);
  const totalLiters = fuelLogs.reduce((sum, log) => sum + parseLooseQuantityValue(log.liters), 0);
  const fuelCost = fuelLogs.reduce((sum, log) => sum + parseLooseMoneyValue(log.amount), 0);
  const maintenanceCost = maintenanceLogs.reduce((sum, log) => sum + parseLooseMoneyValue(log.amount), 0);
  const totalCost = assetLogs.reduce((sum, log) => sum + parseLooseMoneyValue(log.amount), 0);
  const actualConsumption = totalKm > 0 ? (totalLiters / totalKm) * 100 : 0;
  const norm = parseLooseQuantityValue(asset.fuelNorm);
  const deviation = norm > 0 ? ((actualConsumption - norm) / norm) * 100 : 0;
  const fuelCostPerKm = totalKm > 0 ? fuelCost / totalKm : 0;
  const nextMaintenanceKm = parseLooseQuantityValue(asset.nextMaintenanceKm) || (parseLooseQuantityValue(asset.lastMaintenanceKm) + parseLooseQuantityValue(asset.maintenanceIntervalKm));
  const maintenanceRemainingKm = nextMaintenanceKm > 0 ? nextMaintenanceKm - latestKm : null;
  const fuelWarning = deviation > 25 ? 'red' : deviation > 10 ? 'yellow' : 'green';
  const maintenanceWarning = maintenanceRemainingKm === null ? 'none' : maintenanceRemainingKm < 0 ? 'red' : maintenanceRemainingKm < 500 ? 'orange' : maintenanceRemainingKm < 1000 ? 'yellow' : 'green';
  const fuelWarnings = fuelLogs.flatMap(log => getAssetCostWarnings(log, asset, fuelLogs));
  const inspectionWarning = getAssetInspectionWarning(asset);
  let driverScore = 100;
  if (fuelWarning === 'red') driverScore -= 15;
  if (fuelWarning === 'yellow') driverScore -= 5;
  if (maintenanceWarning === 'red') driverScore -= 10;
  if (maintenanceWarning === 'orange') driverScore -= 5;
  if (inspectionWarning?.level === 'red') driverScore -= 10;
  if (inspectionWarning?.level === 'yellow') driverScore -= 5;
  driverScore -= fuelWarnings.filter(warning => warning.level === 'red').length * 8;
  driverScore -= fuelWarnings.filter(warning => warning.level === 'yellow').length * 2;
  return {
    totalKm,
    totalLiters,
    fuelCost,
    maintenanceCost,
    totalCost,
    actualConsumption,
    deviation,
    fuelCostPerKm,
    latestKm,
    nextMaintenanceKm,
    maintenanceRemainingKm,
    fuelWarning,
    maintenanceWarning,
    inspectionWarning,
    warnings: inspectionWarning ? [inspectionWarning, ...fuelWarnings] : fuelWarnings,
    driverScore: Math.max(0, Math.round(driverScore))
  };
};

