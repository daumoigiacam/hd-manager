function ZaloDispatcherRuntime({
  currentCompany,
  customers = [],
  orders = [],
  zaloSendQueue = [],
  zaloCampaigns = [],
  zaloCampaignQueue = [],
  onUpdateCompanySettings = async () => ({ success: false })
}) {
  const [machineInfo, setMachineInfo] = useState(null);
  const processingRef = useRef(false);
  const sentTimestampsRef = useRef([]);
  const bridge = typeof window !== 'undefined' ? window.hdDesktop : null;
  const dispatcherAvailable = Boolean(bridge?.isDesktop && bridge?.sendZaloMessage && bridge?.getMachineId);
  const dispatcherEnabled = dispatcherAvailable && currentCompany?.id
    ? currentCompany?.zaloDispatcherDisabled !== true
    : Boolean(currentCompany?.zaloDispatcherEnabled);
  const rawSendInvoicesEnabled = currentCompany?.zaloDispatcherSendInvoicesEnabled !== false;
  const rawSendCampaignsEnabled = currentCompany?.zaloDispatcherSendCampaignsEnabled !== false;
  const shouldHealDisabledSources = dispatcherEnabled && !rawSendInvoicesEnabled && !rawSendCampaignsEnabled;
  const sendInvoicesEnabled = shouldHealDisabledSources ? true : rawSendInvoicesEnabled;
  const sendCampaignsEnabled = shouldHealDisabledSources ? true : rawSendCampaignsEnabled;
  const dispatcherPaused = Boolean(currentCompany?.zaloDispatcherPaused);
  const machineId = machineInfo?.machineId || '';
  const machineName = machineInfo?.machineName || machineInfo?.hostname || machineId || '';
  const activeMachineId = currentCompany?.zaloDispatcherMachineId || '';
  const heartbeatAt = currentCompany?.zaloDispatcherHeartbeatAt || '';
  const heartbeatAgeMs = heartbeatAt ? Date.now() - (Date.parse(heartbeatAt) || 0) : Number.POSITIVE_INFINITY;
  const isThisMachineActive = Boolean(dispatcherEnabled && machineId && activeMachineId === machineId);
  const companyId = currentCompany?.id || '';
  const schedulerSettings = useMemo(() => getZaloSchedulerSettings(currentCompany), [currentCompany]);
  const orderById = useMemo(() => new Map((orders || []).map(order => [order.id, order])), [orders]);
  const customerById = useMemo(() => new Map((customers || []).map(customer => [customer.id, customer])), [customers]);
  const campaignById = useMemo(() => new Map((zaloCampaigns || []).map(campaign => [campaign.id || campaign.campaignId, campaign])), [zaloCampaigns]);
  const maxPerHourLimit = Math.max(1, parseInt(currentCompany?.zaloDispatcherMaxPerHour ?? 240, 10) || 240);

  const resolveQueueCustomerId = (item = {}) => {
    const order = item.orderId ? orderById.get(item.orderId) : null;
    return `${order?.customerId || item.customerId || ''}`.trim();
  };

  const hasResolvedQueueCustomer = (item = {}) => {
    const customerId = resolveQueueCustomerId(item);
    return !customerId || customerById.has(customerId);
  };

  const resolveQueueZaloGroupLink = (item = {}) => {
    const customerId = resolveQueueCustomerId(item);
    const customer = customerId ? customerById.get(customerId) : null;
    if (customerId && customerById.has(customerId)) {
      return `${customer?.zaloGroupLink || ''}`.trim();
    }
    return `${item.zaloGroupLink || ''}`.trim();
  };

  const normalizeDelayConfig = () => {
    const min = Math.max(1, parseInt(currentCompany?.zaloDispatcherDelayMinSec ?? DEFAULT_ZALO_DISPATCHER_DELAY_MIN_SEC, 10) || DEFAULT_ZALO_DISPATCHER_DELAY_MIN_SEC);
    const max = Math.max(min, parseInt(currentCompany?.zaloDispatcherDelayMaxSec ?? DEFAULT_ZALO_DISPATCHER_DELAY_MAX_SEC, 10) || DEFAULT_ZALO_DISPATCHER_DELAY_MAX_SEC);
    return { min, max };
  };

  const pruneSentWindow = () => {
    const cutoff = Date.now() - 3600000;
    sentTimestampsRef.current = sentTimestampsRef.current.filter(timestamp => timestamp >= cutoff);
    return sentTimestampsRef.current.length;
  };

  const registerRuntimeSent = () => {
    sentTimestampsRef.current = [...sentTimestampsRef.current, Date.now()];
    pruneSentWindow();
  };

  const getQueueDocRef = (item) => doc(db, 'artifacts', appId, 'public', 'data', 'zalo_send_queue', item.orderId || item.id);
  const getCampaignQueueDocRef = (item) => doc(db, 'artifacts', appId, 'public', 'data', 'zalo_campaign_queue', item.id || `${item.campaignId}_${item.customerId}`);
  const getCampaignDocRef = (campaignId) => doc(db, 'artifacts', appId, 'public', 'data', 'zalo_campaigns', campaignId);

  const getInvoiceReadiness = (item) => {
    if (!item || item.isArchived) return { ready: false, reason: 'Ban ghi khong hop le' };
    if (item.status !== 'pending') return { ready: false, reason: 'Khong o trang thai cho gui' };
    if (!hasResolvedQueueCustomer(item)) return { ready: false, reason: 'Cho nap ho so khach de xac nhan link Zalo' };
    if (!resolveQueueZaloGroupLink(item)) return { ready: false, reason: 'Thieu link nhom Zalo' };
    if (!`${item.messageText || item.message || ''}`.trim()) return { ready: false, reason: 'Thieu noi dung tin nhan' };

    const currentOrder = orderById.get(item.orderId) || null;
    const orderReviewStatus = `${currentOrder?.reviewStatus || item.orderStatusAtApproval || ''}`.trim();
    const orderApprovalStatus = `${currentOrder?.zaloApprovalStatus || item.orderStatusAtApproval || ''}`.trim();
    const orderStatus = `${currentOrder?.status || ''}`.trim();
    const blockedStatuses = new Set(['cancelled', 'canceled', 'need_review']);

    if (currentOrder?.isArchived || blockedStatuses.has(orderStatus) || blockedStatuses.has(orderReviewStatus) || blockedStatuses.has(orderApprovalStatus)) {
      return { ready: false, reason: 'Don da huy hoac can kiem tra lai' };
    }

    const isConfirmedOrder = orderApprovalStatus === 'confirmed'
      || orderReviewStatus === 'confirmed'
      || orderReviewStatus === 'approved_for_zalo'
      || item.orderStatusAtApproval === 'confirmed';
    if (!isConfirmedOrder) return { ready: false, reason: 'Don chua confirmed' };

    const isImmediateSend = isZaloImmediateSendQueueItem(item);
    const editHoldMinutes = Math.max(0, parseInt(item.scheduledAfterEditHoldMinutes ?? schedulerSettings.editHoldMinutes, 10) || 0);
    const editedAt = currentOrder?.zaloContentEditedAt || item.sourceOrderUpdatedAt || '';
    if (!isImmediateSend && editHoldMinutes > 0 && editedAt) {
      const editedMs = Date.parse(editedAt);
      if (Number.isFinite(editedMs) && Date.now() - editedMs < editHoldMinutes * 60000) {
        return { ready: false, reason: `Don vua sua, cho ${editHoldMinutes} phut` };
      }
    }

    const scheduleMode = item.scheduleMode || (isImmediateSend ? 'immediate' : schedulerSettings.mode);
    if (!isImmediateSend && scheduleMode === 'route_closed' && !item.routeClosedAt) {
      return { ready: false, reason: 'Cho tai xe chot tuyen' };
    }

    const scheduledAt = item.scheduledAt || '';
    if (!isImmediateSend && scheduledAt) {
      const scheduledMs = Date.parse(scheduledAt);
      if (Number.isFinite(scheduledMs) && scheduledMs > Date.now()) {
        return { ready: false, reason: `Cho lich ${formatDateTimeLabel(scheduledAt)}` };
      }
    }

    return { ready: true, reason: 'San sang gui' };
  };

  const getCampaignReadiness = (item) => {
    if (!item || item.isArchived) return { ready: false, reason: 'Ban ghi khong hop le' };
    if (item.status !== 'pending') return { ready: false, reason: 'Khong o trang thai cho gui' };
    if (!item.campaignId || !item.customerId) return { ready: false, reason: 'Thieu campaignId hoac customerId' };
    if (!hasResolvedQueueCustomer(item)) return { ready: false, reason: 'Cho nap ho so khach de xac nhan link Zalo' };
    if (!resolveQueueZaloGroupLink(item)) return { ready: false, reason: 'Thieu link nhom Zalo' };
    if (!`${item.messageText || item.message || ''}`.trim()) return { ready: false, reason: 'Thieu noi dung tin nhan' };
    const campaign = campaignById.get(item.campaignId) || {};
    if (['cancelled', 'sent'].includes(campaign.status)) return { ready: false, reason: 'Chien dich da ket thuc' };
    const scheduledAt = item.scheduledAt || campaign.scheduledAt || '';
    if (scheduledAt) {
      const scheduledMs = Date.parse(scheduledAt);
      if (Number.isFinite(scheduledMs) && scheduledMs > Date.now()) {
        return { ready: false, reason: `Cho lich ${formatDateTimeLabel(scheduledAt)}` };
      }
    }
    return { ready: true, reason: 'San sang gui' };
  };

  const readyInvoiceQueueCount = (zaloSendQueue || []).filter(item => getInvoiceReadiness(item).ready).length;
  const readyCampaignQueueCount = (zaloCampaignQueue || []).filter(item => getCampaignReadiness(item).ready).length;
  const shouldHealInvoiceSource = dispatcherEnabled && !rawSendInvoicesEnabled && readyInvoiceQueueCount > 0;
  const shouldHealCampaignSource = dispatcherEnabled && !rawSendCampaignsEnabled && readyCampaignQueueCount > 0;
  const hasReadyZaloWork = readyInvoiceQueueCount > 0 || readyCampaignQueueCount > 0;
  const canRuntimeClaimDispatcher = Boolean(
    dispatcherAvailable &&
    dispatcherEnabled &&
    machineId &&
    companyId &&
    !dispatcherPaused &&
    (!activeMachineId || activeMachineId === machineId || heartbeatAgeMs > 120000)
  );

  useEffect(() => {
    if (!companyId || (!shouldHealInvoiceSource && !shouldHealCampaignSource)) return;
    const payload = {
      zaloDispatcherPaused: false,
      zaloDispatcherDisabled: false,
      updatedAt: new Date().toISOString()
    };
    if (shouldHealInvoiceSource) payload.zaloDispatcherSendInvoicesEnabled = true;
    if (shouldHealCampaignSource) payload.zaloDispatcherSendCampaignsEnabled = true;
    setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'companies', companyId), payload, { merge: true }).catch(() => {});
  }, [companyId, shouldHealInvoiceSource, shouldHealCampaignSource]);

  const markInvoiceFailed = async (item, message) => {
    const now = new Date().toISOString();
    await setDoc(getQueueDocRef(item), {
      status: 'failed',
      retryCount: (parseInt(item.retryCount, 10) || 0) + 1,
      errorMessage: message || 'Khong gui duoc Zalo.',
      failedAt: now,
      lockedBy: '',
      lockedAt: '',
      lastDispatchLog: {
        type: 'invoice',
        status: 'failed',
        at: now,
        machineId,
        machineName,
        errorMessage: message || 'Khong gui duoc Zalo.'
      }
    }, { merge: true });
    if (item.orderId) {
      await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', item.orderId), {
        zaloSendStatus: 'failed',
        updatedAt: now
      }, { merge: true });
    }
  };

  const markCampaignFailed = async (item, message) => {
    const now = new Date().toISOString();
    await setDoc(getCampaignQueueDocRef(item), {
      status: 'failed',
      retryCount: (parseInt(item.retryCount, 10) || 0) + 1,
      errorMessage: message || 'Khong gui duoc Zalo.',
      failedAt: now,
      lockedBy: '',
      lockedAt: '',
      lastDispatchLog: {
        type: 'campaign',
        status: 'failed',
        at: now,
        machineId,
        machineName,
        errorMessage: message || 'Khong gui duoc Zalo.'
      }
    }, { merge: true });
    if (item.campaignId) {
      await setDoc(getCampaignDocRef(item.campaignId), {
        status: 'failed',
        failedCount: increment(1),
        updatedAt: now
      }, { merge: true });
    }
    if (item.source === 'ai_zalo_reply' && item.sourceMessageId) {
      await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'zalo_inbox_messages', item.sourceMessageId), {
        status: 'need_human',
        processedAt: now,
        errorMessage: message || 'Khong gui duoc Zalo.'
      }, { merge: true });
    }
  };

  const processInvoiceItem = async (queueItem) => {
    const queueRef = getQueueDocRef(queueItem);
    const locked = await runTransaction(db, async (transaction) => {
      const snapshot = await transaction.get(queueRef);
      if (!snapshot.exists()) return null;
      const current = { id: snapshot.id, ...snapshot.data() };
      if (!getInvoiceReadiness(current).ready) return null;
      const now = new Date().toISOString();
      transaction.set(queueRef, {
        status: 'sending',
        lockedBy: machineId,
        lockedAt: now,
        errorMessage: '',
        lastDispatchLog: { type: 'invoice', status: 'sending', at: now, machineId, machineName }
      }, { merge: true });
      return current;
    });
    if (!locked) return false;

    try {
      if (locked.orderId) {
        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', locked.orderId), {
          zaloSendStatus: 'sending',
          updatedAt: new Date().toISOString()
        }, { merge: true });
      }
      const resolvedZaloGroupLink = resolveQueueZaloGroupLink(locked);
      const resolvedCustomerId = resolveQueueCustomerId(locked);
      const resolvedCustomer = resolvedCustomerId ? customerById.get(resolvedCustomerId) : null;
      const messageText = `${locked.messageText || locked.message || ''}`.trim();
      if (!resolvedZaloGroupLink) throw new Error('Thiáº¿u link nhĂ³m Zalo cá»§a khĂ¡ch.');
      if (
        resolvedZaloGroupLink !== `${locked.zaloGroupLink || ''}`.trim()
        || (resolvedCustomerId && resolvedCustomerId !== `${locked.customerId || ''}`.trim())
      ) {
        await setDoc(queueRef, {
          customerId: resolvedCustomerId || locked.customerId || '',
          customerName: resolvedCustomer?.name || locked.customerName || '',
          zaloGroupLink: resolvedZaloGroupLink,
          zaloGroupLinkResolvedAt: new Date().toISOString(),
          zaloGroupLinkSource: 'customer_profile'
        }, { merge: true });
      }
      const desktopResult = await withTimeout(
        bridge.sendZaloMessage({
          zaloGroupLink: resolvedZaloGroupLink,
          messageText,
          qrImageUrl: locked.paymentQrImageUrl || locked.paymentQrUrl || locked.qrCode || locked.paymentQrPayload || locked.checkoutUrl || '',
          openDelayMs: 22000,
          sendTimeoutMs: 18000
        }),
        44000,
        'Zalo PC khĂ´ng pháº£n há»“i sau 44 giĂ¢y. HĂ£y kiá»ƒm tra Zalo PC Ä‘Ă£ má»Ÿ Ä‘Ăºng nhĂ³m vĂ  mĂ¡y khĂ´ng bá»‹ cháº·n focus.'
      );
      const now = new Date().toISOString();
      await setDoc(queueRef, {
        status: 'sent',
        sentAt: now,
        sentBy: machineId,
        errorMessage: '',
        lastDispatchLog: { type: 'invoice', status: 'sent', at: now, machineId, machineName, customerId: resolvedCustomerId || locked.customerId || '', customerName: resolvedCustomer?.name || locked.customerName || '', zaloGroupLink: resolvedZaloGroupLink, desktopResult }
      }, { merge: true });
      if (locked.orderId) {
        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', locked.orderId), {
          zaloSendStatus: 'sent',
          zaloSentAt: now,
          updatedAt: now
        }, { merge: true });
      }
      registerRuntimeSent();
      return true;
    } catch (error) {
      await markInvoiceFailed(locked, error?.message || 'Khong gui duoc Zalo.');
      return false;
    }
  };

  const processCampaignItem = async (queueItem) => {
    const queueRef = getCampaignQueueDocRef(queueItem);
    const locked = await runTransaction(db, async (transaction) => {
      const snapshot = await transaction.get(queueRef);
      if (!snapshot.exists()) return null;
      const current = { id: snapshot.id, ...snapshot.data() };
      if (!getCampaignReadiness(current).ready) return null;
      const now = new Date().toISOString();
      transaction.set(queueRef, {
        status: 'sending',
        lockedBy: machineId,
        lockedAt: now,
        errorMessage: '',
        lastDispatchLog: { type: 'campaign', status: 'sending', at: now, machineId, machineName }
      }, { merge: true });
      if (current.campaignId) {
