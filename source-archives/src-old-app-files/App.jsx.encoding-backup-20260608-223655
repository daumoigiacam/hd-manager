          { index: 2, lines: row.quantityLines, font: quantityFont, color: '#065f46' },
          { index: 3, lines: row.sizeLines, font: '700 22px Arial', color: '#334155' },
          { index: 4, lines: row.priceLines, font: priceFont, color: '#0f172a' }
