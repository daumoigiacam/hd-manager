      ctx.strokeRect(columnX[0], groupTop, nameWidth, groupHeight);
      drawLines(group.nameLines, columnX[0], groupTop, nameWidth, groupHeight, nameFont, '#0f172a');

      group.wrappedRows.forEach((row) => {
        const rowHeight = row.height;
