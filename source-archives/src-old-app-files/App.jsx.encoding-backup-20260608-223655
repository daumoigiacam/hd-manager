};

const buildComparisonSummary = (currentValue, compareValue, { currency = false, suffix = '', referenceLabel = 'ngĂ y trÆ°á»›c' } = {}) => {
  const safeCurrent = currentValue || 0;
  const safeCompare = compareValue || 0;
  const delta = safeCurrent - safeCompare;

  if (delta === 0) return `KhĂ´ng Ä‘á»•i so vá»›i ${referenceLabel}`;

  const absValue = currency ? `${formatCurrency(Math.abs(delta))} Ä‘` : `${formatNumber(Math.abs(delta))}${suffix ? ` ${suffix}` : ''}`;
  return `${delta > 0 ? 'TÄƒng' : 'Giáº£m'} ${absValue} so vá»›i ${referenceLabel}`;
};

const estimateOrderCost = (order, productMap = {}) => (
  (order?.items || []).reduce((sum, item) => {
    const product = productMap[item.productId];
    const unitCost = parseFloat(item.costPrice ?? product?.costPrice ?? 0) || 0;
    const quantity = parseFloat(item.quantity) || 0;
    return sum + (quantity * unitCost);
  }, 0)
);

const getProductInventoryUnit = (product = {}) => `${product?.stockUnit || product?.inventoryUnit || product?.unit || 'ÄÆ¡n vá»‹'}`.trim();
const getProductOpeningStock = (product = {}) => parseLooseQuantityValue(product?.stockQuantity ?? product?.openingStock ?? product?.inventoryQuantity ?? product?.stock ?? 0);
const getProductMainGroupLabel = (product = {}, fallback = '') => {
  const rawLabel = product?.mainGroup
    || product?.groupName
    || product?.productGroup
    || product?.category
    || fallback
    || product?.name
    || 'NhĂ³m hĂ ng';
  const normalized = normalizeLeadingLabel(rawLabel);
  const lookup = normalizeLookupText(normalized);
  if (lookup.includes('vit')) return 'Vá»‹t';
  if (lookup.includes('ga')) return 'GĂ ';
  if (lookup.includes('heo') || lookup.includes('lon')) return 'Heo';
  if (lookup.includes('thung') || lookup.includes('tui') || lookup.includes('bao') || lookup.includes('vat tu')) return 'Váº­t tÆ°';
  return normalized || 'NhĂ³m hĂ ng';
};
const normalizeInventoryUnitKey = (unit = '') => normalizeLookupText(unit || 'don vi');
const isSameInventoryUnit = (left = '', right = '') => normalizeInventoryUnitKey(left) === normalizeInventoryUnitKey(right);
const getOrderItemQuantityUnit = (item = {}, product = null) => `${item?.quantityUnit || item?.unit || product?.unit || ''}`.trim();
const getOrderItemQuantityValue = (item = {}) => parseLooseQuantityValue(item?.quantity ?? item?.quantityValue ?? item?.qty);
const getOrderItemRevenue = (item = {}) => {
  const quantity = getOrderItemQuantityValue(item);
  const unitPrice = parseLooseMoneyValue(item?.unitPrice ?? item?.price ?? item?.unit_price_vnd);
  return quantity * unitPrice;
};
const getOrderItemCost = (item = {}, product = null) => {
  const quantity = getOrderItemQuantityValue(item);
  const unitCost = parseLooseMoneyValue(item?.costPrice ?? product?.costPrice);
  return quantity * unitCost;
};
const buildInventoryMetrics = (products = [], orders = [], { untilDate = '' } = {}) => {
  const productMap = new Map((products || []).map(product => [product.id, product]));
  const soldByProductId = new Map();
  const revenueByProductId = new Map();
  const costByProductId = new Map();

  (orders || [])
    .filter(order => !order?.isArchived)
    .filter(order => !untilDate || `${order.date || ''}` <= untilDate)
    .forEach(order => {
      (order.items || []).forEach(item => {
        const product = productMap.get(item.productId);
        if (!product) return;
        const productId = product.id;
        const stockUnit = getProductInventoryUnit(product);
        const itemUnit = getOrderItemQuantityUnit(item, product);
        const quantity = getOrderItemQuantityValue(item);
        if (quantity > 0 && isSameInventoryUnit(stockUnit, itemUnit)) {
          soldByProductId.set(productId, (soldByProductId.get(productId) || 0) + quantity);
        }
        revenueByProductId.set(productId, (revenueByProductId.get(productId) || 0) + getOrderItemRevenue(item));
        costByProductId.set(productId, (costByProductId.get(productId) || 0) + getOrderItemCost(item, product));
      });
    });

  const productRows = (products || [])
    .filter(product => !product?.isArchived)
    .map(product => {
      const openingStock = getProductOpeningStock(product);
      const soldQuantity = soldByProductId.get(product.id) || 0;
      const remainingStock = Math.max(0, openingStock - soldQuantity);
      const stockUnit = getProductInventoryUnit(product);
      const costPrice = parseLooseMoneyValue(product.costPrice);
      const stockValue = remainingStock * costPrice;
      const soldCost = costByProductId.get(product.id) || 0;
      const revenue = revenueByProductId.get(product.id) || 0;
      return {
        ...product,
        inventoryGroup: getProductMainGroupLabel(product, product.name),
        stockUnit,
        openingStock,
        soldQuantity,
        remainingStock,
        stockValue,
        soldCost,
        revenue,
        grossProfit: revenue - soldCost
      };
    });

  const groupRows = Array.from(productRows.reduce((acc, product) => {
    const groupKey = `${product.inventoryGroup || 'ChÆ°a phĂ¢n nhĂ³m'}__${normalizeInventoryUnitKey(product.stockUnit)}`;
    const current = acc.get(groupKey) || {
      key: groupKey,
      label: product.inventoryGroup || 'ChÆ°a phĂ¢n nhĂ³m',
      unit: product.stockUnit || 'ÄÆ¡n vá»‹',
      productCount: 0,
      openingStock: 0,
      soldQuantity: 0,
      remainingStock: 0,
      stockValue: 0,
      revenue: 0,
      soldCost: 0,
      grossProfit: 0
    };
    current.productCount += 1;
    current.openingStock += product.openingStock || 0;
    current.soldQuantity += product.soldQuantity || 0;
    current.remainingStock += product.remainingStock || 0;
    current.stockValue += product.stockValue || 0;
    current.revenue += product.revenue || 0;
    current.soldCost += product.soldCost || 0;
    current.grossProfit += product.grossProfit || 0;
    acc.set(groupKey, current);
    return acc;
  }, new Map()).values()).sort((a, b) => {
    if ((b.stockValue || 0) !== (a.stockValue || 0)) return (b.stockValue || 0) - (a.stockValue || 0);
    return (a.label || '').localeCompare(b.label || '', 'vi');
  });

  const totals = productRows.reduce((acc, product) => {
    acc.openingStock += product.openingStock || 0;
    acc.soldQuantity += product.soldQuantity || 0;
    acc.remainingStock += product.remainingStock || 0;
    acc.stockValue += product.stockValue || 0;
    acc.revenue += product.revenue || 0;
    acc.soldCost += product.soldCost || 0;
    acc.grossProfit += product.grossProfit || 0;
    if ((product.openingStock || 0) > 0) acc.trackedProducts += 1;
    if ((product.remainingStock || 0) <= 0 && (product.openingStock || 0) > 0) acc.outOfStockProducts += 1;
    return acc;
  }, { openingStock: 0, soldQuantity: 0, remainingStock: 0, stockValue: 0, revenue: 0, soldCost: 0, grossProfit: 0, trackedProducts: 0, outOfStockProducts: 0 });

  return { productRows, groupRows, totals };
};

const DEFAULT_PROCESSING_INVENTORY_GROUPS = ['Vá»‹t', 'GĂ ', 'Heo', 'Váº­t tÆ°'];
const PROCESSING_INVENTORY_FIELD_KEYS = [
  'openingQty',
  'openingValue',
  'purchaseQty',
  'purchaseValue',
  'processingCost',
  'endingLiveQty',
  'endingLiveValue',
  'endingProcessedQty',
  'endingProcessedValue'
];
const PROCESSING_INVENTORY_MONEY_KEYS = [
  'openingValue',
  'purchaseValue',
  'processingCost',
  'endingLiveValue',
  'endingProcessedValue'
];

const buildProcessingInventoryGroupKey = (groupName = '') => {
  const normalized = normalizeLookupText(groupName || 'nhom').replace(/\s+/g, '_');
  return normalized || 'nhom';
};

const normalizeProcessingInventoryRecord = (record = {}, index = 0) => {
  const groupName = normalizeLeadingLabel(record.groupName || record.label || DEFAULT_PROCESSING_INVENTORY_GROUPS[index] || 'NhĂ³m hĂ ng');
  const normalized = {
    id: record.id || `group_${buildProcessingInventoryGroupKey(groupName)}_${index}`,
    groupName,
    unit: normalizeLeadingLabel(record.unit || 'Con'),
    note: `${record.note || ''}`.trim()
  };

  PROCESSING_INVENTORY_FIELD_KEYS.forEach((key) => {
    normalized[key] = key.toLowerCase().includes('value') || key === 'processingCost'
      ? parseLooseMoneyValue(record[key])
      : parseLooseQuantityValue(record[key]);
  });

  return normalized;
};

const hasProcessingInventoryInput = (record = {}) => PROCESSING_INVENTORY_FIELD_KEYS.some((key) => parseLooseQuantityValue(record[key]) > 0);
const hasProcessingInventoryCostInput = (record = {}) => PROCESSING_INVENTORY_MONEY_KEYS.some((key) => parseLooseMoneyValue(record[key]) > 0);
const calculateProcessingInventorySoldCost = (record = {}) => {
  if (!hasProcessingInventoryCostInput(record)) return 0;
  return Math.max(
    0,
    parseLooseMoneyValue(record.openingValue)
      + parseLooseMoneyValue(record.purchaseValue)
      + parseLooseMoneyValue(record.processingCost)
      - parseLooseMoneyValue(record.endingLiveValue)
      - parseLooseMoneyValue(record.endingProcessedValue)
  );
};

const summarizeWarehouseImportsByGroup = (warehouseImports = [], dateKey = '') => {
  const grouped = new Map();
  (warehouseImports || [])
    .filter(item => !item?.isArchived)
    .filter(item => !dateKey || item.date === dateKey)
    .forEach(item => {
      const groupName = normalizeLeadingLabel(item.groupName || item.productGroup || item.productNameSnapshot || 'NhĂ³m hĂ ng');
      const key = buildProcessingInventoryGroupKey(groupName);
      const current = grouped.get(key) || {
        key,
        groupName,
        unit: item.quantityUnit || item.unit || 'ÄÆ¡n vá»‹',
        quantity: 0,
        totalKg: 0,
        amount: 0,
        importCount: 0
      };
      current.quantity += parseLooseQuantityValue(item.quantity ?? item.totalQuantity);
      current.totalKg += parseLooseQuantityValue(item.totalKg ?? item.weightKg);
      current.amount += parseLooseMoneyValue(item.amount ?? item.totalAmount);
      current.importCount += 1;
      if (item.quantityUnit || item.unit) current.unit = item.quantityUnit || item.unit;
      grouped.set(key, current);
    });
  return grouped;
};

const normalizeProcessingInventorySnapshots = (snapshots = {}) => {
  if (!snapshots || typeof snapshots !== 'object') return {};
  return Object.entries(snapshots).reduce((acc, [dateKey, snapshot]) => {
    const records = Array.isArray(snapshot?.records)
      ? snapshot.records
      : Array.isArray(snapshot)
        ? snapshot
        : [];
    acc[dateKey] = {
      date: snapshot?.date || dateKey,
      updatedAt: snapshot?.updatedAt || '',
      records: records.map((record, index) => normalizeProcessingInventoryRecord(record, index))
    };
    return acc;
  }, {});
};

const getProcessingInventoryRecordsForDate = (company = null, dateKey = getTodayString()) => {
  const snapshots = normalizeProcessingInventorySnapshots(company?.dailyInventorySnapshots || company?.processingInventorySnapshots || {});
  return snapshots[dateKey]?.records || [];
};

const buildProcessingInventoryDraftRows = ({ company = null, date = getTodayString(), products = [], warehouseImports = [] } = {}) => {
  const savedRecords = getProcessingInventoryRecordsForDate(company, date);
  const savedByKey = new Map(savedRecords.map((record, index) => [buildProcessingInventoryGroupKey(record.groupName), normalizeProcessingInventoryRecord(record, index)]));
  const importSummaryByKey = summarizeWarehouseImportsByGroup(warehouseImports, date);
  const labels = [
    ...DEFAULT_PROCESSING_INVENTORY_GROUPS,
    ...products.map(product => getProductMainGroupLabel(product, product.name)),
    ...savedRecords.map(record => record.groupName),
    ...Array.from(importSummaryByKey.values()).map(item => item.groupName)
  ]
    .map(label => normalizeLeadingLabel(label || 'NhĂ³m hĂ ng'))
    .filter(Boolean);
  const uniqueLabels = Array.from(new Map(labels.map(label => [buildProcessingInventoryGroupKey(label), label])).values());

  return uniqueLabels.map((label, index) => {
    const key = buildProcessingInventoryGroupKey(label);
    const importSummary = importSummaryByKey.get(key);
    const baseRecord = savedByKey.get(key)
      || normalizeProcessingInventoryRecord({ groupName: label, unit: label === 'Váº­t tÆ°' ? 'CĂ¡i' : 'Con' }, index);
    if (!importSummary) return baseRecord;
    return {
      ...baseRecord,
      unit: importSummary.unit || baseRecord.unit,
      purchaseQty: importSummary.quantity || baseRecord.purchaseQty || 0,
      purchaseKg: importSummary.totalKg || 0,
      purchaseValue: importSummary.amount || baseRecord.purchaseValue || 0,
      importCount: importSummary.importCount || 0
    };
  });
};

const buildProcessingInventoryCostSummary = ({ orders = [], products = [], company = null, date = getTodayString(), records = null, warehouseImports = [] } = {}) => {
  const productMap = Object.fromEntries((products || []).map(product => [product.id, product]));
  const importSummaryByKey = summarizeWarehouseImportsByGroup(warehouseImports, date);
  const savedRecords = (records || getProcessingInventoryRecordsForDate(company, date))
    .map((record, index) => {
      const normalized = normalizeProcessingInventoryRecord(record, index);
      const importSummary = importSummaryByKey.get(buildProcessingInventoryGroupKey(normalized.groupName));
      if (!importSummary) return normalized;
      return {
        ...normalized,
        unit: importSummary.unit || normalized.unit,
        purchaseQty: importSummary.quantity || normalized.purchaseQty || 0,
        purchaseKg: importSummary.totalKg || 0,
        purchaseValue: importSummary.amount || normalized.purchaseValue || 0,
        importCount: importSummary.importCount || 0
      };
    });
  const recordByKey = new Map(savedRecords.map(record => [buildProcessingInventoryGroupKey(record.groupName), record]));
  const rowsByKey = new Map();

  (orders || [])
    .filter(order => !order?.isArchived)
    .forEach(order => {
      (order.items || []).forEach(item => {
        const product = productMap[item.productId];
        const groupName = getProductMainGroupLabel(product, item.description || product?.name || 'HĂ ng hĂ³a');
        const key = buildProcessingInventoryGroupKey(groupName);
        const record = recordByKey.get(key);
        const current = rowsByKey.get(key) || {
          key,
          groupName,
          unit: record?.unit || getOrderItemQuantityUnit(item, product) || getProductInventoryUnit(product) || 'ÄÆ¡n vá»‹',
          revenue: 0,
          quantity: 0,
          lineCount: 0,
          fallbackCost: 0,
          record: record || null
        };
        current.revenue += getOrderItemRevenue(item);
        current.quantity += getOrderItemQuantityValue(item);
        current.fallbackCost += getOrderItemCost(item, product);
        current.lineCount += 1;
        rowsByKey.set(key, current);
      });
    });

  savedRecords.forEach((record) => {
    const key = buildProcessingInventoryGroupKey(record.groupName);
    if (!rowsByKey.has(key)) {
      rowsByKey.set(key, {
        key,
        groupName: record.groupName,
        unit: record.unit || 'ÄÆ¡n vá»‹',
        revenue: 0,
        quantity: 0,
        lineCount: 0,
        fallbackCost: 0,
        record
      });
    }
  });

  const rows = Array.from(rowsByKey.values())
    .map((row) => {
      const record = row.record || {};
      const usesGroupCost = hasProcessingInventoryCostInput(record);
      const groupCost = calculateProcessingInventorySoldCost(record);
      const costOfGoods = usesGroupCost ? groupCost : row.fallbackCost;
      const endingValue = parseLooseMoneyValue(record.endingLiveValue) + parseLooseMoneyValue(record.endingProcessedValue);
      return {
        ...row,
        ...record,
        usesGroupCost,
        groupCost,
        costOfGoods,
        endingValue,
        grossProfit: row.revenue - costOfGoods
      };
    })
    .filter(row => row.revenue > 0 || hasProcessingInventoryInput(row))
    .sort((a, b) => {
      if ((b.revenue || 0) !== (a.revenue || 0)) return (b.revenue || 0) - (a.revenue || 0);
      return (a.groupName || '').localeCompare(b.groupName || '', 'vi');
    });

  const totals = rows.reduce((acc, row) => {
    acc.revenue += row.revenue || 0;
    acc.costOfGoods += row.costOfGoods || 0;
    acc.groupCost += row.usesGroupCost ? (row.groupCost || 0) : 0;
    acc.fallbackCost += row.usesGroupCost ? 0 : (row.fallbackCost || 0);
    acc.purchaseValue += parseLooseMoneyValue(row.purchaseValue);
    acc.processingCost += parseLooseMoneyValue(row.processingCost);
    acc.endingValue += row.endingValue || 0;
    acc.grossProfit += row.grossProfit || 0;
    acc.configuredGroups += row.usesGroupCost ? 1 : 0;
    return acc;
  }, { revenue: 0, costOfGoods: 0, groupCost: 0, fallbackCost: 0, purchaseValue: 0, processingCost: 0, endingValue: 0, grossProfit: 0, configuredGroups: 0 });

  return { rows, totals };
};

const buildOperatingCostSummaryForDate = ({
  targetDate = getTodayString(),
  orders = [],
  expenses = [],
  employees = [],
  attendance = {},
  holidays = [],
  productMap = {}
} = {}) => {
  const datedOrders = orders.filter(order => !order?.isArchived && order.date === targetDate);
  const directExpense = expenses
    .filter(expense => !expense?.isArchived && expense.date === targetDate)
    .reduce((sum, expense) => sum + (expense.amount || 0), 0);
  const costOfGoods = datedOrders.reduce((sum, order) => sum + estimateOrderCost(order, productMap), 0);
  const payrollExpense = calculateDailyPayrollExpense(employees, attendance, targetDate, holidays);

  return {
    directExpense,
    costOfGoods,
    payrollExpense,
    totalExpense: directExpense + costOfGoods + payrollExpense
  };
};

