      if (paymentByBankTransactionId.has(transaction.id)) return false;
      if (bankReconcileInFlightRef.current.has(transaction.id)) return false;
      const amount = resolveBankTransactionAmount(transaction);
      if (amount <= 0) return false;
      const direction = normalizeLookupText(transaction.direction || transaction.type || transaction.transactionType || '');
      return !direction || ['credit', 'in', 'income', 'deposit', 'receive', 'received', 'thu', 'tien vao'].some(token => direction.includes(token));
