    const nextWrites = [
      ...pendingFirebaseWritesRef.current.filter(item => item?.key !== key),
      nextWrite
    ];
    persistPendingFirebaseWrites(nextWrites);
    setRealtimeStatus({
      state: 'queued',
      collection: collectionName,
      lastAt: now,
      error: `Firebase Ä‘ang háº¿t quota hoáº·c pháº£n há»“i cháº­m. ÄĂ£ lÆ°u táº¡m ${nextWrites.length} lá»‡nh vĂ  sáº½ tá»± Ä‘á»“ng bá»™ láº¡i.`
