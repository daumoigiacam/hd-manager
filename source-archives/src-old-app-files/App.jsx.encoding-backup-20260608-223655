    const matches = [...raw.matchAll(/(\d+(?:[.,]\d+)?)\s*([^\d\s,.;:+-]*)/gi)];
    return matches
      .filter((match) => !isKgQuantityUnit(normalizeLookupText(match[2] || '')))
      .map((match) => parseVoiceNumber(match[1]))
      .filter((value) => value > 0);
