    const shiftPolicy = resolveEmployeeShiftPolicy(emp);
    const attendanceLocationSettings = getEmployeeAttendanceLocationSettings(emp);
    setEmpData({ 
      name: emp.name, phone: emp.phone, position: getEmployeePositionLabel(emp.position), 
